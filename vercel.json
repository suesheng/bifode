      "destination": "https://www.bifode.org/$1",
      "permanent": true,
      "has": [{ "type": "host", "value": "bifode.de" }]
    },
    {
      "source": "/(.*)",
      "destination": "https://www.bifode.org/$1",
      "permanent": true,
