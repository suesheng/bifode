---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout lang="en" title="Cookie Policy" description="Information about the use of cookies on this website.">
  <section class="container">
    <div class="section-header"><h2>Cookie Policy</h2></div>
    <p class="lead">This website uses technically necessary cookies and optional cookies for functionality, analytics, and marketing.</p>
    <p class="lead">You can change your cookie preferences at any time via the cookie settings link in the footer.</p>
  </section>
</MainLayout>

<style>
  .section-header h2 { font-size: 2rem; margin-bottom: 1rem; color: #111827; }
  .lead { color: #475569; line-height: 1.8; max-width: 760px; }
</style>
