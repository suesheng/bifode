---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';

const team = [
  { name: 'Name Surname', role: 'Board / project lead' },
  { name: 'Name Surname', role: 'Education & workshops' },
  { name: 'Name Surname', role: 'Cooperation & network' },
  { name: 'Name Surname', role: 'Communications & outreach' },
];

const timeline = [
  { year: '2024', text: 'Founding idea and first conversations with schools and partners in NRW.' },
  { year: '2025', text: 'Building association structures, developing education modules, and network work.' },
  { year: '2026', text: 'Launch of the NRW pilot project with first workshops and local partnerships.' },
];
---

<MainLayout
  lang="en"
  title="About"
  description="BiFoDe e.V. — Education Forum for Democracy and Diversity NRW. Mission, team, legal form, and founding history."
>
  <Hero
    lang="en"
    centered={false}
    title="About BiFoDe e.V."
    subtitle="Education Forum for Democracy and Diversity NRW — non-profit education and prevention work for schools and partners."
  />

  <section class="container">
    <div class="section-header"><h2>Our mission</h2></div>
    <p class="lead">
      We strengthen democratic education and antisemitism prevention in North Rhine-Westphalia. BiFoDe develops practical programmes for schools, municipalities, and civil society partners — with a clear stance, sound expertise, and respectful collaboration.
    </p>
  </section>

  <section class="container">
    <div class="section-header"><h2>Legal form &amp; status</h2></div>
    <div class="card legal-card">
      <p><strong>BiFoDe e.V.</strong> (Bildungsforum für Demokratie und Vielfalt NRW e.V.)</p>
      <ul>
        <li>Non-profit association <strong>currently in formation</strong></li>
        <li>Based and active in <strong>North Rhine-Westphalia</strong></li>
        <li>Focus: democratic education, antisemitism prevention, media literacy</li>
      </ul>
      <p class="legal-note">
        Details on registration in the association register will be added once the founding process is complete.
        The <a href="/en/statutes">statutes</a> are published on this website.
      </p>
    </div>
  </section>

  <section class="container">
    <div class="section-header"><h2>Founding history</h2></div>
    <ol class="timeline">
      {timeline.map((item) => (
        <li>
          <span class="timeline-year">{item.year}</span>
          <p>{item.text}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="container">
    <div class="section-header"><h2>Team</h2></div>
    <p class="lead">Our team is growing with the pilot project. The profiles below are placeholders until final introductions are published.</p>
    <div class="card-grid team-grid">
      {team.map((member) => (
        <article class="card team-card">
          <span class="team-avatar" aria-hidden="true">{member.name.charAt(0)}</span>
          <h3>{member.name}</h3>
          <p>{member.role}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container cta-section">
    <a class="btn-outline" href="/en/cooperation">Start a cooperation →</a>
  </section>
</MainLayout>

<style>
  .section-header h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #111827;
  }

  .lead {
    color: #475569;
    line-height: 1.8;
    max-width: 720px;
  }

  .legal-card ul {
    margin: 0.75rem 0;
    padding-left: 1.25rem;
    line-height: 1.8;
    color: #334155;
  }

  .legal-note {
    margin: 1rem 0 0;
    font-size: 0.9rem;
    color: #64748b;
  }

  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid #dbeafe;
    max-width: 720px;
  }

  .timeline li {
    position: relative;
    padding: 0 0 1.5rem 1.5rem;
  }

  .timeline li::before {
    content: '';
    position: absolute;
    left: -7px;
    top: 0.35rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #163b63;
  }

  .timeline-year {
    display: block;
    font-weight: 700;
    color: #163b63;
    margin-bottom: 0.25rem;
  }

  .timeline p {
    margin: 0;
    color: #475569;
    line-height: 1.7;
  }

  .team-grid {
    margin-top: 1.5rem;
  }

  .team-card {
    text-align: center;
  }

  .team-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e8f1ff, #dbeafe);
    color: #163b63;
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .team-card h3 {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
  }

  .team-card p {
    margin: 0;
    color: #64748b;
    font-size: 0.9rem;
  }

  .cta-section {
    padding: 2rem 0 3rem;
    text-align: center;
  }
</style>
