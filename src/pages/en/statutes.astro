---
import MainLayout from '../../layouts/MainLayout.astro';
import SatzungDocument from '../../components/SatzungDocument.astro';
---

<MainLayout
  title="Statutes"
  description="Statutes of BiFoDe e.V. (German)."
  lang="en"
>
  <div class="container satzung-page">
    <p class="satzung-intro">
      The statutes govern the association’s purpose, membership, governing bodies, and fees. The document below
      is in German (official language of the association).
    </p>
    <SatzungDocument />
    <p class="satzung-footer-note">
      Questions: <a href="mailto:info@bifode.org">info@bifode.org</a> ·{' '}
      <a href="/en/membership">Apply for membership</a>
    </p>
  </div>
</MainLayout>

<style>
  .satzung-page {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
  }

  .satzung-intro {
    margin: 0 0 1.5rem;
    color: #334155;
    line-height: 1.65;
  }

  .satzung-footer-note {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid #e2e8f0;
    font-size: 0.9rem;
    color: #64748b;
  }

  .satzung-page a {
    color: #163b63;
  }
</style>
