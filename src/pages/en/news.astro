---
export const prerender = true;

import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';

const posts = (await getCollection('aktuelles'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<MainLayout
  lang="en"
  title="News"
  description="News, reports, and announcements from BiFoDe e.V.'s education and prevention work in NRW."
>
  <Hero
    lang="en"
    centered={false}
    title="News"
    subtitle="Updates from our educational and prevention work in North Rhine-Westphalia."
  />

  <section class="container">
    <p class="language-note">News posts are currently published in German.</p>

    {posts.length === 0 ? (
      <p class="lead">No posts are published at the moment.</p>
    ) : (
      <ul class="news-list">
        {posts.map((post) => (
          <li>
            <article class="card news-card">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              <h2>
                <a href={`/aktuelles/${post.id}`}>{post.data.title}</a>
              </h2>
              <p>{post.data.description}</p>
              <a class="btn-outline" href={`/aktuelles/${post.id}`}>Read in German -></a>
            </article>
          </li>
        ))}
      </ul>
    )}
  </section>
</MainLayout>

<style>
  .language-note {
    margin: 0 0 1.5rem;
    color: #475569;
    line-height: 1.7;
    font-weight: 500;
  }

  .lead {
    color: #475569;
    line-height: 1.8;
  }

  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }

  .news-card time {
    display: block;
    font-size: 0.875rem;
    color: #64748b;
    margin-bottom: 0.5rem;
  }

  .news-card h2 {
    margin: 0 0 0.75rem;
    font-size: 1.35rem;
  }

  .news-card h2 a {
    color: #111827;
    text-decoration: none;
  }

  .news-card h2 a:hover {
    color: #163b63;
  }

  .news-card p {
    margin: 0 0 0.5rem;
    color: #475569;
    line-height: 1.7;
  }
</style>
