---
import MainLayout from '../../layouts/MainLayout.astro';
import { SATZUNG_PAGE_EN } from '../../lib/vereinDocs';
---

<MainLayout lang="en" title="Legal Notice" description="Legal notice of Bildungsforum für Demokratie und Vielfalt NRW e.V. (BiFoDe e.V.)">
  <div class="container">
    <h1>Legal notice</h1>

    <div class="content-section">
      <h2>Information pursuant to Section 5 DDG</h2>
      <p>
        <strong>Bildungsforum für Demokratie und Vielfalt NRW e.V.</strong><br />
        BiFoDe e.V.
      </p>
      <p>
        <strong>Represented by:</strong><br />
        Denis Vilensky, Board member
      </p>
      <p>
        <strong>Contact:</strong><br />
        Email: <a href="mailto:info@bifode.org">info@bifode.org</a>
      </p>
      <p>
        <strong>Address:</strong><br />
        North Rhine-Westphalia, Germany
      </p>
    </div>

    <div class="content-section">
      <h2>Register entry</h2>
      <p>
        Registered in the association register (<em>Vereinsregister</em>).<br />
        Register court: Local Court (Amtsgericht) Wuppertal<br />
        Register number: VR 31702
      </p>
    </div>

    <div class="content-section">
      <h2>Statutes</h2>
      <p>
        The statutes of BiFoDe e.V. are published on this website:
        <a href={SATZUNG_PAGE_EN}>Statutes</a> (German official text).
      </p>
    </div>

    <div class="content-section">
      <h2>Responsible for content</h2>
      <p>
        Denis Vilensky<br />
        Email: <a href="mailto:info@bifode.org">info@bifode.org</a>
      </p>
    </div>

    <div class="content-section">
      <h2>Liability for content</h2>
      <p>
        The contents of this website have been prepared with care. However, we cannot guarantee accuracy, completeness, or timeliness. As a service provider, we are responsible for our own content on these pages in accordance with general laws.
      </p>
    </div>

    <div class="content-section">
      <h2>Liability for links</h2>
      <p>
        External links lead to third-party content. We have no influence over that content and expressly distance ourselves from unlawful content on linked pages.
      </p>
    </div>

    <div class="content-section">
      <h2>Copyright</h2>
      <p>
        The contents of this website are subject to German copyright law. Reproduction, editing, or use requires the written consent of the rights holder.
      </p>
    </div>

    <div class="content-section">
      <h2>Dispute resolution</h2>
      <p>
        The European Commission provides a platform for online dispute resolution:
        <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer">https://ec.europa.eu/consumers/odr/</a>
      </p>
    </div>
  </div>
</MainLayout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  h1 {
    color: #111827;
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }

  .content-section {
    margin-bottom: 2rem;
  }

  .content-section h2 {
    color: #111827;
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .content-section p {
    margin-bottom: 1rem;
    line-height: 1.6;
    color: #374151;
  }

  .content-section p:last-child {
    margin-bottom: 0;
  }

  a {
    color: #3b82f6;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  strong {
    font-weight: 600;
  }
</style>
