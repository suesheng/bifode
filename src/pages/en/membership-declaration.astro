---
import MainLayout from '../../layouts/MainLayout.astro';
import { getSpendenBankDetails } from '../../lib/spendenBank';
import { MONTHLY_EUR, formatEur, getMembershipFeeAmounts } from '../../lib/membershipFees';

const { monthlyStudent, annualStandard, annualStudent } = getMembershipFeeAmounts();
const bank = getSpendenBankDetails('en');

const pageDescription =
  'Membership declaration for BiFoDe e.V. — fill in in the browser and save as PDF (print).';
---

<MainLayout
  lang="en"
  title="Membership declaration"
  description={pageDescription}
  mainClass="beitritt-main"
>
  <div class="beitritt-toolbar no-print" aria-label="Document actions">
    <div class="container beitritt-toolbar-inner">
      <a href="/mitglied-werden" class="beitritt-back">← Back to membership</a>
      <div class="beitritt-toolbar-actions">
        <button type="button" class="beitritt-btn" id="beitritt-print">Save as PDF / print</button>
      </div>
    </div>
    <p class="container beitritt-toolbar-hint">
      Tip: In the print dialog choose “Save as PDF”. Fill in the fields in the browser first.
    </p>
  </div>

  <article class="beitritt-doc container" id="beitritt-document" lang="en">
    <header class="beitritt-header">
      <p class="beitritt-org">BiFoDe e.V.</p>
      <p class="beitritt-org-sub">Bildungsforum für Demokratie und Vielfalt NRW e.V.</p>
      <h1>Declaration of membership</h1>
      <p class="beitritt-draft">
        <strong>Draft.</strong> The association is being established. This declaration is for admission as a member
        following a decision by the board. The applicable statutes and board resolutions take precedence.
      </p>
    </header>

    <section>
      <h2>1. Applicant details</h2>
      <div class="beitritt-grid">
        <label class="beitritt-field">
          <span>First name</span>
          <input type="text" name="firstName" autocomplete="given-name" />
        </label>
        <label class="beitritt-field">
          <span>Last name</span>
          <input type="text" name="lastName" autocomplete="family-name" />
        </label>
        <label class="beitritt-field beitritt-field-wide">
          <span>Street and number</span>
          <input type="text" name="street" autocomplete="street-address" />
        </label>
        <label class="beitritt-field">
          <span>Postal code</span>
          <input type="text" name="postalCode" autocomplete="postal-code" />
        </label>
        <label class="beitritt-field">
          <span>City</span>
          <input type="text" name="city" autocomplete="address-level2" />
        </label>
        <label class="beitritt-field">
          <span>Email</span>
          <input type="email" name="email" autocomplete="email" />
        </label>
        <label class="beitritt-field">
          <span>Phone (optional)</span>
          <input type="tel" name="phone" autocomplete="tel" />
        </label>
        <label class="beitritt-field">
          <span>Date of birth (optional)</span>
          <input type="text" name="birthDate" placeholder="DD.MM.YYYY" />
        </label>
      </div>
    </section>

    <section>
      <h2>2. Membership and fee</h2>
      <p>I apply for admission as an <strong>ordinary member</strong> of BiFoDe e.V.</p>

      <fieldset class="beitritt-fieldset">
        <legend>Fee category (please tick one)</legend>
        <label class="beitritt-check">
          <input type="radio" name="feeCategory" value="standard" />
          Standard — {formatEur(MONTHLY_EUR)} € / month (regular fee)
        </label>
        <label class="beitritt-check">
          <input type="radio" name="feeCategory" value="student" />
          Student — {formatEur(monthlyStudent)} € / month (reduced rate; proof required)
        </label>
      </fieldset>

      <fieldset class="beitritt-fieldset">
        <legend>Payment schedule (please tick one)</legend>
        <label class="beitritt-check">
          <input type="radio" name="payment" value="monthly-standard" />
          Monthly (standard) — {formatEur(MONTHLY_EUR)} €
        </label>
        <label class="beitritt-check">
          <input type="radio" name="payment" value="monthly-student" />
          Monthly (student) — {formatEur(monthlyStudent)} € (reduced)
        </label>
        <label class="beitritt-check">
          <input type="radio" name="payment" value="annual-standard" />
          Annual (standard) — {formatEur(annualStandard)} € (annual discount)
        </label>
        <label class="beitritt-check">
          <input type="radio" name="payment" value="annual-student" />
          Annual (student) — {formatEur(annualStudent)} € (reduced + annual discount)
        </label>
      </fieldset>

      <p class="beitritt-small">
        The fee is a membership contribution under the statutes, not a donation. Changes follow the statutes and board
        decisions.
      </p>
    </section>

    <section>
      <h2>3. Declarations</h2>
      <ol class="beitritt-list">
        <li>
          I have taken note of the statutes of BiFoDe e.V. and accept them once provided or published by the
          association.
        </li>
        <li>I undertake to pay the membership fee determined by the association on time.</li>
        <li>
          I agree that my data may be processed for membership administration, communication, and billing. Details:{' '}
          <a href="/en/privacy">Privacy policy</a>.
        </li>
        <li>
          Membership grants access to association programmes subject to availability; it does not guarantee specific
          events or services.
        </li>
      </ol>
      <label class="beitritt-check beitritt-check-block">
        <input type="checkbox" name="confirm" />
        I confirm the information and declarations above.
      </label>
    </section>

    <section>
      <h2>4. Payment / SEPA direct debit (optional)</h2>
      <p>
        Instead of a transfer, a SEPA direct debit mandate may be issued. Until set up, fees may be paid by transfer or
        standing order to:
      </p>
      <dl class="beitritt-bank">
        <div><dt>Account holder</dt><dd>{bank.accountHolder}</dd></div>
        <div><dt>Bank</dt><dd>{bank.bankName}</dd></div>
        <div><dt>IBAN</dt><dd>{bank.iban}</dd></div>
        {bank.blz && (
          <div><dt>Bank code (BLZ)</dt><dd>{bank.blz}</dd></div>
        )}
        <div><dt>Payment reference</dt><dd>Membership fee BiFoDe e.V.</dd></div>
      </dl>

      <label class="beitritt-check beitritt-check-block">
        <input type="checkbox" name="sepa" />
        I authorise SEPA direct debit (mandate to be provided or confirmed by the association after admission).
      </label>
      <div class="beitritt-grid beitritt-sepa">
        <label class="beitritt-field beitritt-field-wide">
          <span>IBAN (direct debit)</span>
          <input type="text" name="sepa-iban" />
        </label>
        <label class="beitritt-field">
          <span>BIC (if required)</span>
          <input type="text" name="sepa-bic" />
        </label>
        <label class="beitritt-field beitritt-field-wide">
          <span>Account holder (if different)</span>
          <input type="text" name="sepa-holder" />
        </label>
      </div>
    </section>

    <section class="beitritt-sign">
      <h2>5. Signature</h2>
      <div class="beitritt-grid">
        <label class="beitritt-field">
          <span>Place</span>
          <input type="text" name="place" />
        </label>
        <label class="beitritt-field">
          <span>Date</span>
          <input type="text" name="date" placeholder="DD.MM.YYYY" />
        </label>
      </div>
      <p class="beitritt-line-label">Signature of applicant</p>
      <div class="beitritt-signature-line" aria-hidden="true"></div>
      <p class="beitritt-small">For minors: additional signature of legal guardian.</p>
    </section>

    <section class="beitritt-verein only-print-block">
      <h2>6. For the association (completed by the board)</h2>
      <p>Admission resolved on: _________________________</p>
      <p>Member number (optional): _________________________</p>
      <p class="beitritt-line-label">Signature of board</p>
      <div class="beitritt-signature-line" aria-hidden="true"></div>
    </section>

    <footer class="beitritt-footer">
      <p>
        Submit the completed declaration by email to{' '}
        <a href="mailto:info@bifode.org?subject=Membership%20declaration%20BiFoDe%20e.V.">info@bifode.org</a> (PDF
        attachment) or by post to the address provided by the association. You may also use the{' '}
        <a href="/mitglied-werden#anmeldung">online form</a> first.
      </p>
      <p class="beitritt-small">BiFoDe e.V. · North Rhine-Westphalia · www.bifode.org</p>
    </footer>
  </article>
</MainLayout>

<style>
  .beitritt-main {
    background: #eef2f7;
    padding-bottom: 3rem;
  }

  .beitritt-toolbar {
    padding: 1.25rem 0 0.5rem;
    background: #fff;
    border-bottom: 1px solid #e2e8f0;
    position: sticky;
    top: 0;
    z-index: 40;
  }

  .beitritt-toolbar-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .beitritt-toolbar-hint {
    margin: 0.5rem auto 0;
    font-size: 0.85rem;
    color: #64748b;
  }

  .beitritt-back {
    color: #1e3a8a;
    font-weight: 600;
    text-decoration: none;
  }

  .beitritt-btn {
    padding: 0.6rem 1.1rem;
    border: none;
    border-radius: 0.5rem;
    background: #1e3a8a;
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
  }

  .beitritt-btn:hover {
    background: #1d4ed8;
  }

  .beitritt-doc {
    max-width: 800px;
    margin: 1.5rem auto 0;
    padding: 2rem 2.25rem 2.5rem;
    background: #fff;
    border: 1px solid #dbe5f1;
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(15, 23, 42, 0.06);
    color: #111827;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .beitritt-header h1 {
    margin: 0.35rem 0 0.75rem;
    font-size: 1.65rem;
    color: #0c1e34;
  }

  .beitritt-org {
    margin: 0;
    font-weight: 700;
    color: #1e3a8a;
  }

  .beitritt-org-sub {
    margin: 0.15rem 0 0;
    font-size: 0.9rem;
    color: #475569;
  }

  .beitritt-draft {
    margin: 0;
    padding: 0.75rem 1rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 8px;
    font-size: 0.88rem;
  }

  .beitritt-doc h2 {
    margin: 1.75rem 0 0.65rem;
    font-size: 1.1rem;
    color: #0c1e34;
    page-break-after: avoid;
  }

  .beitritt-doc section {
    page-break-inside: avoid;
  }

  .beitritt-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem 1rem;
  }

  .beitritt-field-wide {
    grid-column: 1 / -1;
  }

  .beitritt-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .beitritt-field span {
    font-size: 0.8rem;
    font-weight: 600;
    color: #475569;
  }

  .beitritt-field input {
    border: none;
    border-bottom: 1px solid #94a3b8;
    padding: 0.35rem 0;
    font-size: 1rem;
    font-family: inherit;
    background: transparent;
  }

  .beitritt-field input:focus {
    outline: none;
    border-bottom-color: #1e3a8a;
    box-shadow: 0 1px 0 #1e3a8a;
  }

  .beitritt-fieldset {
    margin: 1rem 0 0;
    padding: 0.85rem 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
  }

  .beitritt-fieldset legend {
    font-weight: 600;
    padding: 0 0.25rem;
  }

  .beitritt-check {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin: 0.5rem 0 0;
    cursor: pointer;
  }

  .beitritt-check-block {
    margin-top: 1rem;
  }

  .beitritt-check input {
    margin-top: 0.2rem;
    flex-shrink: 0;
  }

  .beitritt-list {
    margin: 0;
    padding-left: 1.25rem;
  }

  .beitritt-list li {
    margin-bottom: 0.5rem;
  }

  .beitritt-bank {
    margin: 0.75rem 0;
    display: grid;
    gap: 0.35rem;
    font-size: 0.92rem;
  }

  .beitritt-bank div {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0.5rem;
  }

  .beitritt-bank dt {
    font-weight: 600;
    color: #64748b;
    margin: 0;
  }

  .beitritt-bank dd {
    margin: 0;
  }

  .beitritt-small {
    font-size: 0.82rem;
    color: #64748b;
  }

  .beitritt-line-label {
    margin: 1.25rem 0 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .beitritt-signature-line {
    height: 2.5rem;
    border-bottom: 1px solid #334155;
    max-width: 20rem;
  }

  .beitritt-footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #e2e8f0;
    font-size: 0.88rem;
    color: #475569;
  }

  .beitritt-footer a {
    color: #1e3a8a;
  }

  @media (max-width: 600px) {
    .beitritt-doc {
      padding: 1.25rem 1rem 1.75rem;
    }

    .beitritt-grid {
      grid-template-columns: 1fr;
    }

    .beitritt-bank div {
      grid-template-columns: 1fr;
    }
  }

  @media print {
    .no-print,
    .navbar,
    .footer,
    #cookie-banner,
    .lang-switch {
      display: none !important;
    }

    .beitritt-main,
    html,
    body {
      background: #fff !important;
    }

    .beitritt-doc {
      margin: 0;
      padding: 0;
      border: none;
      box-shadow: none;
      max-width: none;
    }

    .beitritt-field input {
      border-bottom: 1px solid #000;
    }

    @page {
      margin: 1.5cm;
      size: A4;
    }
  }
</style>

<script>
  function initBeitrittPrint() {
    const btn = document.getElementById('beitritt-print');
    btn?.addEventListener('click', () => window.print());
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBeitrittPrint, { once: true });
  } else {
    initBeitrittPrint();
  }
</script>
