---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';
import { publicEnv } from '../../lib/publicEnv';
import { getSpendenBankDetails } from '../../lib/spendenBank';

const description =
  'Donate to BiFoDe e.V. — education and prevention work in North Rhine-Westphalia. Bank transfer, donation receipts, and tax information.';

const donationUrl = publicEnv('PUBLIC_DONATION_URL');
const { iban, bic, bankName, blz, accountHolder, paymentReference, hasBankDetails } =
  getSpendenBankDetails('en');

const impactAreas = [
  {
    title: 'Schools & prevention',
    text: 'Workshops, project days, and materials on democracy, antisemitism prevention, and media literacy in NRW.',
  },
  {
    title: 'Community & language',
    text: 'Hebrew- and Israel-related education, meetings, and networking — including Israel Community and Israel Hub DACH.',
  },
  {
    title: 'Projects & network',
    text: 'Pilot projects, partnerships, and building sustainable organisational structures.',
  },
];
---

<MainLayout lang="en" title="Donate" description={description}>
  <Hero
    lang="en"
    centered={false}
    title="Donate"
    subtitle="Your support strengthens democratic education, prevention work, and community programmes by BiFoDe e.V. in North Rhine-Westphalia."
  />

  <div class="sp-page">
    <section class="container sp-section">
      <div class="sp-stack">
        <h2>What your donation supports</h2>
        <p class="sp-lead">
          BiFoDe e.V. (Bildungsforum für Demokratie und Vielfalt NRW) develops education and prevention formats for schools, partners, and communities. Donations fund our association’s work — planning, delivery, and further development of our programmes.
        </p>
        <div class="sp-card-grid">
          {impactAreas.map((area) => (
            <article class="sp-card">
              <h3>{area.title}</h3>
              <p>{area.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="container sp-section sp-section-alt" id="ways-to-donate" aria-labelledby="sp-ways-title">
      <div class="sp-stack">
        <h2 id="sp-ways-title">How to donate</h2>

        <article class="sp-panel" id="bank-transfer" aria-labelledby="sp-bank-title">
          <h3 id="sp-bank-title">Bank transfer</h3>
          {hasBankDetails ? (
            <dl class="sp-bank-dl">
              <div>
                <dt>Account holder</dt>
                <dd>{accountHolder}</dd>
              </div>
              {bankName && (
                <div>
                  <dt>Bank</dt>
                  <dd>{bankName}</dd>
                </div>
              )}
              <div>
                <dt>IBAN</dt>
                <dd><code class="sp-mono">{iban}</code></dd>
              </div>
              {blz && (
                <div>
                  <dt>Bank code (BLZ)</dt>
                  <dd><code class="sp-mono">{blz}</code></dd>
                </div>
              )}
              {bic && (
                <div>
                  <dt>BIC</dt>
                  <dd><code class="sp-mono">{bic}</code></dd>
                </div>
              )}
              <div>
                <dt>Payment reference</dt>
                <dd><code class="sp-mono">{paymentReference}</code></dd>
              </div>
            </dl>
          ) : (
            <p>
              Bank details for donations will be published here shortly. Until then, please contact us at{' '}
              <a href="mailto:info@bifode.org?subject=Donation%20BiFoDe%20e.V.">info@bifode.org</a> and we will send you the payment information.
            </p>
          )}
          <p class="sp-small">
            Please enter your first and last name and “Donation” in the payment reference (e.g. <code class="sp-mono">Jane Doe, Donation</code>) so we can allocate your gift. For donation receipts we need your full postal address.
          </p>
        </article>

        {donationUrl && (
          <article class="sp-panel" aria-labelledby="sp-online-title">
            <h3 id="sp-online-title">Donate online</h3>
            <p>
              You can also support us via our external donation page. The provider’s privacy policy applies.
            </p>
            <p class="sp-actions">
              <a href={donationUrl} class="sp-btn sp-btn-primary" target="_blank" rel="noopener noreferrer">
                Donate online now
              </a>
            </p>
          </article>
        )}

        <article class="sp-panel sp-panel-muted" aria-labelledby="sp-contact-title">
          <h3 id="sp-contact-title">Questions or larger gifts</h3>
          <p>
            For corporate donations, standing orders, or questions about project funding, please get in touch — we will respond as soon as possible.
          </p>
          <p class="sp-actions">
            <a href="/en/contact" class="sp-btn sp-btn-secondary">Contact us</a>
            <a href="mailto:info@bifode.org?subject=Donation%20BiFoDe%20e.V." class="sp-btn sp-btn-secondary">info@bifode.org</a>
          </p>
        </article>
      </div>
    </section>

    <section class="container sp-section" aria-labelledby="sp-diff-title">
      <div class="sp-stack">
        <h2 id="sp-diff-title">Donation or membership?</h2>
        <p class="sp-lead">
          A <strong>donation</strong> is a voluntary one-off or recurring gift without membership rights. <a href="/en/membership">Membership</a> is an ongoing association fee with access to member benefits under the statutes and board decisions.
        </p>
        <p class="sp-lead">Both forms of support help our work — choose what suits you.</p>
      </div>
    </section>

    <section class="container sp-section sp-section-alt" aria-labelledby="sp-tax-title">
      <div class="sp-stack">
        <h2 id="sp-tax-title">Tax information &amp; donation receipts</h2>
        <div class="sp-note-box">
          <p>
            <strong>Non-profit status:</strong> BiFoDe e.V. is currently <strong>in formation</strong>. Application for recognition of charitable status and registration in the association register are not yet complete. Until recognition is granted, we cannot make binding statements on tax deductibility.
          </p>
          <p>
            <strong>Donation receipts:</strong> Once legal requirements are met, we will issue donation receipts where permitted. Please provide your name and address with the transfer or contact us after donating.
          </p>
          <p class="sp-small">
            This information does not constitute tax or legal advice. Tax treatment depends on your personal situation and applicable law.
          </p>
        </div>
        <p class="sp-links">
          <a href="/en/legal-notice">Legal notice</a>
          ·
          <a href="/en/privacy">Privacy policy</a>
        </p>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .sp-page {
    --sp-navy: #0c1e34;
    --sp-blue: #1e3a8a;
    padding-bottom: 2.5rem;
  }

  .sp-section {
    padding: 2.25rem 0;
  }

  .sp-section-alt {
    background: #fff;
  }

  .sp-stack {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
  }

  .sp-stack h2 {
    margin: 0 0 1rem;
    font-size: clamp(1.45rem, 3vw, 1.9rem);
    color: var(--sp-navy);
  }

  .sp-lead {
    margin: 0 0 1.25rem;
    color: #334155;
    line-height: 1.75;
  }

  .sp-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 200px), 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .sp-card {
    padding: 1.15rem 1.25rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
  }

  .sp-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    color: var(--sp-navy);
  }

  .sp-card p {
    margin: 0;
    color: #475569;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .sp-panel {
    margin-top: 1.25rem;
    padding: 1.35rem 1.5rem;
    background: #f8fafc;
    border: 1px solid #dbe5f1;
    border-radius: 14px;
  }

  .sp-panel-muted {
    background: #fff;
  }

  .sp-panel h3 {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
    color: var(--sp-navy);
  }

  .sp-panel p {
    margin: 0 0 0.75rem;
    color: #334155;
    line-height: 1.65;
  }

  .sp-panel p:last-child {
    margin-bottom: 0;
  }

  .sp-bank-dl {
    margin: 0 0 1rem;
    display: grid;
    gap: 0.65rem;
  }

  .sp-bank-dl div {
    display: grid;
    gap: 0.15rem;
  }

  .sp-bank-dl dt {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #64748b;
  }

  .sp-bank-dl dd {
    margin: 0;
    color: #1e293b;
    font-size: 1rem;
  }

  .sp-mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.95rem;
    word-break: break-all;
  }

  .sp-small {
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.55;
  }

  .sp-note-box {
    padding: 1.25rem 1.35rem;
    background: #eef3fc;
    border-left: 4px solid var(--sp-blue);
    border-radius: 0 10px 10px 0;
  }

  .sp-note-box p {
    margin: 0 0 0.85rem;
    color: #1e293b;
    line-height: 1.65;
  }

  .sp-note-box p:last-child {
    margin-bottom: 0;
  }

  .sp-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 0.5rem;
  }

  .sp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 1.15rem;
    border-radius: 0.65rem;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border: 2px solid transparent;
    transition: background 0.2s, transform 0.2s;
  }

  .sp-btn-primary {
    background: var(--sp-blue);
    color: #fff;
    border-color: var(--sp-blue);
  }

  .sp-btn-primary:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  .sp-btn-secondary {
    background: #fff;
    color: var(--sp-blue);
    border-color: #89a6cc;
  }

  .sp-btn-secondary:hover {
    background: #e8f1ff;
  }

  .sp-links {
    margin: 1.25rem 0 0;
    font-size: 0.95rem;
  }

  .sp-links a {
    color: var(--sp-blue);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .sp-actions .sp-btn {
      width: 100%;
    }
  }
</style>
