---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';
---

<MainLayout lang="en" title="Schools" description="Educational formats on antisemitism, prejudice, media literacy, and democratic cohesion.">
  <Hero lang="en" centered={false} title="Programs for Schools" subtitle="Educational formats on antisemitism, prejudice, media literacy, and democratic cohesion." />

  <section class="container">
    <div class="section-header"><h2>Why This Program?</h2></div>
    <p class="lead">Schools increasingly face polarization and disinformation in daily practice. We provide practical, age-appropriate formats.</p>
  </section>

  <section class="container">
    <div class="section-header"><h2>Target Groups</h2></div>
    <div class="card-grid">
      <div class="card feature-card"><h3>Lower Secondary Students</h3></div>
      <div class="card feature-card"><h3>Upper Secondary Students</h3></div>
      <div class="card feature-card"><h3>Teachers</h3></div>
      <div class="card feature-card"><h3>Educational Professionals</h3></div>
    </div>
  </section>
</MainLayout>

<style>
  .section-header h2 { font-size: 2rem; margin-bottom: 1rem; color: #111827; }
  .lead { color: #475569; line-height: 1.8; max-width: 720px; }
</style>
