---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustSection from '../../components/TrustSection.astro';
import StatsBar from '../../components/StatsBar.astro';
import CommunityChannels from '../../components/CommunityChannels.astro';
import { MOODLE_INFO_PATH, ULPAN_LANDING_PATH_EN } from '../../lib/communityLinks';
import { PILOT_LANDING_PATH } from '../../lib/projectCards';
---

<MainLayout lang="en" title="Home" description="BiFoDe e.V. develops education and prevention programmes for schools and partners in North Rhine-Westphalia.">
  <Hero
    lang="en"
    centered={true}
    title="Strengthen education. Challenge prejudice. Live democracy in practice."
    subtitle="BiFoDe e.V. (Education Forum for Democracy and Diversity NRW) delivers education and prevention programmes across North Rhine-Westphalia."
    tertiaryLinks={[
      { href: ULPAN_LANDING_PATH_EN, label: 'Ulpan Next →' },
      { href: '/en/moodle', label: 'Moodle →' },
    ]}
  />

  <StatsBar lang="en" />

  <TrustSection
    lang="en"
    partnerTitle="Our partners"
    label="Collaboration and exchange with partners from education and civil society"
    cooperationHref="/en/cooperation"
    cooperationLabel="More on cooperation →"
    mobileHidden={false}
  />

  <section class="container">
    <div class="section-header">
      <h2>Who we are</h2>
    </div>
    <p class="lead">We strengthen education and social cohesion in North Rhine-Westphalia (NRW). We provide practical programmes for schools, municipalities, and civil society partners with a clear stance against antisemitism.</p>
    <p class="section-cta-wrap">
      <a class="btn-outline" href="/en/about">More about us →</a>
    </p>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Our work</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M4 6.5A2.5 2.5 0 0 1 6.5 4H20v15.5A2.5 2.5 0 0 0 17.5 17H4z" /><path d="M4 6.5V20h13.5A2.5 2.5 0 0 0 20 17" /><path d="M8 8h8M8 11h8" /></svg>
        </div>
        <h3>Education &amp; prevention</h3>
        <p>Programmes that support respectful coexistence and early prevention work.</p>
        <a href="/en/contact" class="btn-outline">Request a workshop →</a>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><circle cx="9" cy="8" r="3" /><circle cx="16" cy="10" r="2.5" /><path d="M3.5 18a5.5 5.5 0 0 1 11 0" /><path d="M13.5 18a4 4 0 0 1 7 0" /></svg>
        </div>
        <h3>Guidance &amp; support</h3>
        <p>Practical guidance for teachers, schools, and partner organisations.</p>
        <a href="/en/our-work" class="btn-outline">Learn more →</a>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="6" /><path d="m20 20-4.2-4.2" /><path d="M11 8v6M8 11h6" /></svg>
        </div>
        <h3>Analysis &amp; context</h3>
        <p>Reliable background analysis that informs our educational work.</p>
        <a href="/en/projects" class="btn-outline">Learn more →</a>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Who we work with</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M3 10.5 12 5l9 5.5-9 5.5z" /><path d="M7 12.5V16a5 3 0 0 0 10 0v-3.5" /></svg>
        </div>
        <h3>Schools</h3>
        <p>Programmes for teachers and schools that promote democratic learning and mutual respect.</p>
        <a href="/en/schools" class="btn-outline">Request a workshop →</a>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M8 14a3 3 0 1 1 0-6c1.2 0 2.2.7 2.7 1.7A3 3 0 1 1 13 14c-.9 0-1.6-.3-2.2-.8A3 3 0 0 1 8 14Z" /><path d="M4.5 19a3.5 3.5 0 0 1 6.5-1.8A3.5 3.5 0 0 1 17.5 19" /></svg>
        </div>
        <h3>Partners &amp; NGOs</h3>
        <p>Reliable cooperation with civil society organisations and education partners.</p>
        <a href="/en/cooperation" class="btn-outline">Start a cooperation →</a>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M4 20h16" /><path d="M5 20V9h14v11" /><path d="M3 9h18L12 4z" /><path d="M9 13h6v7H9z" /></svg>
        </div>
        <h3>Public institutions</h3>
        <p>Advice and programmes for municipalities and institutional partners.</p>
        <a href="/en/cooperation" class="btn-outline">Start a cooperation →</a>
      </div>
    </div>
  </section>

  <CommunityChannels lang="en" />

  <section class="container">
    <div class="section-header">
      <h2>NRW pilot project</h2>
    </div>
    <p class="lead">
      In our statewide pilot project, we run education programmes shaped by practical questions and developed in close exchange with schools and partners.
    </p>
    <p class="pilot-cta-wrap">
      <a href={PILOT_LANDING_PATH} class="btn-outline">View NRW pilot project →</a>
    </p>
  </section>
</MainLayout>

<style>
  .section-header h2 { font-size: 2rem; margin-bottom: 1rem; color: #111827; }
  .lead { max-width: 720px; color: #475569; line-height: 1.85; margin-top: 0.5rem; }
  .section-cta-wrap,
  .pilot-cta-wrap { margin: 1.25rem 0 0; }
</style>
