---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustSection from '../../components/TrustSection.astro';
---

<MainLayout lang="en" title="Home" description="BiFoDe e.V. develops educational and prevention formats for schools and partners in NRW.">
  <Hero
    lang="en"
    centered={true}
    title="Strengthen education. Counter antisemitism. Live democracy."
    subtitle="BiFoDe e.V. implements educational and prevention formats across North Rhine-Westphalia."
    tertiary={{ href: '/en/events', label: 'Upcoming events →' }}
  />

  <TrustSection
    partnerTitle="Our partners"
    label="Collaboration and exchange with partners from education and civil society"
    cooperationHref="/en/cooperation"
    cooperationLabel="About cooperation →"
  />

  <section class="container">
    <div class="section-header">
      <h2>Who We Are</h2>
    </div>
    <p class="lead">We strengthen education and social cohesion in NRW. We provide practical formats for schools, municipalities, and civil society partners with a clear stance against antisemitism.</p>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Our Work</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M4 6.5A2.5 2.5 0 0 1 6.5 4H20v15.5A2.5 2.5 0 0 0 17.5 17H4z" /><path d="M4 6.5V20h13.5A2.5 2.5 0 0 0 20 17" /><path d="M8 8h8M8 11h8" /></svg>
        </div>
        <h3>Education & Prevention</h3>
        <p>Programs that support respectful coexistence and early prevention work.</p>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><circle cx="9" cy="8" r="3" /><circle cx="16" cy="10" r="2.5" /><path d="M3.5 18a5.5 5.5 0 0 1 11 0" /><path d="M13.5 18a4 4 0 0 1 7 0" /></svg>
        </div>
        <h3>Support & Orientation</h3>
        <p>Practical guidance for teachers, schools, and partner organizations.</p>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="6" /><path d="m20 20-4.2-4.2" /><path d="M11 8v6M8 11h6" /></svg>
        </div>
        <h3>Analysis & Context</h3>
        <p>Reliable background analysis that informs our educational work.</p>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Who we work with</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M3 10.5 12 5l9 5.5-9 5.5z" /><path d="M7 12.5V16a5 3 0 0 0 10 0v-3.5" /></svg>
        </div>
        <h3>Schools</h3>
        <p>Programmes for teachers and schools that promote democratic learning and respect.</p>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M8 14a3 3 0 1 1 0-6c1.2 0 2.2.7 2.7 1.7A3 3 0 1 1 13 14c-.9 0-1.6-.3-2.2-.8A3 3 0 0 1 8 14Z" /><path d="M4.5 19a3.5 3.5 0 0 1 6.5-1.8A3.5 3.5 0 0 1 17.5 19" /></svg>
        </div>
        <h3>Partners & NGOs</h3>
        <p>Reliable cooperation with civil society organisations and education partners.</p>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M4 20h16" /><path d="M5 20V9h14v11" /><path d="M3 9h18L12 4z" /><path d="M9 13h6v7H9z" /></svg>
        </div>
        <h3>Public bodies</h3>
        <p>Consulting and formats for municipal actors and institutional partners.</p>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>NRW pilot project</h2>
    </div>
    <p class="lead">
      In our statewide pilot project we run educational formats that take up practical questions and are developed in close exchange with schools and partners.
    </p>
    <p class="pilot-link-wrap">
      <a href="/en/projects" class="pilot-link">Browse our projects →</a>
    </p>
  </section>
</MainLayout>

<style>
  .section-header h2 { font-size: 2rem; margin-bottom: 1rem; color: #111827; }
  .lead { max-width: 720px; color: #475569; line-height: 1.85; margin-top: 0.5rem; }
  .pilot-link-wrap { margin: 1rem 0 0; }
  .pilot-link { font-weight: 600; color: #163b63; text-decoration: none; border-bottom: 1px solid rgba(22, 59, 99, 0.35); }
  .pilot-link:hover { color: #0f2e50; border-bottom-color: #0f2e50; }
</style>
