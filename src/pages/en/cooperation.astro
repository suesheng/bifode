---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';
---

<MainLayout lang="en" title="Cooperation" description="We work with schools, education providers, municipalities, and civil society partners.">
  <Hero lang="en" centered={false} title="Cooperation" subtitle="We work with schools, education providers, municipalities, and civil society partners." />

  <section class="container">
    <div class="section-header">
      <h2>Why cooperation matters</h2>
    </div>
    <p class="lead">Prevention works best where education, experience, and local networks come together. BiFoDe combines practical education work with partnership-based collaboration in North Rhine-Westphalia to strengthen democratic resilience and prevent antisemitism.</p>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Who we work with</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M3 10.5 12 5l9 5.5-9 5.5z" /><path d="M7 12.5V16a5 3 0 0 0 10 0v-3.5" /></svg>
        </div>
        <h3>Schools and educational institutions</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M4 20h16" /><path d="M5 20V9h14v11" /><path d="M3 9h18L12 4z" /><path d="M9 13h6v7H9z" /></svg>
        </div>
        <h3>Municipalities and public bodies</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M8 14a3 3 0 1 1 0-6c1.2 0 2.2.7 2.7 1.7A3 3 0 1 1 13 14c-.9 0-1.6-.3-2.2-.8A3 3 0 0 1 8 14Z" /><path d="M4.5 19a3.5 3.5 0 0 1 6.5-1.8A3.5 3.5 0 0 1 17.5 19" /></svg>
        </div>
        <h3>Civil society organisations</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M12 4v16" /><path d="M8.5 7.5H15.5" /><path d="M9 16h6" /><path d="M10 20h4" /></svg>
        </div>
        <h3>Faith communities</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3" /><path d="M6 19a6 6 0 0 1 12 0" /><path d="M19 6v4M17 8h4" /></svg>
        </div>
        <h3>Specialist services and experts</h3>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Forms of collaboration</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M7 5h10v4H7z" /><path d="M7 14h10v5H7z" /><path d="M12 9v5" /></svg>
        </div>
        <h3>Workshops and project days</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M7 4h10v16H7z" /><path d="M10 8h4M10 12h4M10 16h4" /></svg>
        </div>
        <h3>Joint education projects</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M4 7h16v9H8l-4 4z" /><path d="M9 11h6" /></svg>
        </div>
        <h3>Professional exchange</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M12 4v16" /><path d="M8 8h8" /><path d="M8 16h8" /><path d="M7 20h10" /></svg>
        </div>
        <h3>Pilot formats in schools</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M5 6h8a3 3 0 0 1 3 3v9H8a3 3 0 0 0-3 3z" /><path d="M19 6h-6a3 3 0 0 0-3 3v12a3 3 0 0 1 3-3h6z" /></svg>
        </div>
        <h3>Materials and digital modules</h3>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Our approach to cooperation</h2>
    </div>
    <p class="lead">BiFoDe understands cooperation as practical collaboration on equal terms. We complement existing structures, pool knowledge, and develop formats that are genuinely useful on the ground and promote a clear stance against antisemitic narratives.</p>
  </section>

  <section class="container cta-section">
    <p class="lead">Would you like to partner with BiFoDe or host an education programme at your institution? Please get in touch.</p>
    <a class="button" href="/en/contact">Contact us</a>
  </section>
</MainLayout>

<style>
  .lead {
    color: #4b5563;
    line-height: 1.8;
    max-width: 720px;
  }

  .section-header h2 {
    font-size: clamp(1.8rem, 3vw, 2.2rem);
    margin-bottom: 1rem;
    color: #0f172a;
    letter-spacing: -0.01em;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.35rem;
    margin-top: 1.5rem;
  }

  .cta-section {
    padding: 2.5rem 0;
    text-align: center;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.6rem;
    border-radius: 0.9rem;
    background: #163b63;
    color: white;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .button:hover {
    background: #0f2e50;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .card-grid {
      grid-template-columns: 1fr;
    }

    .button {
      width: 100%;
    }
  }
</style>
