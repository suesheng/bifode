---
import MainLayout from '../../../layouts/MainLayout.astro';
import Hero from '../../../components/Hero.astro';
---

<MainLayout lang="en" title="Projects" description="Our projects combine educational work, prevention, and practical guidance for schools and partners in NRW.">
  <Hero lang="en" title="Projects" subtitle="Our projects combine educational work, prevention, and practical guidance for schools and partners in NRW." />

  <section class="container">
    <div class="card-grid">
      <div class="card project-card">
        <h3>School Program NRW</h3>
        <p class="card-text">Workshops and project days on antisemitism prevention, prejudice, media literacy, and democratic cohesion.</p>
        <a href="/en/schools" class="card-link">Learn more →</a>
      </div>
      <div class="card project-card">
        <h3>Digital Education Modules</h3>
        <p class="card-text">Interactive learning content for schools and educational institutions.</p>
        <a href="/en/schools" class="card-link">Learn more →</a>
      </div>
      <div class="card project-card">
        <h3>Interactive Displays / Kiosk</h3>
        <p class="card-text">Digital information and learning stations for schools and public spaces.</p>
        <a href="/en/schools" class="card-link">Learn more →</a>
      </div>
    </div>
  </section>
</MainLayout>
