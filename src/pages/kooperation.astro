---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
---

<MainLayout title="Kooperation" description="Wir arbeiten mit Schulen, Bildungsträgern, Kommunen und zivilgesellschaftlichen Partnern zusammen.">
  <Hero centered={false} title="Kooperation" subtitle="Wir arbeiten mit Schulen, Bildungsträgern, Kommunen und zivilgesellschaftlichen Partnern zusammen." />

  <section class="container">
    <div class="section-header">
      <h2>Warum Kooperation wichtig ist</h2>
    </div>
    <p class="lead">Prävention gelingt dort am besten, wo Bildung, Erfahrung und lokale Netzwerke zusammenkommen. BiFoDe verbindet praxisnahe Bildungsarbeit mit partnerschaftlicher Zusammenarbeit in Nordrhein-Westfalen, um demokratische Resilienz zu stärken und Antisemitismus vorzubeugen.</p>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Mit wem wir arbeiten</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M3 10.5 12 5l9 5.5-9 5.5z" />
            <path d="M7 12.5V16a5 3 0 0 0 10 0v-3.5" />
          </svg>
        </div>
        <h3>Schulen und Bildungseinrichtungen</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M4 20h16" />
            <path d="M5 20V9h14v11" />
            <path d="M3 9h18L12 4z" />
            <path d="M9 13h6v7H9z" />
          </svg>
        </div>
        <h3>Kommunen und öffentliche Stellen</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M8 14a3 3 0 1 1 0-6c1.2 0 2.2.7 2.7 1.7A3 3 0 1 1 13 14c-.9 0-1.6-.3-2.2-.8A3 3 0 0 1 8 14Z" />
            <path d="M4.5 19a3.5 3.5 0 0 1 6.5-1.8A3.5 3.5 0 0 1 17.5 19" />
          </svg>
        </div>
        <h3>Zivilgesellschaftliche Organisationen</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M12 4v16" />
            <path d="M8.5 7.5H15.5" />
            <path d="M9 16h6" />
            <path d="M10 20h4" />
          </svg>
        </div>
        <h3>Religiöse Gemeinden</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="3" />
            <path d="M6 19a6 6 0 0 1 12 0" />
            <path d="M19 6v4M17 8h4" />
          </svg>
        </div>
        <h3>Fachstellen und Expertinnen / Experten</h3>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Formen der Zusammenarbeit</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M7 5h10v4H7z" />
            <path d="M7 14h10v5H7z" />
            <path d="M12 9v5" />
          </svg>
        </div>
        <h3>Workshops und Projekttage</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M7 4h10v16H7z" />
            <path d="M10 8h4M10 12h4M10 16h4" />
          </svg>
        </div>
        <h3>Gemeinsame Bildungsprojekte</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M4 7h16v9H8l-4 4z" />
            <path d="M9 11h6" />
          </svg>
        </div>
        <h3>Fachlicher Austausch</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M12 4v16" />
            <path d="M8 8h8" />
            <path d="M8 16h8" />
            <path d="M7 20h10" />
          </svg>
        </div>
        <h3>Pilotformate an Schulen</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M5 6h8a3 3 0 0 1 3 3v9H8a3 3 0 0 0-3 3z" />
            <path d="M19 6h-6a3 3 0 0 0-3 3v12a3 3 0 0 1 3-3h6z" />
          </svg>
        </div>
        <h3>Materialien und digitale Module</h3>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Unser Kooperationsverständnis</h2>
    </div>
    <p class="lead">BiFoDe versteht Kooperation als praktische Zusammenarbeit auf Augenhöhe. Wir ergänzen bestehende Strukturen, bündeln Wissen und entwickeln Formate, die vor Ort konkret nutzbar sind und eine klare Haltung gegen antisemitische Narrative fördern.</p>
  </section>

  <section class="container cta-section">
    <p class="lead">Sie möchten mit BiFoDe zusammenarbeiten oder ein Bildungsformat an Ihrer Einrichtung umsetzen? Sprechen Sie uns an.</p>
    <a class="button" href="/kontakt">Kontakt aufnehmen</a>
  </section>
</MainLayout>

<style>
  .lead {
    color: #4b5563;
    line-height: 1.8;
    max-width: 720px;
  }

  .section-header h2 {
    font-size: clamp(1.8rem, 3vw, 2.2rem);
    margin-bottom: 1rem;
    color: #0f172a;
    letter-spacing: -0.01em;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.35rem;
    margin-top: 1.5rem;
  }

  .cta-section {
    padding: 2.5rem 0;
    text-align: center;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.6rem;
    border-radius: 0.9rem;
    background: #163b63;
    color: white;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .button:hover {
    background: #0f2e50;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .card-grid {
      grid-template-columns: 1fr;
    }

    .button {
      width: 100%;
    }
  }
</style>
