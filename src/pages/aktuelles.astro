---
export const prerender = true;

import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';

const posts = (await getCollection('aktuelles'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<MainLayout
  title="Aktuelles"
  description="Neuigkeiten, Berichte und Ankündigungen von BiFoDe e.V. zu Bildungsprojekten und Präventionsarbeit in NRW."
>
  <Hero
    centered={false}
    title="Aktuelles"
    subtitle="Neuigkeiten aus unserer Bildungs- und Präventionsarbeit in Nordrhein-Westfalen."
  />

  <section class="container">
    {posts.length === 0 ? (
      <p class="lead">Derzeit sind keine Beiträge veröffentlicht.</p>
    ) : (
      <ul class="news-list">
        {posts.map((post) => (
          <li>
            <article class="card news-card">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              <h2>
                <a href={`/aktuelles/${post.id}`}>{post.data.title}</a>
              </h2>
              <p>{post.data.description}</p>
              <a class="btn-outline" href={`/aktuelles/${post.id}`}>Weiterlesen →</a>
            </article>
          </li>
        ))}
      </ul>
    )}
  </section>
</MainLayout>

<style>
  .lead {
    color: #475569;
    line-height: 1.8;
  }

  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }

  .news-card time {
    display: block;
    font-size: 0.875rem;
    color: #64748b;
    margin-bottom: 0.5rem;
  }

  .news-card h2 {
    margin: 0 0 0.75rem;
    font-size: 1.35rem;
  }

  .news-card h2 a {
    color: #111827;
    text-decoration: none;
  }

  .news-card h2 a:hover {
    color: #163b63;
  }

  .news-card p {
    margin: 0 0 0.5rem;
    color: #475569;
    line-height: 1.7;
  }
</style>
