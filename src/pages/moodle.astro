---
import MainLayout from '../layouts/MainLayout.astro';
import MoodleLanding from '../components/MoodleLanding.astro';
import { MOODLE_ULPAN_URL } from '../lib/communityLinks';

const pageDescription =
  'Moodle-Lernplattform für Ulpan.Next — Kursmaterialien und Übungen für Mitglieder von BiFoDe e.V. Zugang nach Aufnahme in den Verein.';
---

<MainLayout
  title="Moodle — Ulpan.Next Lernplattform"
  description={pageDescription}
  titleSuffix={false}
  mainClass="md-main"
>
  <MoodleLanding lang="de" />
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'Moodle — Ulpan.Next Lernplattform',
      url: 'https://www.bifode.org/moodle',
      description: pageDescription,
      inLanguage: 'de-DE',
      isPartOf: { '@type': 'WebSite', name: 'BiFoDe e.V.', url: 'https://www.bifode.org/' },
      mainEntity: {
        '@type': 'WebApplication',
        name: 'Moodle Ulpan.Next',
        url: MOODLE_ULPAN_URL,
        applicationCategory: 'EducationalApplication',
      },
    })}
  />
</MainLayout>
