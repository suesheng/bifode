---
/**
 * Mitgliedschaft — landing for new Verein members (no tracking yet).
 */
import MainLayout from '../layouts/MainLayout.astro';
import {
  MONTHLY_EUR,
  formatEur,
  getMembershipFeeAmounts,
} from '../lib/membershipFees';
import { ULPAN_LANDING_PATH } from '../lib/communityLinks';

const pageTitle = 'Mitglied werden | BiFoDe e.V.';
const pageDescription =
  'Mitgliedschaft bei BiFoDe e.V. ab 15 €/Monat (Studierende 10,50 €, Jahresbeitrag ab 162 €) — Ulpan, Lernmaterialien, Community-Treffen, Merch und weitere Vereinsangebote.';

const eur = formatEur;
const { monthlyStudent, annualStandard, annualStudent, annualStandardFull, annualStudentFull } =
  getMembershipFeeAmounts();

const vereinServices = [
  {
    title: 'Ulpan vor Ort & online',
    text: 'Hebräisch lernen in Präsenz- und Online-Formaten — für Mitglieder des Vereins.'
  },
  {
    title: 'Lernmaterialien',
    text: 'Zugang zu Übungen, Links, Empfehlungen und ausgewählten Materialien rund um Ivrit und Bildung.'
  },
  {
    title: 'Gemeinsame Treffen',
    text: 'Community-Runden und Begegnungen — inklusive Bewirtung bei ausgewählten Formaten.'
  },
  {
    title: 'Merch & Vereinsmaterialien',
    text: 'Community-Merch und Vereinsmaterialien, sofern verfügbar und passend zum jeweiligen Angebot.'
  },
  {
    title: 'Weitere Vereinsangebote',
    text: 'Workshops, Webinare, Israel-Community-Formate und weitere Projekte von BiFoDe e.V.'
  },
  {
    title: 'Netzwerk & Mitgestaltung',
    text: 'Austausch, frühe Informationen zu neuen Kursen und die Möglichkeit, Projekte mitzuprägen.'
  }
];

const pricingRows = [
  {
    label: 'Standard',
    monthly: eur(MONTHLY_EUR),
    monthlyNote: 'Regelbeitrag',
    annual: eur(annualStandard),
    annualRef: eur(annualStandardFull),
    annualNote: 'mit Rabatt bei Jahreszahlung',
    highlight: false
  },
  {
    label: 'Studierende',
    monthly: eur(monthlyStudent),
    monthlyRef: eur(MONTHLY_EUR),
    monthlyNote: 'mit Ermäßigung',
    annual: eur(annualStudent),
    annualRef: eur(annualStudentFull),
    annualNote: 'mit Ermäßigung und Rabatt bei Jahreszahlung',
    highlight: true,
    badge: 'Ermäßigung'
  }
];

const steps = [
  {
    title: 'Mitgliedschaft abschließen',
    text: 'Online-Formular oder Beitrittserklärung ausfüllen — monatlich oder jährlich.'
  },
  {
    title: 'Aufnahme & Zugang',
    text: 'Nach Vereinsbeschluss und Beitrittserklärung erhältst du Zugang zu allen Vereinsangeboten.'
  },
  {
    title: 'Angebote nutzen',
    text: 'Ulpan, Materialien, Treffen, Merch und weitere Formate — gemäß Programm und Verfügbarkeit.'
  }
];

const membershipTypes = [
  `Standard — ${eur(MONTHLY_EUR)} € / Monat`,
  `Studierende — ${eur(monthlyStudent)} € / Monat (mit Ermäßigung)`,
  `Jahresbeitrag Standard — ${eur(annualStandard)} € / Jahr (mit Rabatt)`
];

const billingOptions = [
  `Monatlich (Standard) — ${eur(MONTHLY_EUR)} €`,
  `Monatlich (Studierende) — ${eur(monthlyStudent)} € (mit Ermäßigung)`,
  `Jährlich (Standard) — ${eur(annualStandard)} € (mit Rabatt)`,
  `Jährlich (Studierende) — ${eur(annualStudent)} € (mit Ermäßigung und Rabatt)`
];

const interestOptions = [
  'Demokratische Bildung & Schulen',
  'Israel Community / Hebräisch',
  'Veranstaltungen & Workshops',
  'Kooperation & Netzwerk',
  'Ehrenamt / Mitgestaltung',
  'Sonstiges'
];

const webPageJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  url: 'https://www.bifode.org/mitglied-werden',
  description: pageDescription,
  inLanguage: 'de-DE',
  isPartOf: { '@type': 'WebSite', name: 'BiFoDe e.V.', url: 'https://www.bifode.org/' }
});
---

<MainLayout title={pageTitle} description={pageDescription} titleSuffix={false} mainClass="mw-main">
  <script type="application/ld+json" set:html={webPageJsonLd} />

  <div class="mw-page" data-landing="mitglied-werden">
    <section class="mw-hero" aria-labelledby="mw-hero-title">
      <div class="mw-hero-visual" aria-hidden="true"></div>
      <div class="container mw-hero-inner">
        <p class="mw-eyebrow">BiFoDe e.V. · Bildungsforum für Demokratie und Vielfalt NRW</p>
        <h1 id="mw-hero-title">Mitglied werden</h1>
        <p class="mw-hero-sub">Gemeinsam Bildung stärken — demokratisch, vielfältig und mit klarem gesellschaftlichem Auftrag.</p>
        <p class="mw-lead">
          <strong>Alle Vereinsangebote</strong> — Ulpan vor Ort und online, Lernmaterialien, gemeinsame Treffen mit Bewirtung, Merch und weitere Formate — sind <strong>nach abgeschlossener Mitgliedschaft</strong> und laufendem Mitgliedsbeitrag verfügbar.
        </p>
        <p class="mw-price-hero">
          <span class="mw-price-big">15 €</span>
          <span class="mw-price-unit">pro Monat</span>
          <span class="mw-price-meta">
            Studierende {eur(monthlyStudent)} € / Monat (mit Ermäßigung) · Jahresbeitrag ab {eur(annualStandard)} € (mit Rabatt)
          </span>
        </p>
        <div class="mw-actions">
          <a href="#anmeldung" class="mw-btn mw-btn-primary">Mitgliedschaft abschließen</a>
          <a href="#preise" class="mw-btn mw-btn-secondary">Preistabelle</a>
        </div>
      </div>
    </section>

    <section class="mw-section" id="leistungen" aria-labelledby="mw-services-title">
      <div class="container">
        <h2 id="mw-services-title">Das ist mit der Mitgliedschaft drin</h2>
        <p class="mw-lead">
          Nach Aufnahme als Mitglied und mit laufendem Mitgliedsbeitrag nutzt du die Angebote von BiFoDe e.V. — ein Zugang für alle genannten Vereinsleistungen, nicht pro Einzelleistung.
        </p>
        <div class="card-grid">
          {vereinServices.map((item) => (
            <article class="card feature-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
        <p class="mw-note">
          Die Teilnahme an konkreten Terminen erfolgt je nach Verfügbarkeit, Projektphase und Kapazität. Die Mitgliedschaft ist ein Vereinsbeitrag, kein Fernabsatzvertrag mit pauschaler Erfolgsgarantie.
        </p>
      </div>
    </section>

    <section class="mw-section mw-section-alt" id="beitrag" aria-labelledby="mw-fee-title">
      <span id="preise" class="mw-anchor" aria-hidden="true"></span>
      <div class="container">
        <h2 id="mw-fee-title">Mitgliedsbeitrag</h2>
        <p class="mw-lead">Alle Beträge in Euro. Ermäßigungen und Rabatte sind als Hinweis genannt — die Spalten zeigen die Beiträge, die du zahlst.</p>

        <div class="mw-table-wrap">
          <table class="mw-price-table" aria-describedby="mw-fee-caption">
            <caption id="mw-fee-caption" class="mw-table-caption">
              Mitgliedsbeiträge BiFoDe e.V. — monatliche und jährliche Zahlung
            </caption>
            <thead>
              <tr>
                <th scope="col">Mitgliedschaft</th>
                <th scope="col">Monatlich</th>
                <th scope="col">Jährlich</th>
              </tr>
            </thead>
            <tbody>
              {pricingRows.map((row) => (
                <tr class:list={[row.highlight && 'mw-table-row--highlight']}>
                  <th scope="row">
                    <span class="mw-table-label">{row.label}</span>
                    {row.badge && <span class="mw-table-badge">{row.badge}</span>}
                  </th>
                  <td data-label="Monatlich">
                    <span class="mw-table-amount">{row.monthly} €</span>
                    {row.monthlyRef ? (
                      <span class="mw-table-ref">
                        statt <s>{row.monthlyRef} €</s> · {row.monthlyNote}
                      </span>
                    ) : (
                      <span class="mw-table-ref">{row.monthlyNote}</span>
                    )}
                  </td>
                  <td data-label="Jährlich">
                    <span class="mw-table-amount">{row.annual} €</span>
                    <span class="mw-table-ref">
                      statt <s>{row.annualRef} €</s> · {row.annualNote}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p class="mw-table-foot">
          Studierenden-Ermäßigung nach Vorlage eines Nachweises. Bei Jahreszahlung gilt der ausgewiesene Jahresbeitrag mit Vereins-Rabatt.
        </p>

        <p class="mw-cta-row">
          <a href="#anmeldung" class="mw-btn mw-btn-primary">Mitgliedschaft abschließen</a>
        </p>
      </div>
    </section>

    <section class="mw-section mw-section-alt" id="ablauf" aria-labelledby="mw-steps-title">
      <div class="container">
        <div class="mw-split">
          <div class="mw-split-col">
            <h2 id="mw-steps-title">So funktioniert die Aufnahme</h2>
            <ol class="mw-steps">
              {steps.map((step, i) => (
                <li>
                  <span class="mw-step-num" aria-hidden="true">{i + 1}</span>
                  <div>
                    <h3>{step.title}</h3>
                    <p>{step.text}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
          <div class="mw-split-col" id="zielgruppe" aria-labelledby="mw-who-title">
            <h2 id="mw-who-title">Wer kann Mitglied werden?</h2>
            <p class="mw-lead mw-lead-tight">
              Natürliche Personen, die unsere Bildungs- und Präventionsarbeit unterstützen möchten — in NRW, deutschlandweit oder im DACH-Raum, sofern eine Mitgliedschaft nach Satzung möglich ist.
            </p>
            <ul class="mw-list">
              <li>Engagierte für demokratische Bildung und gesellschaftlichen Zusammenhalt</li>
              <li>Interessierte an Israel Community, Hebräisch und verknüpften Bildungsformaten</li>
              <li>Partner, Fachkräfte und Ehrenamtliche, die den Verein langfristig stärken möchten</li>
              <li>Fördernde, die BiFoDe e.V. finanziell und ideell unterstützen wollen</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="mw-section" id="anmeldung" aria-labelledby="mw-form-title">
      <div class="container">
        <div class="mw-form-stack">
        <h2 id="mw-form-title">Mitgliedschaft abschließen</h2>
        <p class="mw-lead">
          Starte deine Aufnahme als Mitglied bei BiFoDe e.V. Wir melden uns mit Zahlungsinformationen. Pflichtfelder sind mit * markiert.
        </p>
        <p class="mw-doc-link no-print">
          <a href="/beitrittserklaerung" class="mw-doc-btn">Beitrittserklärung öffnen (HTML, als PDF speichern)</a>
        </p>
        <div class="mw-form-card">
          <form class="contact-form" id="mw-membership-form" novalidate>
            <input type="hidden" name="page_source" value="mitglied_werden_landing" />

            <div class="mw-form-row">
              <div class="form-group">
                <label for="mw-firstName">Vorname *</label>
                <input type="text" id="mw-firstName" name="firstName" required autocomplete="given-name" />
              </div>
              <div class="form-group">
                <label for="mw-lastName">Nachname *</label>
                <input type="text" id="mw-lastName" name="lastName" required autocomplete="family-name" />
              </div>
            </div>

            <div class="form-group">
              <label for="mw-email">E-Mail *</label>
              <input type="email" id="mw-email" name="email" required autocomplete="email" />
            </div>

            <div class="form-group">
              <label for="mw-phone">Telefon</label>
              <input type="tel" id="mw-phone" name="phone" autocomplete="tel" />
            </div>

            <div class="form-group">
              <label for="mw-street">Straße und Hausnummer</label>
              <input type="text" id="mw-street" name="street" autocomplete="street-address" />
            </div>

            <div class="mw-form-row">
              <div class="form-group">
                <label for="mw-postalCode">PLZ *</label>
                <input type="text" id="mw-postalCode" name="postalCode" required autocomplete="postal-code" inputmode="numeric" />
              </div>
              <div class="form-group">
                <label for="mw-city">Ort *</label>
                <input type="text" id="mw-city" name="city" required autocomplete="address-level2" />
              </div>
            </div>

            <div class="mw-form-row">
              <div class="form-group">
                <label for="mw-membershipType">Mitgliedschaftsart *</label>
                <select id="mw-membershipType" name="membershipType" required>
                  <option value="">Bitte wählen</option>
                  {membershipTypes.map((type) => (
                    <option value={type}>{type}</option>
                  ))}
                </select>
              </div>
              <div class="form-group">
                <label for="mw-billing">Zahlungsweise *</label>
                <select id="mw-billing" name="billing" required>
                  <option value="">Bitte wählen</option>
                  {billingOptions.map((opt) => (
                    <option value={opt}>{opt}</option>
                  ))}
                </select>
              </div>
            </div>

            <div class="form-group checkbox-group">
              <input type="checkbox" id="mw-student" name="isStudent" />
              <label for="mw-student">
                Ich bin studierend und möchte die Ermäßigung beantragen ({eur(monthlyStudent)} € / Monat statt {eur(MONTHLY_EUR)} € — Nachweis wird angefordert).
              </label>
            </div>

            <fieldset class="mw-fieldset">
              <legend>Interessenschwerpunkte (optional)</legend>
              <div class="mw-checkbox-grid">
                {interestOptions.map((opt) => (
                  <label class="mw-checkbox-label">
                    <input type="checkbox" name="interests" value={opt} />
                    <span>{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <div class="form-group">
              <label for="mw-message">Nachricht / Fragen</label>
              <textarea id="mw-message" name="message" rows="4" placeholder="Optional: Motivation, Fragen zur Aufnahme …"></textarea>
            </div>

            <div class="form-group checkbox-group">
              <input type="checkbox" id="mw-privacy" name="privacy" required />
              <label for="mw-privacy">
                Ich stimme zu, dass meine Angaben zur Bearbeitung meiner Mitgliedschaftsanfrage gespeichert und verarbeitet werden. Weitere Informationen in der <a href="/datenschutz">Datenschutzerklärung</a>.
              </label>
            </div>

            <div class="form-group checkbox-group">
              <input type="checkbox" id="mw-newsletter" name="newsletter" />
              <label for="mw-newsletter">Ich möchte Informationen zu Vereinsangeboten und Veranstaltungen per E-Mail erhalten.</label>
            </div>

            <div class="hp-field" aria-hidden="true">
              <label for="mw-website">Website</label>
              <input type="text" id="mw-website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <button type="submit" class="mw-btn mw-btn-primary">Mitgliedschaft abschließen</button>
          </form>
          <p class="form-note" id="mw-form-note">
            Alternativ: <a href="mailto:info@bifode.org?subject=Mitgliedschaft%20BiFoDe%20e.V.">info@bifode.org</a>
          </p>
        </div>

        <div class="mw-tax-box">
          <h3>Steuerlicher Hinweis</h3>
          <p>
            Mitgliedsbeiträge an gemeinnützige Organisationen können in Deutschland grundsätzlich steuerlich berücksichtigt werden, sofern die gesetzlichen Voraussetzungen erfüllt sind. Nach entsprechender Anerkennung kann BiFoDe e.V. Zuwendungsbestätigungen ausstellen, soweit rechtlich zulässig.
          </p>
          <p class="mw-small">Diese Angabe ersetzt keine steuerliche Beratung. Der gemeinnützige Status und die formalen Voraussetzungen müssen jeweils erfüllt sein.</p>
        </div>
        </div>
      </div>
    </section>

    <section class="mw-section mw-final" aria-labelledby="mw-final-title">
      <div class="container mw-narrow mw-final-inner">
        <h2 id="mw-final-title">Fragen vor der Anmeldung?</h2>
        <p class="mw-lead">Noch unsicher? Schreib uns — oder starte direkt die Aufnahme.</p>
        <div class="mw-actions">
          <a href="#anmeldung" class="mw-btn mw-btn-primary">Mitgliedschaft abschließen</a>
          <a href="/kontakt" class="mw-btn mw-btn-secondary">Kontakt</a>
          <a href={ULPAN_LANDING_PATH} class="mw-btn mw-btn-outline">Ulpan Next</a>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  :global(.mw-main) {
    padding: 0 !important;
  }

  .mw-page {
    --mw-navy: #0c1e34;
    --mw-blue: #163b63;
    --mw-sky: #d6e1fc;
    --mw-bg: #f4f7fb;
    background: var(--mw-bg);
  }

  .mw-hero {
    position: relative;
    overflow: hidden;
    padding: 3rem 0 2.75rem;
    background: linear-gradient(160deg, #e8f2ff 0%, #f5f9ff 50%, #fff 100%);
  }

  .mw-hero-visual {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 50% at 20% 30%, rgba(22, 59, 99, 0.1), transparent),
      radial-gradient(ellipse 50% 40% at 90% 20%, rgba(214, 225, 252, 0.9), transparent);
  }

  .mw-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .mw-eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: #475569;
  }

  .mw-hero h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(2rem, 5vw, 2.85rem);
    font-weight: 800;
    color: var(--mw-navy);
    line-height: 1.1;
  }

  .mw-hero-sub {
    margin: 0 0 1rem;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--mw-blue);
    line-height: 1.45;
  }

  .mw-price-hero {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.75rem;
    margin: 0 0 0.25rem;
  }

  .mw-price-big {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--mw-navy);
    line-height: 1;
  }

  .mw-price-unit {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--mw-blue);
  }

  .mw-price-meta {
    width: 100%;
    font-size: 0.95rem;
    color: #64748b;
  }

  .mw-page .container {
    min-width: 0;
    box-sizing: border-box;
  }

  .mw-table-wrap {
    margin: 1.5rem 0 1rem;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius, 18px);
    box-shadow: var(--shadow);
    border: 1px solid #c7d9f5;
    background: #fff;
    box-sizing: border-box;
  }

  .mw-price-table {
    width: 100%;
    min-width: min(520px, 100%);
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .mw-table-caption {
    caption-side: top;
    padding: 1rem 1.25rem 0.5rem;
    text-align: left;
    font-weight: 600;
    color: var(--mw-navy);
    font-size: 0.9rem;
  }

  .mw-price-table thead th {
    background: linear-gradient(180deg, var(--mw-navy) 0%, var(--mw-blue) 100%);
    color: #fff;
    font-weight: 600;
    text-align: left;
    padding: 0.85rem 1.25rem;
    font-size: 0.875rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .mw-price-table thead th:first-child {
    border-radius: 0;
  }

  .mw-price-table tbody th,
  .mw-price-table tbody td {
    padding: 1.15rem 1.25rem;
    vertical-align: top;
    border-bottom: 1px solid #e8eef7;
  }

  .mw-price-table tbody tr:last-child th,
  .mw-price-table tbody tr:last-child td {
    border-bottom: none;
  }

  .mw-table-row--highlight {
    background: linear-gradient(90deg, #f0f6ff 0%, #fafcff 100%);
  }

  .mw-price-table tbody th {
    font-weight: 600;
    color: var(--mw-navy);
    text-align: left;
    width: 28%;
    background: #f8fafc;
  }

  .mw-table-label {
    display: block;
    font-size: 1.05rem;
  }

  .mw-table-badge {
    display: inline-block;
    margin-top: 0.35rem;
    padding: 0.2rem 0.55rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--mw-blue);
    background: var(--mw-sky);
    border-radius: 999px;
  }

  .mw-table-amount {
    display: block;
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--mw-navy);
    line-height: 1.2;
    margin-bottom: 0.35rem;
  }

  .mw-table-ref {
    display: block;
    font-size: 0.82rem;
    color: #64748b;
    line-height: 1.45;
  }

  .mw-table-ref s {
    color: #94a3b8;
    text-decoration-thickness: 1px;
  }

  .mw-table-foot {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.55;
    max-width: 68ch;
  }

  .mw-cta-row {
    margin-top: 1.5rem;
  }

  @media (max-width: 640px) {
    .mw-table-wrap {
      border: none;
      box-shadow: none;
      background: transparent;
      overflow: visible;
    }

    .mw-price-table {
      min-width: 0;
      display: block;
    }

    .mw-price-table thead {
      display: none;
    }

    .mw-price-table tbody {
      display: grid;
      gap: 1rem;
    }

    .mw-price-table tbody tr {
      display: block;
      background: #fff;
      border: 1px solid #dbe5f1;
      border-radius: 14px;
      padding: 0.25rem 0;
      box-shadow: var(--shadow);
    }

    .mw-table-row--highlight {
      border-color: var(--mw-blue);
      background: linear-gradient(160deg, #eef4ff, #fff);
    }

    .mw-price-table tbody th,
    .mw-price-table tbody td {
      display: block;
      width: 100%;
      border: none;
      padding: 0.75rem 1rem;
    }

    .mw-price-table tbody th {
      background: transparent;
      padding-bottom: 0.25rem;
      border-bottom: 1px solid #eef3fa;
    }

    .mw-price-table tbody td::before {
      content: attr(data-label);
      display: block;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
