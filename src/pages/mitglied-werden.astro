---
/**
 * Mitgliedschaft — landing for new Verein members (no tracking yet).
 */
import MainLayout from '../layouts/MainLayout.astro';
import JotformEmbed from '../components/JotformEmbed.astro';
import {
  ANNUAL_STANDARD_EUR,
  ANNUAL_STUDENT_EUR,
  formatEur,
  MONTHLY_STANDARD_EUR,
  MONTHLY_STUDENT_EUR,
} from '../lib/membershipFees';
import { jotformMitgliedschaftUrl, MOODLE_INFO_PATH, ULPAN_LANDING_PATH } from '../lib/communityLinks';

const jotformUrl = jotformMitgliedschaftUrl();

const pageTitle = 'Mitglied werden | BiFoDe e.V.';
const pageDescription =
  `Mitgliedschaft bei BiFoDe e.V. — ${formatEur(ANNUAL_STANDARD_EUR)} € / Jahr (Standard, ${formatEur(MONTHLY_STANDARD_EUR)} € / Monat) · Studierende / ermäßigt ${formatEur(ANNUAL_STUDENT_EUR)} € / Jahr — Unterstützung der Vereinsarbeit mit Zugang zu Bildungsangeboten nach Aufnahme.`;

const ctaApply = 'Mitgliedschaft beantragen';

const formSectionTitle = 'Mitglied werden bei BiFoDe e.V.';
const formSectionIntro =
  'Mit Ihrer Mitgliedschaft unterstützen Sie die gemeinnützige Bildungs-, Kultur- und Community-Arbeit von BiFoDe e.V. Nach Prüfung und Aufnahme erhalten Sie Zugang zu Vereinsangeboten — etwa Ulpan.Next, Lernmaterialien und Community-Formate, je nach Verfügbarkeit. Pflichtfelder sind mit * markiert.';

const vereinServices = [
  {
    title: 'Ulpan vor Ort & online',
    text: 'Hebräisch lernen in Präsenz- und Online-Formaten — für Mitglieder des Vereins.'
  },
  {
    title: 'Lernmaterialien & Moodle',
    text: 'Zugang zu Übungen, Links, Empfehlungen und der Moodle-Lernplattform für Mitglieder — mit Kursmaterialien zu Ulpan Next.'
  },
  {
    title: 'Gemeinsame Treffen',
    text: 'Community-Runden und Begegnungen — inklusive Bewirtung bei ausgewählten Formaten.'
  },
  {
    title: 'Vereinsmaterialien',
    text: 'Ausgewählte Vereinsmaterialien, sofern verfügbar und passend zum jeweiligen Angebot.'
  },
  {
    title: 'Weitere Bildungsformate',
    text: 'Workshops, Webinare, Israel-Community-Formate und weitere Projekte von BiFoDe e.V.'
  },
  {
    title: 'Netzwerk & Mitgestaltung',
    text: 'Austausch, frühe Informationen zu neuen Kursen und die Möglichkeit, Projekte mitzuprägen.'
  }
];

const steps = [
  {
    title: 'Aufnahme beantragen',
    text: 'Online-Formular ausfüllen — jährlicher Mitgliedsbeitrag (180 € bzw. 144 €).'
  },
  {
    title: 'Aufnahme & Zugang',
    text: 'Nach Prüfung und Vereinsbeschluss erhalten Sie Zugang zu den Vereinsangeboten gemäß Satzung und Verfügbarkeit.'
  },
  {
    title: 'Angebote nutzen',
    text: 'Ulpan, Moodle, Materialien, Treffen und weitere Formate — je nach Programm und Kapazität.'
  }
];

const webPageJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  url: 'https://www.bifode.org/mitglied-werden',
  description: pageDescription,
  inLanguage: 'de-DE',
  isPartOf: { '@type': 'WebSite', name: 'BiFoDe e.V.', url: 'https://www.bifode.org/' }
});
---

<MainLayout title={pageTitle} description={pageDescription} titleSuffix={false} mainClass="mw-main">
  <script type="application/ld+json" set:html={webPageJsonLd} />

  <div class="mw-page" data-landing="mitglied-werden">
    <section class="mw-hero" aria-labelledby="mw-hero-title">
      <div class="mw-hero-visual" aria-hidden="true"></div>
      <div class="container mw-hero-inner">
        <p class="mw-eyebrow">BiFoDe e.V. · Bildungsforum für Demokratie und Vielfalt NRW</p>
        <h1 id="mw-hero-title">Mitglied werden</h1>
        <p class="mw-hero-sub">Gemeinsam Bildung stärken — demokratisch, vielfältig und mit klarem gesellschaftlichem Auftrag.</p>
        <p class="mw-lead">
          Mit Ihrer Mitgliedschaft unterstützen Sie die gemeinnützige Arbeit von BiFoDe e.V. Nach Aufnahme und laufendem Mitgliedsbeitrag erhalten Sie Zugang zu Vereinsangeboten — etwa Ulpan, Lernmaterialien und gemeinsame Treffen — <strong>je nach Verfügbarkeit und Programm</strong>.
        </p>
        <p class="mw-price-hero">
          <span class="mw-price-big">{formatEur(ANNUAL_STANDARD_EUR)} €</span>
          <span class="mw-price-unit">pro Jahr</span>
          <span class="mw-price-meta">
            Standard · entspricht {formatEur(MONTHLY_STANDARD_EUR)} € / Monat · Studierende / ermäßigt{' '}
            {formatEur(ANNUAL_STUDENT_EUR)} € / Jahr ({formatEur(MONTHLY_STUDENT_EUR)} € / Monat)
          </span>
        </p>
        <div class="mw-actions">
          <a href="#anmeldung" class="mw-btn mw-btn-primary">{ctaApply}</a>
        </div>
      </div>
    </section>

    <section class="mw-section" id="leistungen" aria-labelledby="mw-services-title">
      <div class="container">
        <h2 id="mw-services-title">Was die Mitgliedschaft ermöglicht</h2>
        <p class="mw-lead">
          Nach Aufnahme als Mitglied und mit laufendem Mitgliedsbeitrag können Sie die Angebote von BiFoDe e.V. nutzen — ein gemeinsamer Zugang zur Vereinsarbeit, nicht pro Einzelleistung.
        </p>
        <div class="card-grid">
          {vereinServices.map((item) => (
            <article class="card feature-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
        <p class="mw-note">
          Die Teilnahme an konkreten Terminen erfolgt je nach Verfügbarkeit, Projektphase und Kapazität. Die Mitgliedschaft ist ein Vereinsbeitrag, kein Fernabsatzvertrag mit pauschaler Erfolgsgarantie.
        </p>
      </div>
    </section>

    <section class="mw-section mw-section-alt" id="ablauf" aria-labelledby="mw-steps-title">
      <div class="container">
        <div class="mw-split">
          <div class="mw-split-col">
            <h2 id="mw-steps-title">So funktioniert die Aufnahme</h2>
            <ol class="mw-steps">
              {steps.map((step, i) => (
                <li>
                  <span class="mw-step-num" aria-hidden="true">{i + 1}</span>
                  <div>
                    <h3>{step.title}</h3>
                    <p>{step.text}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
          <div class="mw-split-col" id="zielgruppe" aria-labelledby="mw-who-title">
            <h2 id="mw-who-title">Wer kann Mitglied werden?</h2>
            <p class="mw-lead mw-lead-tight">
              Natürliche Personen, die unsere Bildungs- und Präventionsarbeit unterstützen möchten — in NRW, deutschlandweit oder im DACH-Raum, sofern eine Mitgliedschaft nach Satzung möglich ist.
            </p>
            <ul class="mw-list">
              <li>Engagierte für demokratische Bildung und gesellschaftlichen Zusammenhalt</li>
              <li>Interessierte an Israel Community, Hebräisch und verknüpften Bildungsformaten</li>
              <li>Partner, Fachkräfte und Ehrenamtliche, die den Verein langfristig stärken möchten</li>
              <li>Fördernde, die BiFoDe e.V. finanziell und ideell unterstützen wollen</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="mw-section mw-section-alt mw-form-section" id="anmeldung" aria-labelledby="mw-form-title">
      <div class="container mw-form-container">
        <div class="mw-form-stack">
        <h2 id="mw-form-title">{formSectionTitle}</h2>
        <p class="mw-lead mw-form-intro">{formSectionIntro}</p>
        <JotformEmbed
          formUrl={jotformUrl}
          title="Mitgliedschaft bei BiFoDe e.V. beantragen"
          iframeLang="de"
          flush
        />
        <p class="form-note">
          Fragen? Schreiben Sie an{' '}
          <a href="mailto:info@bifode.org?subject=Mitgliedschaft%20BiFoDe%20e.V.">info@bifode.org</a>.
        </p>

        <div class="mw-tax-note">
          <h3>Steuerlicher Hinweis</h3>
          <p>
            Mitgliedsbeiträge an gemeinnützige Organisationen können in Deutschland grundsätzlich steuerlich berücksichtigt werden, sofern die gesetzlichen Voraussetzungen erfüllt sind. Nach entsprechender Anerkennung kann BiFoDe e.V. Zuwendungsbestätigungen ausstellen, soweit rechtlich zulässig.
          </p>
          <p class="mw-small">Diese Angabe ersetzt keine steuerliche Beratung. Der gemeinnützige Status und die formalen Voraussetzungen müssen jeweils erfüllt sein.</p>
        </div>
        </div>
      </div>
    </section>

    <section class="mw-section mw-final" aria-labelledby="mw-final-title">
      <div class="container mw-narrow mw-final-inner">
        <h2 id="mw-final-title">Fragen vor der Aufnahme?</h2>
        <p class="mw-lead">Noch unsicher? Schreiben Sie uns — oder stellen Sie direkt Ihre Anfrage.</p>
        <div class="mw-actions">
          <a href="#anmeldung" class="mw-btn mw-btn-primary">{ctaApply}</a>
          <a href="/kontakt" class="mw-btn mw-btn-secondary">Kontakt</a>
          <a href={ULPAN_LANDING_PATH} class="mw-btn mw-btn-outline">Ulpan Next</a>
          <a href={MOODLE_INFO_PATH} class="mw-btn mw-btn-outline">Moodle</a>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  :global(.mw-main) {
    padding: 0 !important;
  }

  .mw-page {
    --mw-navy: #0c1e34;
    --mw-blue: #163b63;
    --mw-sky: #d6e1fc;
    --mw-bg: #ffffff;
    background: var(--mw-bg);
  }

  .mw-hero {
    position: relative;
    overflow: hidden;
    padding: 3rem 0 2.75rem;
    background: linear-gradient(160deg, #e8f2ff 0%, #f5f9ff 50%, #fff 100%);
  }

  .mw-hero-visual {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 50% at 20% 30%, rgba(22, 59, 99, 0.1), transparent),
      radial-gradient(ellipse 50% 40% at 90% 20%, rgba(214, 225, 252, 0.9), transparent);
  }

  .mw-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .mw-eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: #475569;
  }

  .mw-hero h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(2rem, 5vw, 2.85rem);
    font-weight: 800;
    color: var(--mw-navy);
    line-height: 1.1;
  }

  .mw-hero-sub {
    margin: 0 0 1rem;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--mw-blue);
    line-height: 1.45;
  }

  .mw-price-hero {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.75rem;
    margin: 0 0 0.25rem;
  }

  .mw-price-big {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--mw-navy);
    line-height: 1;
  }

  .mw-price-unit {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--mw-blue);
  }

  .mw-price-meta {
    width: 100%;
    font-size: 0.95rem;
    color: #64748b;
  }

  .mw-page .container {
    min-width: 0;
    box-sizing: border-box;
  }

  .mw-section {
    padding: 2.75rem 0;
  }

  .mw-section-alt {
    background: #fff;
  }

  .mw-section h2 {
    margin: 0 0 1rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--mw-navy);
  }

  .mw-lead {
    margin: 0 0 1rem;
    color: #334155;
    line-height: 1.7;
    max-width: 68ch;
  }

  .mw-narrow {
    max-width: 720px;
  }

  .mw-split {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2.5rem 3rem;
    align-items: start;
  }

  .mw-split-col h2 {
    margin-top: 0;
  }

  .mw-lead-tight {
    max-width: none;
  }

  @media (max-width: 768px) {
    .mw-split {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }
  }

  .mw-note {
    margin-top: 1.25rem;
    padding: 0.85rem 1rem;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-left: 4px solid var(--mw-blue);
    border-radius: 0 8px 8px 0;
    color: #1e293b;
    line-height: 1.55;
    font-size: 0.95rem;
  }

  .mw-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .mw-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.25rem;
    border-radius: 0.65rem;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border: 2px solid transparent;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.2s;
  }

  .mw-btn-primary {
    background: var(--mw-blue);
    color: #fff;
    border-color: var(--mw-blue);
  }

  .mw-btn-primary:hover {
    background: #0f2e50;
    transform: translateY(-1px);
  }

  .mw-btn-secondary {
    background: #fff;
    color: var(--mw-blue);
    border-color: #89a6cc;
  }

  .mw-btn-secondary:hover {
    background: var(--mw-sky);
  }

  .mw-btn-outline {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.45);
  }

  .mw-btn-outline:hover {
    background: #fff;
    color: var(--mw-navy);
  }

  .mw-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }

  .mw-steps li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .mw-step-num {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--mw-blue);
    color: #fff;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
  }

  .mw-steps h3 {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
    color: var(--mw-navy);
  }

  .mw-steps p {
    margin: 0;
    color: #475569;
    line-height: 1.6;
  }

  .mw-list {
    margin: 0;
    padding-left: 1.25rem;
    color: #334155;
    line-height: 1.75;
  }

  .mw-small {
    font-size: 0.875rem;
    color: #64748b;
  }

  .mw-form-container {
    max-width: 1280px;
  }

  .mw-form-stack {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  .mw-form-stack .mw-lead {
    max-width: none;
  }

  .mw-form-stack h2 {
    margin-top: 0;
  }

  .mw-form-intro {
    margin-bottom: 1.5rem;
  }

  .mw-form-section {
    background: #fff;
    padding-top: 2rem;
  }

  .mw-form-section :global(.jotform-embed-root) {
    margin: 0;
  }

  .form-note {
    margin-top: 1.25rem;
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.55;
  }

  .mw-tax-note {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e2e8f0;
  }

  .mw-tax-note h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    color: var(--mw-navy);
  }

  .mw-tax-note p {
    margin: 0 0 0.75rem;
    color: #475569;
    line-height: 1.65;
    font-size: 0.95rem;
  }

  .mw-tax-note p:last-child {
    margin-bottom: 0;
  }

  .mw-final {
    background: linear-gradient(180deg, var(--mw-navy), #0f2e50);
    color: #e2e8f0;
    padding: 3rem 0;
  }

  .mw-final h2 {
    color: #fff;
  }

  .mw-final .mw-lead {
    color: #cbd5e1;
  }

  .mw-final .mw-btn-secondary {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.35);
  }

  @media (max-width: 768px) {
    .mw-actions .mw-btn {
      width: 100%;
    }
  }
</style>
