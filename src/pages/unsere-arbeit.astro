---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
---

<MainLayout title="Unsere Arbeit" description="Bildung, Orientierung und Analyse – unsere Arbeit verbindet Prävention mit praktischer Unterstützung im Alltag.">
  <Hero centered={false} title="Unsere Arbeit" subtitle="Bildung, Orientierung und Analyse – unsere Arbeit verbindet Prävention mit praktischer Unterstützung im Alltag." />

  <section class="container">
    <div class="section-header">
      <h2>Bildung & Prävention</h2>
    </div>
    <p class="lead">Wir entwickeln und realisieren Bildungsformate für Schulen und Bildungseinrichtungen. Ziel ist es, Antisemitismus einzuordnen, Vorurteile sichtbar zu machen und Medienkompetenz zu stärken.</p>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M7 5h10v4H7z" />
            <path d="M7 14h10v5H7z" />
            <path d="M12 9v5" />
          </svg>
        </div>
        <h3>Workshops für Schulen</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="4" y="6" width="16" height="14" rx="2" />
            <path d="M8 4v4M16 4v4M4 10h16" />
          </svg>
        </div>
        <h3>Projekttage und Module</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="4" y="6" width="16" height="11" rx="2" />
            <path d="M10 20h4M9 17h6" />
            <path d="m10 10 2 1.4L14 10" />
          </svg>
        </div>
        <h3>Medienkompetenz</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <circle cx="8.5" cy="8" r="2.5" />
            <path d="M4.5 17a4 4 0 0 1 8 0" />
            <rect x="13" y="6" width="7" height="6" rx="1" />
            <path d="M14 16h6" />
          </svg>
        </div>
        <h3>Lehrerfortbildungen</h3>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Unterstützung & Orientierung</h2>
    </div>
    <p class="lead">Wir bieten eine niedrigschwellige Anlaufstelle für die Einordnung von Vorfällen und unterstützen bei ersten Schritten im Umgang mit Konflikten und Diskriminierung.</p>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="6" />
            <path d="m20 20-4.2-4.2" />
            <path d="M11 8v6M8 11h6" />
          </svg>
        </div>
        <h3>Erste Einordnung von Vorfällen</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M7 4h7l4 4v12H7z" />
            <path d="M14 4v4h4" />
            <path d="M9 13h6M9 16h6" />
          </svg>
        </div>
        <h3>Unterstützung bei Dokumentation</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M4 7h16v9H8l-4 4z" />
            <path d="M9 11h6" />
          </svg>
        </div>
        <h3>Orientierung im Umgang mit Konflikten</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M8 14a3 3 0 1 1 0-6c1.2 0 2.2.7 2.7 1.7A3 3 0 1 1 13 14c-.9 0-1.6-.3-2.2-.8A3 3 0 0 1 8 14Z" />
            <path d="M4.5 19a3.5 3.5 0 0 1 6.5-1.8A3.5 3.5 0 0 1 17.5 19" />
          </svg>
        </div>
        <h3>Weitervermittlung an Fachstellen</h3>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Analyse & Hintergrund</h2>
    </div>
    <p class="lead">Wir beobachten gesellschaftliche Entwicklungen und öffentliche Diskurse auf Basis offener Quellen. Die Ergebnisse fließen in unsere Bildungsarbeit ein.</p>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M5 19V9M12 19V5M19 19v-7" />
            <path d="M4 19h16" />
          </svg>
        </div>
        <h3>Analyse von gesellschaftlichen Trends</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M5 6h14v12H5z" />
            <path d="M8 10h3M8 13h8M8 16h8" />
            <rect x="12.5" y="9" width="5.5" height="2.5" />
          </svg>
        </div>
        <h3>Einordnung von Medieninhalten</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M5 6h8a3 3 0 0 1 3 3v9H8a3 3 0 0 0-3 3z" />
            <path d="M19 6h-6a3 3 0 0 0-3 3v12a3 3 0 0 1 3-3h6z" />
          </svg>
        </div>
        <h3>Hintergrundwissen für Bildungsarbeit</h3>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Zusammenarbeit</h2>
    </div>
    <p class="lead">Unsere Arbeit erfolgt in enger Kooperation mit Schulen, zivilgesellschaftlichen Organisationen und öffentlichen Institutionen.</p>
  </section>

  <section class="container cta-section">
    <a class="button" href="/kooperation">Mehr über Kooperation erfahren</a>
  </section>
</MainLayout>

<style>
  .hero {
    padding: 4rem 0 2.5rem;
    background: #f8fafc;
  }

  .hero-content {
    max-width: 760px;
    margin: 0 auto;
    display: grid;
    gap: 1rem;
  }

  .lead {
    color: #475569;
    line-height: 1.8;
    max-width: 720px;
  }

  .section-header h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #111827;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .cta-section {
    padding: 3rem 0;
    text-align: center;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.6rem;
    border-radius: 0.9rem;
    background: #1e3a8a;
    color: white;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .button:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 1.5rem;
    }

    .card-grid {
      grid-template-columns: 1fr;
    }

    .button {
      width: 100%;
    }
  }
</style>
