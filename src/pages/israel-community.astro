---
import MainLayout from '../layouts/MainLayout.astro';
import IsraelCommunityTracking from '../components/IsraelCommunityTracking.astro';
import { FB_GROUP_ISRAEL_HUB_DACH, FB_PAGE_BIFODE, MOODLE_INFO_PATH } from '../lib/communityLinks';

const pageTitle = 'Community-Projekt | Sprache, Orientierung & Austausch | BiFoDe e.V.';
const pageDescription =
  'Bildungs- und Community-Projekt von BiFoDe e.V.: Hebräisch und Ulpan, Orientierung zu Auslandsschritten, Beruf, Studium und Alltag — in Kooperation mit internationalen Partnern.';

const FB_PAGE = FB_PAGE_BIFODE;
const FB_GROUP = FB_GROUP_ISRAEL_HUB_DACH;

function envUrl(key: string): string | null {
  const raw = import.meta.env[key];
  if (!raw || typeof raw !== 'string') return null;
  const v = raw.trim();
  if (!v || v.startsWith('TODO')) return null;
  return v;
}

const telegramUrl = envUrl('PUBLIC_TELEGRAM_ISRAEL_HUB_URL');
const donationUrl = envUrl('PUBLIC_DONATION_URL');
const spendenHref = donationUrl || '/spenden';
const spendenIsDonationLink = Boolean(donationUrl);

const interestOptions = [
  'Hebräisch / Ulpan',
  'Umzug / Orientierung im Ausland',
  'Dokumente & Konsulat',
  'Berufsanerkennung',
  'Ärztinnen & Ärzte',
  'Studium / Ausbildung',
  'Immobilien / Wohnen',
  'Banken / Steuern',
  'Alltag & Leben im Ausland',
  'Veranstaltungen / Community',
  'Mitgliedschaft bei BiFoDe e.V.',
  'Spende / Unterstützung',
  'Sonstiges'
];

const offerOptions = [
  'Hebräisch- / Ulpan-Kurse',
  'Online-Kurse',
  'Präsenzkurse',
  'Lernmaterialien',
  'Gesprächsclub',
  'Webinare',
  'Community-Treffen',
  'Feiertage & Kultur',
  'Merch / Vereinsmaterialien',
  'Orientierung Umzug / Ausland',
  'Beruf & Anerkennung',
  'Spenden / Unterstützung'
];

const themeTags = [
  'Hebräisch & Sprachkurse',
  'Erste Schritte im Ausland',
  'Konsulate & Dokumente',
  'Beruf & Anerkennung',
  'Medizin & Gesundheitsberufe',
  'Studium & Ausbildung',
  'Schule & Familie',
  'Wohnen & Immobilien',
  'Finanzen & Steuern',
  'Gesundheitssystem',
  'Arbeit & Netzwerke',
  'Kultur & Community'
];

const webPageJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  url: 'https://www.bifode.org/israel-community',
  description: pageDescription,
  inLanguage: 'de-DE',
  isPartOf: { '@type': 'WebSite', name: 'BiFoDe e.V.', url: 'https://www.bifode.org/' },
  about: {
    '@type': 'EducationalOrganization',
    name: 'Community-Projekt BiFoDe e.V.',
    parentOrganization: { '@type': 'Organization', name: 'BiFoDe e.V.' }
  }
});
---

<MainLayout title={pageTitle} description={pageDescription} titleSuffix={false} mainClass="ic-main">
  <IsraelCommunityTracking />
  <script type="application/ld+json" set:html={webPageJsonLd} />

  <div class="ic-page">
    <!-- 1. Hero -->
    <section class="ic-hero" id="top" aria-labelledby="ic-hero-title">
      <div class="ic-hero-bg" aria-hidden="true"></div>
      <div class="container ic-hero-inner">
        <p class="ic-eyebrow">BiFoDe e.V. · Bildungs- und Community-Projekt in NRW</p>
        <h1 id="ic-hero-title">Sprache lernen. Orientierung finden. Gemeinschaft erleben.</h1>
        <p class="ic-hero-sub">Israel Community Deutschland — ein Angebot von BiFoDe e.V.</p>
        <p class="ic-lead">
          Wir verbinden Menschen in Deutschland mit Bildungsformaten, Sprachkursen, Gesprächsgruppen und verlässlicher Orientierung — von Hebräisch und Ulpan bis zu Fragen zu Beruf, Studium und Alltag im Ausland. Das Projekt wird von BiFoDe e.V. umgesetzt und mit internationalen Partnern, darunter der World Zionist Organization, weiterentwickelt.
        </p>
        <div class="ic-hero-actions">
          <a href="#kontakt" class="ic-btn ic-btn-primary" data-track="contact_cta">Interesse anmelden</a>
          <a href="#kontakt" class="ic-btn ic-btn-secondary" data-track="contact_cta">Direkt eine Frage stellen</a>
          <a href="/mitglied-werden" class="ic-btn ic-btn-outline" data-track="membership_intent">Mitglied werden</a>
          <a
            href="#spenden"
            class="ic-btn ic-btn-ghost"
            data-track={spendenIsDonationLink ? 'donation_intent' : 'contact_cta'}
          >
            Projekt unterstützen
          </a>
        </div>
      </div>
    </section>

    <!-- 2. Wer wir sind -->
    <section class="ic-section" id="ueber-uns" aria-labelledby="ic-ueber-title">
      <div class="container">
        <h2 id="ic-ueber-title">Wer wir sind</h2>
        <p class="ic-lead">
          BiFoDe e.V. – Bildungsforum für Demokratie und Vielfalt NRW – ist ein eingetragener gemeinnütziger Verein mit Sitz in Nordrhein-Westfalen. Wir stärken Menschen durch Bildung, Austausch und praktische Orientierung. Das Community-Projekt bündelt Sprachangebote, Informationsformate und Vernetzung — mit Schwerpunkt auf deutsch-israelischem Austausch, ohne politische Einordnung.
        </p>
        <div class="card-grid ic-trust-grid">
          <article class="card feature-card">
            <h3>BiFoDe e.V.</h3>
            <p>Bildung, Demokratie und Vielfalt in NRW — gemeinnütziger Verein mit klarem Bildungsauftrag.</p>
          </article>
          <article class="card feature-card">
            <h3>Internationale Partnerschaft</h3>
            <p>Entwicklung von Formaten mit erfahrenen Partnerorganisationen, u. a. der World Zionist Organization.</p>
          </article>
          <article class="card feature-card">
            <h3>Online & vor Ort</h3>
            <p>Webinare, Gesprächsgruppen und Veranstaltungen in Deutschland — niederschwellig und praxisnah.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- 3. Community-Kanäle -->
    <section class="ic-section ic-section-alt" id="community" aria-labelledby="ic-community-title">
      <div class="container">
        <h2 id="ic-community-title">Bleib mit uns verbunden</h2>
        <p class="ic-lead">
          Folge unseren Kanälen für Kursankündigungen, Veranstaltungen, Webinare und Austausch — in der Facebook-Gruppe Israel Hub DACH und auf den offiziellen BiFoDe-Kanälen.
        </p>
        <div class="card-grid ic-community-grid">
          <article class="card feature-card">
            <h3>Facebook-Seite BiFoDe</h3>
            <p>Offizielle Informationen, Projekte und Updates von BiFoDe e.V.</p>
            <a
              href={FB_PAGE}
              class="ic-btn ic-btn-primary ic-card-btn"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook-Seite BiFoDe öffnen"
              data-track="facebook_page_click"
            >
              Facebook-Seite besuchen
            </a>
          </article>
          <article class="card feature-card">
            <h3>Facebook-Gruppe Israel Hub DACH</h3>
            <p>
              Gruppe für Fragen zum Umzug nach Israel (Aliyah) — Sprache, Arbeit, Kinder, Medizin, Wohnen und mehr. Beiträge auf Deutsch; Antworten von erfahrenen Community-Mitgliedern.
            </p>
            <a
              href={FB_GROUP}
              class="ic-btn ic-btn-primary ic-card-btn"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook-Gruppe Israel Hub DACH öffnen"
              data-track="facebook_group_click"
            >
              Facebook-Gruppe öffnen
            </a>
          </article>
          <article class="card feature-card">
            <h3>Telegram-Kanal</h3>
            <p>Schnelle Updates, Kursankündigungen, Termine und Hinweise zu neuen Veranstaltungen.</p>
            {telegramUrl ? (
              <a
                href={telegramUrl}
                class="ic-btn ic-btn-primary ic-card-btn"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Telegram-Kanal Israel Hub Deutschland öffnen"
                data-track="telegram_click"
              >
                Telegram-Kanal abonnieren
              </a>
            ) : (
              <p class="ic-todo-note">Telegram-Link wird ergänzt. {/* TODO: add Telegram channel URL — PUBLIC_TELEGRAM_ISRAEL_HUB_URL */}</p>
            )}
          </article>
        </div>
      </div>
    </section>

    <!-- 4. Was wir anbieten -->
    <section class="ic-section" id="angebote" aria-labelledby="ic-angebote-title">
      <div class="container">
        <h2 id="ic-angebote-title">Was wir anbieten</h2>
        <div class="card-grid">
          <article class="card feature-card">
            <h3>Hebräisch & Ulpan</h3>
            <p>Online- und Präsenzformate zum Sprachenlernen — von den ersten Schritten bis zu fortgeschrittenen Gesprächsgruppen.</p>
          </article>
          <article class="card feature-card">
            <h3>Gesprächs- und Diskussionsclubs</h3>
            <p>Regelmäßige Treffen zu Sprache, Kultur, Gesellschaft und Alltag — in Deutschland und im Austausch mit Erfahrungen aus dem Ausland.</p>
          </article>
          <article class="card feature-card">
            <h3>Orientierung bei Umzug & Ausland</h3>
            <p>Informationsangebote zu ersten Schritten, Unterlagen, Konsulaten und Ansprechpartnern — persönliche Wege verständlich einordnen.</p>
          </article>
          <article class="card feature-card">
            <h3>Beruf & Anerkennung</h3>
            <p>Themenabende für Fachkräfte — Medizin, Pflege, Technik, Bildung und weitere Berufsgruppen — mit Blick auf Anerkennung und Einstieg im Ausland.</p>
          </article>
          <article class="card feature-card">
            <h3>Alltag & Leben vor Ort</h3>
            <p>Praktische Informationen zu Wohnen, Finanzen, Versicherungen, Bildung, Gesundheit und Alltag — ohne individuelle Rechts- oder Steuerberatung.</p>
          </article>
          <article class="card feature-card">
            <h3>Begegnungen mit Expertinnen und Experten</h3>
            <p>Webinare und persönliche Treffen mit Menschen, die relevante Wege bereits erfolgreich gegangen sind.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- 5. Mitgliedschaft -->
    <section class="ic-section ic-section-alt" id="mitgliedschaft" aria-labelledby="ic-mitglied-title">
      <div class="container">
        <h2 id="ic-mitglied-title">Mitgliedschaft als Zugang zu unseren Angeboten</h2>
        <p class="ic-subhead">Werde Teil von BiFoDe e.V. und nutze die Bildungs-, Sprach- und Community-Angebote des Vereins.</p>
        <p class="ic-lead">
          Mit einer Mitgliedschaft bei BiFoDe e.V. unterstützt du unsere Bildungsarbeit und wirst Teil eines Netzwerks für Sprache, Austausch und Community in Deutschland. Mitglieder erhalten Zugang zu ausgewählten Vereinsangeboten, Informationen zu Kursen und Veranstaltungen sowie Teilnahme an internen Formaten — je nach Verfügbarkeit und Projektphase.
        </p>
        <p class="ic-note"><strong>Wichtig:</strong> Die konkrete Teilnahme an Kursen und Veranstaltungen erfolgt je nach Verfügbarkeit, Projektphase und organisatorischen Rahmenbedingungen. Für einzelne Angebote können zusätzliche Teilnahmebeiträge anfallen.</p>
        <div class="card-grid ic-membership-grid">
          <article class="card feature-card"><h3>Ulpan-Kurse</h3><p>Mitglieder werden bevorzugt über neue Online- und Präsenzkurse informiert und können sich für verfügbare Plätze anmelden.</p></article>
          <article class="card feature-card"><h3>Moodle-Lernplattform</h3><p>Zugang zur Vereins-Moodle-Instanz mit Kursmaterialien, Übungen und begleitenden Lernformaten — nach Aufnahme in den Verein.</p></article>
          <article class="card feature-card"><h3>Lernmaterialien</h3><p>Zugang zu ausgewählten Lernmaterialien, Übungsunterlagen, Links und Empfehlungen rund um Sprache und Bildung.</p></article>
          <article class="card feature-card"><h3>Gesprächs- und Sprachclubs</h3><p>Teilnahme an Gesprächsrunden, Sprachpraxisgruppen und Diskussionsformaten für Austausch.</p></article>
          <article class="card feature-card"><h3>Webinare & Expertenformate</h3><p>Einladungen zu Online- und Präsenzveranstaltungen mit Expertinnen und Experten zu Beruf, Bildung und Alltag.</p></article>
          <article class="card feature-card"><h3>Community & Feiertage</h3><p>Gemeinsame Treffen, kulturelle Formate, Feiertage und Begegnungen innerhalb der Community.</p></article>
          <article class="card feature-card"><h3>Merch & Vereinsmaterialien</h3><p>Zugang zu ausgewählten Vereinsmaterialien und Community-Merch, sofern verfügbar und passend zum jeweiligen Projektformat.</p></article>
        </div>
        <p class="ic-cta-row">
          <a href="/mitglied-werden" class="ic-btn ic-btn-primary" data-track="membership_intent">Mitglied werden und Angebote nutzen</a>
          <a href={MOODLE_INFO_PATH} class="ic-btn ic-btn-outline">Moodle für Mitglieder</a>
        </p>
        <p class="ic-small">Die Mitgliedschaft ist ein Beitrag zur Vereinsarbeit. Einzelne Kurse oder Veranstaltungen können zusätzliche Beiträge oder eine separate Anmeldung erfordern.</p>
      </div>
    </section>

    <!-- 6. Zielgruppen -->
    <section class="ic-section" id="zielgruppen" aria-labelledby="ic-ziel-title">
      <div class="container ic-narrow">
        <h2 id="ic-ziel-title">Für wen ist das Angebot gedacht?</h2>
        <ul class="ic-checklist">
          <li>Für Menschen, die Hebräisch lernen möchten.</li>
          <li>Für Familien, die sich mit Kultur und Alltag im Ausland vertraut machen wollen.</li>
          <li>Für Menschen mit persönlicher oder familiärer Verbindung zur Region — unabhängig von Hintergrund oder Weltanschauung.</li>
          <li>Für alle, die einen längeren Aufenthalt oder Umzug ins Ausland prüfen.</li>
          <li>Für Fachkräfte mit Fragen zu Anerkennung und Berufseinstieg.</li>
          <li>Für Studierende und junge Erwachsene, die Bildungs- und Zukunftswege kennenlernen möchten.</li>
          <li>Für alle, die Austausch, Orientierung und eine seriöse Community suchen.</li>
        </ul>
      </div>
    </section>

    <!-- 7. Themenbereiche -->
    <section class="ic-section ic-section-alt" id="themen" aria-labelledby="ic-themen-title">
      <div class="container">
        <h2 id="ic-themen-title">Unsere Themenbereiche</h2>
        <ul class="ic-tag-grid">
          {themeTags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      </div>
    </section>

    <!-- 8. Formate -->
    <section class="ic-section" id="veranstaltungen" aria-labelledby="ic-formate-title">
      <div class="container">
        <h2 id="ic-formate-title">Unsere Formate</h2>
        <div class="card-grid">
          <article class="card feature-card"><h3>Webinare</h3><p>Digitale Informationsabende mit Expertinnen und Experten aus Deutschland und Israel.</p></article>
          <article class="card feature-card"><h3>Präsenztreffen</h3><p>Lokale Treffen, Gesprächsabende und Community-Events in Deutschland.</p></article>
          <article class="card feature-card"><h3>Fachgespräche</h3><p>Spezielle Sessions für Berufsgruppen – zum Beispiel Medizin, Bildung, Technik, Medien und Wirtschaft.</p></article>
          <article class="card feature-card"><h3>Erfahrungsberichte</h3><p>Menschen erzählen, wie sie ihren Weg nach Israel vorbereitet und gestaltet haben.</p></article>
          <article class="card feature-card"><h3>Sprachpraxis</h3><p>Hebräisch in kleinen Gruppen — Austausch und praktische Übungen.</p></article>
        </div>
      </div>
    </section>

    <!-- 9. Expertenthemen -->
    <section class="ic-section ic-section-alt" id="expertenthemen" aria-labelledby="ic-expert-title">
      <div class="container">
        <h2 id="ic-expert-title">Beispiele für kommende Themen</h2>
        <ul class="ic-bullet-list">
          <li>Als Ärztin oder Arzt nach Israel: Anerkennung, Sprache, erste Schritte</li>
          <li>Von Deutschland nach Israel: persönliche Erfahrung eines erfolgreichen beruflichen Neustarts</li>
          <li>Arbeiten in Israel: Arbeitsmarkt, Bewerbungen, Netzwerke</li>
          <li>Immobilien in Israel: Mieten, Kaufen, typische Fragen</li>
          <li>Bankkonto, Steuern und Versicherungen in Israel</li>
          <li>Studium und Ausbildung in Israel</li>
          <li>Schule, Kinder und Familie</li>
          <li>Hebräisch lernen: Wie man realistisch beginnt und dranbleibt</li>
          <li>Medien, Kultur und Gesellschaft in Israel</li>
        </ul>
        <aside class="ic-highlight card">
          <h3>Praxisnaher Einblick</h3>
          <p>
            Ein deutscher Sprecher und Medienprofi, der nach Israel gezogen ist und heute erfolgreich dort arbeitet, berichtet über seinen Weg, Herausforderungen und praktische Tipps.
          </p>
        </aside>
      </div>
    </section>

    <!-- 10. Warum teilnehmen -->
    <section class="ic-section" id="warum" aria-labelledby="ic-warum-title">
      <div class="container">
        <h2 id="ic-warum-title">Warum teilnehmen?</h2>
        <div class="card-grid">
          <article class="card feature-card"><h3>Verlässliche Orientierung</h3><p>Wir helfen, Informationen zu strukturieren und die richtigen nächsten Schritte zu verstehen.</p></article>
          <article class="card feature-card"><h3>Community statt Einzelkampf</h3><p>Du triffst Menschen mit ähnlichen Fragen, Erfahrungen und Zielen.</p></article>
          <article class="card feature-card"><h3>Direkter Zugang zu Wissen</h3><p>Expertinnen, Experten und Menschen mit echter Erfahrung teilen konkrete Einblicke.</p></article>
          <article class="card feature-card"><h3>Bildung mit Kontext</h3><p>Sprache, Kultur, Gesellschaft und praktische Lebensfragen werden verständlich verbunden.</p></article>
        </div>
      </div>
    </section>

    <!-- 11. WZO -->
    <section class="ic-section ic-section-alt" id="wzo" aria-labelledby="ic-wzo-title">
      <div class="container ic-narrow">
        <h2 id="ic-wzo-title">Partner & Rahmen</h2>
        <p class="ic-lead">
          Das Projekt entsteht im Rahmen der Bildungsarbeit von BiFoDe e.V. und wird mit internationalen Partnern weiterentwickelt, darunter die World Zionist Organization. Gemeinsam ermöglichen wir Zugang zu Bildungs-, Sprach- und Informationsangeboten — sachlich, respektvoll und ohne politische Einordnung durch BiFoDe.
        </p>
        <p class="ic-note">Die Angebote dienen der Bildung, Orientierung und allgemeinen Information. Sie ersetzen keine individuelle Rechts-, Steuer- oder Einwanderungsberatung.</p>
      </div>
    </section>

    <!-- 12. Mitglied werden -->
    <section class="ic-section" id="mitglied-werden" aria-labelledby="ic-mw-title">
      <div class="container ic-narrow">
        <h2 id="ic-mw-title">Mitglied bei BiFoDe e.V. werden</h2>
        <p class="ic-lead">
          Du möchtest unsere Bildungsarbeit langfristig unterstützen und Zugang zu unseren Vereinsangeboten erhalten? Als Mitglied wirst du Teil eines Netzwerks für Sprache, Austausch, Veranstaltungen und Community in Deutschland.
        </p>
        <p><strong>Als Mitglied kannst du:</strong></p>
        <ul class="ic-checklist">
          <li>frühzeitig Informationen zu neuen Ulpan-Kursen erhalten;</li>
          <li>dich für Online- und Präsenzangebote anmelden;</li>
          <li>an ausgewählten Sprach- und Gesprächsformaten teilnehmen;</li>
          <li>Zugang zu Lernmaterialien und Empfehlungen erhalten;</li>
          <li>Einladungen zu Webinaren und Expertenveranstaltungen bekommen;</li>
          <li>an Community-Treffen und gemeinsamen Feiertagsformaten teilnehmen;</li>
          <li>die Entwicklung neuer Bildungsangebote aktiv unterstützen.</li>
        </ul>
        <p class="ic-cta-row">
          <a href="/mitglied-werden" class="ic-btn ic-btn-primary" data-track="membership_intent">Mitgliedschaft anfragen</a>
        </p>
        <div class="ic-tax-box">
          <h3>Steuerlicher Vorteil</h3>
          <p>
            Mitgliedsbeiträge und Spenden an gemeinnützige Organisationen können in Deutschland grundsätzlich steuerlich berücksichtigt werden, sofern die gesetzlichen Voraussetzungen erfüllt sind. BiFoDe e.V. stellt Zuwendungsbestätigungen aus, soweit dies rechtlich zulässig ist.
          </p>
          <p class="ic-small">Die steuerliche Behandlung hängt von der persönlichen Situation und den geltenden gesetzlichen Vorgaben ab. Diese Information ersetzt keine steuerliche Beratung.</p>
        </div>
      </div>
    </section>

    <!-- 13. Spenden -->
    <section class="ic-section ic-section-alt" id="spenden" aria-labelledby="ic-spenden-title">
      <div class="container ic-narrow">
        <h2 id="ic-spenden-title">Unsere Arbeit unterstützen</h2>
        <p class="ic-lead">
          Mit einer Spende unterstützt du Bildungsangebote, Sprachformate, Informationsveranstaltungen und Community-Arbeit. Jeder Beitrag hilft, neue Angebote zugänglich zu machen.
        </p>
        <div class="ic-hero-actions">
          <a
            href={spendenHref}
            class="ic-btn ic-btn-primary"
            data-track={spendenIsDonationLink ? 'donation_intent' : 'contact_cta'}
          >
            Jetzt spenden
          </a>
          <a href="#kontakt" class="ic-btn ic-btn-secondary" data-track="contact_cta">Erst Kontakt aufnehmen</a>
        </div>
        {!donationUrl && (
          <p class="ic-note">Online-Spenden über einen externen Anbieter folgen in Kürze — bis dahin Banküberweisung und Infos auf der <a href="/spenden">Spenden-Seite</a>.</p>
        )}
        <p class="ic-note">Spenden können – bei Vorliegen der gesetzlichen Voraussetzungen – steuerlich berücksichtigt werden. BiFoDe e.V. stellt Zuwendungsbestätigungen aus, soweit rechtlich zulässig.</p>
      </div>
    </section>

    <!-- 14. Kontaktformular -->
    <section class="ic-section" id="kontakt" aria-labelledby="ic-kontakt-title">
      <div class="container ic-kontakt-stack">
        <h2 id="ic-kontakt-title">Stell deine Frage direkt</h2>
        <p class="ic-lead ic-lead-centered">
          Du hast eine Frage zu Sprache, einem möglichen Umzug, Dokumenten, Beruf, Studium, Wohnen, Finanzen oder Alltag im Ausland? Schreib uns. Wir ordnen dein Anliegen ein und verbinden dich – wenn möglich – mit passenden Informationen, Veranstaltungen oder Ansprechpartnern.
        </p>
        <div class="card contact-form-card ic-form-card">
          <form class="contact-form" id="ic-contact-form" novalidate>
            <input type="hidden" name="utm_source" id="utm_source" />
            <input type="hidden" name="utm_medium" id="utm_medium" />
            <input type="hidden" name="utm_campaign" id="utm_campaign" />
            <input type="hidden" name="utm_content" id="utm_content" />
            <input type="hidden" name="utm_term" id="utm_term" />
            <input type="hidden" name="page_source" id="page_source" value="israel_community_landing" />

            <div class="ic-form-row">
              <div class="form-group">
                <label for="ic-firstName">Vorname *</label>
                <input type="text" id="ic-firstName" name="firstName" required autocomplete="given-name" />
              </div>
              <div class="form-group">
                <label for="ic-lastName">Nachname *</label>
                <input type="text" id="ic-lastName" name="lastName" required autocomplete="family-name" />
              </div>
            </div>
            <div class="form-group">
              <label for="ic-email">E-Mail *</label>
              <input type="email" id="ic-email" name="email" required autocomplete="email" />
            </div>
            <div class="form-group">
              <label for="ic-phone">Telefonnummer / WhatsApp</label>
              <input type="tel" id="ic-phone" name="phone" autocomplete="tel" />
            </div>
            <div class="form-group">
              <label for="ic-city">Stadt in Deutschland</label>
              <input type="text" id="ic-city" name="city" autocomplete="address-level2" />
            </div>
            <div class="form-group">
              <label for="ic-interest">Interessensbereich *</label>
              <select id="ic-interest" name="interest" required>
                <option value="">Bitte wählen</option>
                {interestOptions.map((opt) => (
                  <option value={opt}>{opt}</option>
                ))}
              </select>
            </div>
            <fieldset class="ic-fieldset">
              <legend>Welche Angebote interessieren dich?</legend>
              <div class="ic-checkbox-grid">
                {offerOptions.map((opt) => (
                  <label class="ic-checkbox-label">
                    <input type="checkbox" name="offers" value={opt} />
                    <span>{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>
            <div class="form-group">
              <label for="ic-message">Nachricht / Frage *</label>
              <textarea id="ic-message" name="message" rows="5" required></textarea>
            </div>
            <div class="form-group checkbox-group">
              <input type="checkbox" id="ic-privacy" name="privacy" required />
              <label for="ic-privacy">
                Ich stimme zu, dass meine Angaben zur Bearbeitung meiner Anfrage gespeichert und verarbeitet werden. Weitere Informationen finde ich in der <a href="/datenschutz">Datenschutzerklärung</a>.
              </label>
            </div>
            <div class="form-group checkbox-group">
              <input type="checkbox" id="ic-newsletter" name="newsletter" />
              <label for="ic-newsletter">Ich möchte Informationen zu Kursen, Veranstaltungen und Vereinsangeboten per E-Mail erhalten.</label>
            </div>
            <div class="hp-field" aria-hidden="true">
              <label for="ic-website">Website</label>
              <input type="text" id="ic-website" name="website" tabindex="-1" autocomplete="off" />
            </div>
            <button type="submit" class="ic-btn ic-btn-primary" data-track="form_submit">Frage absenden</button>
          </form>
          <p class="form-note" id="ic-form-note">Alternativ: <a href="mailto:info@bifode.org">info@bifode.org</a></p>
        </div>
        <div class="ic-privacy-box">
          <p><strong>Hinweis zum Datenschutz:</strong> Wir verwenden deine Angaben ausschließlich zur Bearbeitung deiner Anfrage und zur Kommunikation im Rahmen der Vereinsarbeit. Personenbezogene Angaben aus dem Formular werden nicht an Meta Pixel übermittelt. Wenn du Marketing-Cookies akzeptierst, können allgemeine Interaktionen auf dieser Seite gemessen werden, um relevante Informationen zu unseren Bildungs- und Community-Angeboten anzeigen zu können.</p>
          <p class="ic-small">{/* TODO: Datenschutzerklärung um Kontaktformular, CRM/Formularverarbeitung und Meta Pixel ergänzen. */}</p>
        </div>
      </div>
    </section>

    <!-- 15. Final CTA -->
    <section class="ic-section ic-final-cta" aria-labelledby="ic-final-title">
      <div class="container ic-narrow ic-final-inner">
        <h2 id="ic-final-title">Sprache, Orientierung oder Community — worum geht es bei dir?</h2>
        <p class="ic-lead">
          Melde dich unverbindlich an, stelle deine Frage oder werde Mitglied bei BiFoDe e.V. Wir informieren dich über passende Kurse, Gesprächsformate und Veranstaltungen.
        </p>
        <div class="ic-hero-actions">
          <a href="#kontakt" class="ic-btn ic-btn-primary" data-track="contact_cta">Frage stellen</a>
          <a href="/mitglied-werden" class="ic-btn ic-btn-secondary" data-track="membership_intent">Mitglied werden</a>
          <a
            href={FB_GROUP}
            class="ic-btn ic-btn-outline"
            target="_blank"
            rel="noopener noreferrer"
            data-track="facebook_group_click"
          >
            Facebook-Gruppe öffnen
          </a>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

