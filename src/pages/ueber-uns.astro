---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';

const team = [
  { name: 'Denis Vilensky', role: '1. Vorsitzender' },
  { name: 'Denis Berengolts', role: 'Stellvertretender Vorsitzender' },
  { name: 'Ilja Litwin', role: 'Schatzmeister' },
];

const timeline = [
  { year: '2024', text: 'Gründungsidee und erste Gespräche mit Schulen und Partnern in NRW.' },
  { year: '2025', text: 'Aufbau der Vereinsstruktur, Entwicklung der Bildungsmodule und Netzwerkarbeit.' },
  { year: '2026', text: 'Start des Pilotprojekts NRW mit ersten Workshops und Kooperationen vor Ort.' },
];
---

<MainLayout
  title="Über uns"
  description="BiFoDe e.V. — Bildungsforum für Demokratie und Vielfalt in NRW. Mission, Team, Rechtsform und Gründungsgeschichte."
>
  <Hero
    centered={false}
    title="Über BiFoDe e.V."
    subtitle="Bildungsforum für Demokratie und Vielfalt NRW — gemeinnützige Bildungs- und Präventionsarbeit für Schulen und Partner."
  />

  <section class="container">
    <div class="section-header"><h2>Unsere Mission</h2></div>
    <p class="lead">
      Wir stärken demokratische Bildung und Antisemitismusprävention in Nordrhein-Westfalen. BiFoDe entwickelt praxisnahe Formate für Schulen, Kommunen und zivilgesellschaftliche Partner — mit klarer Haltung, wissenschaftlicher Fundierung und respektvollem Miteinander.
    </p>
  </section>

  <section class="container">
    <div class="section-header"><h2>Rechtsform & Status</h2></div>
    <div class="card legal-card">
      <p><strong>BiFoDe e.V.</strong> (Bildungsforum für Demokratie und Vielfalt NRW e.V.)</p>
      <ul>
        <li>Eingetragener gemeinnütziger Verein (<strong>e.V.</strong>)</li>
        <li>Sitz und Tätigkeit in <strong>Nordrhein-Westfalen</strong></li>
        <li>Migrantenselbstorganisation (<strong>MSO</strong>) in NRW</li>
        <li>Überparteilich und konfessionell ungebunden</li>
        <li>Schwerpunkt: demokratische Bildung, Antisemitismusprävention, Medienkompetenz</li>
      </ul>
      <p class="legal-note">
        Der Verein ist im Vereinsregister eingetragen. Die <a href="/satzung">Satzung</a>, unsere <a href="/charta">Charta</a> und unsere <a href="/werte">Werte</a> sind veröffentlicht.
      </p>
    </div>
  </section>

  <section class="container">
    <div class="section-header"><h2>Gründungsgeschichte</h2></div>
    <ol class="timeline">
      {timeline.map((item) => (
        <li>
          <span class="timeline-year">{item.year}</span>
          <p>{item.text}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="container">
    <div class="section-header"><h2>Vorstand</h2></div>
    <p class="lead">Der Vorstand von BiFoDe e.V. gemäß § 26 BGB. Unser Team wächst mit dem Pilotprojekt.</p>
    <div class="card-grid team-grid">
      {team.map((member) => (
        <article class="card team-card">
          <span class="team-avatar" aria-hidden="true">{member.name.charAt(0)}</span>
          <h3>{member.name}</h3>
          <p>{member.role}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container cta-section">
    <a class="btn-outline" href="/kooperation">Kooperation starten →</a>
  </section>
</MainLayout>

<style>
  .section-header h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #111827;
  }

  .lead {
    color: #475569;
    line-height: 1.8;
    max-width: 720px;
  }

  .legal-card ul {
    margin: 0.75rem 0;
    padding-left: 1.25rem;
    line-height: 1.8;
    color: #334155;
  }

  .legal-note {
    margin: 1rem 0 0;
    font-size: 0.9rem;
    color: #64748b;
  }

  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid #dbeafe;
    max-width: 720px;
  }

  .timeline li {
    position: relative;
    padding: 0 0 1.5rem 1.5rem;
  }

  .timeline li::before {
    content: '';
    position: absolute;
    left: -7px;
    top: 0.35rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #163b63;
  }

  .timeline-year {
    display: block;
    font-weight: 700;
    color: #163b63;
    margin-bottom: 0.25rem;
  }

  .timeline p {
    margin: 0;
    color: #475569;
    line-height: 1.7;
  }

  .team-grid {
    margin-top: 1.5rem;
  }

  .team-card {
    text-align: center;
  }

  .team-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e8f1ff, #dbeafe);
    color: #163b63;
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .team-card h3 {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
  }

  .team-card p {
    margin: 0;
    color: #64748b;
    font-size: 0.9rem;
  }

  .cta-section {
    padding: 2rem 0 3rem;
    text-align: center;
  }
</style>
