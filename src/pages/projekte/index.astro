---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';
import { MOODLE_INFO_PATH, ULPAN_LANDING_PATH } from '../../lib/communityLinks';
import { PROJECT_CARDS } from '../../lib/projectCards';
---

<MainLayout
  title="Projekte"
  description="Pilotprojekt NRW, Ulpan Next und weitere Bildungsprojekte von BiFoDe e.V. — Antisemitismusprävention und demokratische Bildung in Nordrhein-Westfalen."
>
  <Hero
    centered={false}
    title="Projekte"
    subtitle="Unsere Projekte verbinden Bildungsarbeit, Prävention und praktische Orientierung für Schulen und Partner in Nordrhein-Westfalen."
  />

  <section class="container projects-overview">
    <div class="section-header">
      <h2>Projektübersicht</h2>
    </div>
    <p class="lead">Wählen Sie ein Projekt — jedes Format hat eine eigene Seite mit Details und nächsten Schritten.</p>

    <div class="card-grid projects-grid">
      {
        PROJECT_CARDS.map((project) =>
          project.status === 'soon' ? (
            <article class="card project-card project-card--soon">
              <h3>{project.titleDe}</h3>
              <p>{project.descriptionDe}</p>
              <span class="badge">Demnächst</span>
            </article>
          ) : (
            <a class="card project-card project-card--link" href={project.href}>
              <h3>{project.titleDe}</h3>
              <p>{project.descriptionDe}</p>
              <span class="project-card-cta">Zum Projekt →</span>
            </a>
          )
        )
      }
    </div>

    <aside class="moodle-callout card" aria-labelledby="moodle-callout-title">
      <h3 id="moodle-callout-title">Moodle — Lernplattform für Mitglieder</h3>
      <p>
        Mitglieder von BiFoDe e.V. nutzen unsere Moodle-Instanz für Kursmaterialien, Übungen und begleitende Lernformate zu Ulpan Next.
        Zugang erhalten Sie nach Aufnahme in den Verein.
      </p>
      <div class="moodle-callout-actions">
        <a class="project-card-cta" href={MOODLE_INFO_PATH}>Zur Moodle-Seite →</a>
        <a class="moodle-callout-secondary" href={ULPAN_LANDING_PATH}>Ulpan Next →</a>
      </div>
    </aside>
  </section>
</MainLayout>

<style>
  .section-header h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #111827;
  }

  .lead {
    color: #475569;
    line-height: 1.8;
    max-width: 720px;
  }

  .projects-overview {
    padding-bottom: 3rem;
  }

  .projects-grid {
    margin-top: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .project-card h3 {
    margin: 0;
    font-size: 1.2rem;
    color: #111827;
  }

  .project-card p {
    margin: 0;
    flex: 1;
    color: #64748b;
    line-height: 1.55;
  }

  .project-card--link:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 14px var(--accent-tint);
  }

  .project-card-cta {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--primary);
  }

  .project-card--soon {
    opacity: 0.92;
  }

  .badge {
    display: inline-block;
    margin-top: 0.25rem;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    background: #eef2ff;
    color: #1e3a8a;
    font-size: 0.8rem;
    font-weight: 600;
    width: fit-content;
  }

  .moodle-callout {
    margin-top: 2rem;
    padding: 1.5rem 1.75rem;
    border-left: 4px solid var(--accent);
  }

  .moodle-callout h3 {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
    color: #111827;
  }

  .moodle-callout p {
    margin: 0 0 1rem;
    color: #475569;
    line-height: 1.7;
    max-width: 720px;
  }

  .moodle-callout-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    align-items: center;
  }

  .moodle-callout-secondary {
    color: #163b63;
    font-weight: 600;
    text-decoration: none;
  }

  .moodle-callout-secondary:hover {
    text-decoration: underline;
  }
</style>
