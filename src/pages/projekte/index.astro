---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';
---

<MainLayout
  title="Projekte"
  description="Pilotprojekt NRW und weitere Bildungsprojekte von BiFoDe e.V. — Antisemitismusprävention und demokratische Bildung für Schulen in Nordrhein-Westfalen."
>
  <Hero
    centered={false}
    title="Projekte"
    subtitle="Unsere Projekte verbinden Bildungsarbeit, Prävention und praktische Orientierung für Schulen und Partner in Nordrhein-Westfalen."
  />

  <section class="container pilot-section">
    <div class="section-header">
      <h2>Pilotprojekt NRW</h2>
    </div>
    <p class="lead">
      Das <strong>Pilotprojekt NRW</strong> ist unser Hauptprojekt: In enger Zusammenarbeit mit Schulen und Bildungspartnern testen und verfeinern wir modulare Formate zu Antisemitismusprävention, Medienkompetenz und demokratischem Zusammenhalt.
    </p>

    <div class="card pilot-card">
      <h3>Projektziele</h3>
      <ul>
        <li>Praxisnahe Workshops und Projekttage in Schulen etablieren</li>
        <li>Lehrkräfte mit Materialien und fachlicher Einordnung unterstützen</li>
        <li>Formate evaluieren und für NRW-weiten Roll-out vorbereiten</li>
      </ul>

      <h3>Zielgruppen</h3>
      <ul>
        <li>Schulen (Sekundarstufe I und II)</li>
        <li>Lehrkräfte und pädagogische Fachkräfte</li>
        <li>Kommunen und zivilgesellschaftliche Partner</li>
      </ul>

      <h3>Zeitplan (Pilotphase)</h3>
      <ul class="timeline-inline">
        <li><strong>Q1–Q2 2026:</strong> Vorgespräche und erste Workshops</li>
        <li><strong>Q3 2026:</strong> Ausweitung auf weitere Standorte</li>
        <li><strong>Q4 2026:</strong> Auswertung und Weiterentwicklung der Module</li>
      </ul>

      <a class="btn-outline" href="/fuer-schulen">Workshop anfragen →</a>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Weitere Projekte</h2>
    </div>
    <p class="lead">Weitere Schwerpunkte sind in Planung und werden hier ergänzt, sobald sie starten.</p>
    <div class="card-grid">
      <article class="card project-card placeholder-card">
        <h3>Digitale Bildungsmodule</h3>
        <p>Interaktive Online-Inhalte für Schulen — in Vorbereitung.</p>
        <span class="badge">Demnächst</span>
      </article>
      <article class="card project-card placeholder-card">
        <h3>Interaktive Lernstationen</h3>
        <p>Informations- und Lernstationen für Schulen und öffentliche Räume — Konzeptphase.</p>
        <span class="badge">Demnächst</span>
      </article>
    </div>
  </section>

  <section class="container cta-section">
    <p class="lead">Sie möchten das Pilotprojekt mit Ihrer Schule oder Institution begleiten?</p>
    <a class="button" href="/kontakt">Kontakt aufnehmen</a>
  </section>
</MainLayout>

<style>
  .section-header h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #111827;
  }

  .lead {
    color: #475569;
    line-height: 1.8;
    max-width: 720px;
  }

  .pilot-card {
    margin-top: 1.5rem;
    max-width: 720px;
  }

  .pilot-card h3 {
    margin: 1.25rem 0 0.5rem;
    font-size: 1.1rem;
    color: #163b63;
  }

  .pilot-card h3:first-child {
    margin-top: 0;
  }

  .pilot-card ul {
    margin: 0;
    padding-left: 1.25rem;
    line-height: 1.8;
    color: #334155;
  }

  .pilot-card .btn-outline {
    margin-top: 1.5rem;
  }

  .placeholder-card {
    opacity: 0.92;
  }

  .badge {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    background: #eef2ff;
    color: #1e3a8a;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .cta-section {
    padding: 2.5rem 0 3rem;
    text-align: center;
  }

  .button {
    display: inline-flex;
    padding: 1rem 1.6rem;
    border-radius: 0.9rem;
    background: linear-gradient(135deg, #1d4ed8 0%, #163b63 100%);
    color: white;
    text-decoration: none;
    font-weight: 600;
  }
</style>
