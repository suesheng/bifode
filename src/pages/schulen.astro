---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
---

<MainLayout title="Angebote für Schulen" description="Bildungsformate zu Antisemitismus, Vorurteilen, Medienkompetenz und demokratischem Zusammenhalt.">
  <Hero centered={false} title="Angebote für Schulen" subtitle="Bildungsformate zu Antisemitismus, Vorurteilen, Medienkompetenz und demokratischem Zusammenhalt." />

  <section class="container">
    <div class="section-header">
      <h2>Warum dieses Angebot?</h2>
    </div>
    <p class="lead">Viele Schulen erleben, dass gesellschaftliche Konflikte, Vorurteile und Desinformation auch im Schulalltag sichtbar werden. Lehrkräfte brauchen Orientierung, Materialien und Formate, die praxisnah und altersgerecht sind.</p>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Für wen?</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M3 10.5 12 5l9 5.5-9 5.5z" />
            <path d="M7 12.5V16a5 3 0 0 0 10 0v-3.5" />
          </svg>
        </div>
        <h3>Sekundarstufe I</h3>
        <p>Altersgerechte Formate für Jugendliche in der Mittelstufe, abgestimmt auf schulische Bedürfnisse.</p>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M3 10.5 12 5l9 5.5-9 5.5z" />
            <path d="M7 12.5V16a5 3 0 0 0 10 0v-3.5" />
          </svg>
        </div>
        <h3>Sekundarstufe II</h3>
        <p>Vertiefende Angebote für ältere Schülerinnen und Schüler mit Fokus auf kritisch-reflexives Lernen.</p>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <circle cx="8.5" cy="8" r="2.5" />
            <path d="M4.5 17a4 4 0 0 1 8 0" />
            <rect x="13" y="6" width="7" height="6" rx="1" />
            <path d="M14 16h6" />
          </svg>
        </div>
        <h3>Lehrkräfte</h3>
        <p>Materialien und Begleitung für Lehrkräfte, um Unterricht sicher und selbstbewusst zu gestalten.</p>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="3" />
            <path d="M6 19a6 6 0 0 1 12 0" />
            <path d="M9 12h6" />
          </svg>
        </div>
        <h3>Pädagogische Fachkräfte</h3>
        <p>Professionelle Unterstützung für Schulsozialarbeit und pädagogische Beratung.</p>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Themen</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M12 4 6 6.5V12c0 4.2 2.8 6.7 6 8 3.2-1.3 6-3.8 6-8V6.5z" />
            <path d="m9.5 12 2 2 3-3.2" />
          </svg>
        </div>
        <h3>Antisemitismus verstehen</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M2.5 12s3.5-5 9.5-5 9.5 5 9.5 5-3.5 5-9.5 5-9.5-5-9.5-5z" />
            <circle cx="12" cy="12" r="2.5" />
          </svg>
        </div>
        <h3>Vorurteile erkennen</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="4" y="6" width="16" height="11" rx="2" />
            <path d="M10 20h4M9 17h6" />
            <path d="m10 10 2 1.4L14 10" />
          </svg>
        </div>
        <h3>Medienkompetenz stärken</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="6" />
            <path d="m20 20-4.2-4.2" />
            <path d="M11 8v6M8 11h6" />
          </svg>
        </div>
        <h3>Desinformation einordnen</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M5 10h14v10H5z" />
            <path d="M9 10V6h6v4" />
            <path d="M9 14h6" />
          </svg>
        </div>
        <h3>Demokratische Werte vermitteln</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M4 7h16v9H8l-4 4z" />
            <path d="M9 11h6" />
          </svg>
        </div>
        <h3>Konflikte im Schulalltag besprechen</h3>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Formate</h2>
    </div>
    <div class="card-grid">
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M7 5h10v4H7z" />
            <path d="M7 14h10v5H7z" />
            <path d="M12 9v5" />
          </svg>
        </div>
        <h3>Workshops</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="4" y="6" width="16" height="14" rx="2" />
            <path d="M8 4v4M16 4v4M4 10h16" />
          </svg>
        </div>
        <h3>Projekttage</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="4" y="6" width="16" height="10" rx="2" />
            <path d="M2.5 19h19" />
          </svg>
        </div>
        <h3>Digitale Module</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="3.5" y="5.5" width="17" height="11" rx="2" />
            <path d="M10 19h4M8.5 16.5h7" />
          </svg>
        </div>
        <h3>Interaktive Displays / Kiosk</h3>
      </div>
      <div class="card feature-card">
        <div class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M5 6h8a3 3 0 0 1 3 3v9H8a3 3 0 0 0-3 3z" />
            <path d="M19 6h-6a3 3 0 0 0-3 3v12a3 3 0 0 1 3-3h6z" />
          </svg>
        </div>
        <h3>Fortbildungen für Lehrkräfte</h3>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Unser Ansatz</h2>
    </div>
    <p class="lead">Unsere Angebote sind keine religiösen oder gruppenspezifischen Inhalte, sondern Teil demokratischer Bildungsarbeit. Jüdisches Leben dient als realer Bezugspunkt, um aktuelle gesellschaftliche Fragen verständlich zu machen.</p>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>Ablauf</h2>
    </div>
    <div class="grid steps">
      <article class="card">
        <p>Anfrage</p>
      </article>
      <article class="card">
        <p>Vorgespräch</p>
      </article>
      <article class="card">
        <p>Format auswählen</p>
      </article>
      <article class="card">
        <p>Durchführung</p>
      </article>
      <article class="card">
        <p>Auswertung</p>
      </article>
    </div>
  </section>

  <section class="container cta-section">
    <a class="button" href="/kontakt">Schulangebot anfragen</a>
  </section>
</MainLayout>

<style>
  .hero {
    padding: 4rem 0 3rem;
    background: #f8fafc;
  }

  .hero-content {
    max-width: 760px;
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
  }

  .lead {
    color: #475569;
    line-height: 1.8;
    max-width: 720px;
  }

  .section-header h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #111827;
  }

  .grid,
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    background: #eef2ff;
    color: #1e3a8a;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.6rem;
    border-radius: 0.9rem;
    background: #1e3a8a;
    color: white;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .button:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  .cta-section {
    padding: 3rem 0;
    text-align: center;
  }

  .steps .card {
    text-align: center;
    min-height: 120px;
  }

  .steps .card p {
    font-weight: 600;
    color: #0f172a;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 2rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .button {
      width: 100%;
    }
  }
</style>
