---
// src/layouts/MainLayout.astro
import CookieBanner from '../components/CookieBanner.astro';
const {
  title = 'Startseite',
  description = 'BiFoDe e.V. entwickelt Bildungs- und Präventionsformate für Schulen und Partner in NRW',
  lang = 'de'
} = Astro.props;

const isEn = lang === 'en';
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = isEn
  ? [
      { href: '/en', label: 'Home' },
      { href: '/en/about', label: 'About' },
      { href: '/en/our-work', label: 'Our Work' },
      { href: '/en/schools', label: 'Schools' },
      { href: '/en/projects', label: 'Projects' },
      { href: '/en/cooperation', label: 'Cooperation' },
      { href: '/en/contact', label: 'Contact' }
    ]
  : [
      { href: '/', label: 'Startseite' },
      { href: '/ueber-uns', label: 'Über uns' },
      { href: '/unsere-arbeit', label: 'Unsere Arbeit' },
      { href: '/schulen', label: 'Schulen' },
      { href: '/projekte', label: 'Projekte' },
      { href: '/kooperation', label: 'Kooperation' },
      { href: '/kontakt', label: 'Kontakt' }
    ];

const pathMap: Record<string, string> = {
  '/': '/en',
  '/ueber-uns': '/en/about',
  '/unsere-arbeit': '/en/our-work',
  '/schulen': '/en/schools',
  '/projekte': '/en/projects',
  '/kooperation': '/en/cooperation',
  '/kontakt': '/en/contact',
  '/impressum': '/en/legal-notice',
  '/datenschutz': '/en/privacy',
  '/cookie-richtlinien': '/en/cookie-policy',
  '/en': '/',
  '/en/about': '/ueber-uns',
  '/en/our-work': '/unsere-arbeit',
  '/en/schools': '/schulen',
  '/en/projects': '/projekte',
  '/en/cooperation': '/kooperation',
  '/en/contact': '/kontakt',
  '/en/legal-notice': '/impressum',
  '/en/privacy': '/datenschutz',
  '/en/cookie-policy': '/cookie-richtlinien'
};

const counterpartPath = pathMap[currentPath] || (isEn ? '/kontakt' : '/en/contact');
const langDeHref = isEn ? counterpartPath : currentPath;
const langEnHref = isEn ? currentPath : counterpartPath;
---

<!doctype html>
<html lang={isEn ? 'en' : 'de'}>
        <head>
                <meta charset="UTF-8" />
                <meta name="viewport" content="width=device-width" />
                <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
                <link rel="icon" href="/favicon.ico" />
                <link rel="apple-touch-icon" href="/favicon.svg" />
                <meta name="generator" content={Astro.generator} />
                <title>{title} | BiFoDe</title>
                <meta name="description" content={description} />

                <!-- Preconnect to external font domains -->
                <link rel="preconnect" href="https://fonts.googleapis.com">
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

                <!-- Async Google Fonts with display=swap -->
                <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap">
                <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" media="print" onload="this.media='all'">
                <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"></noscript>

                <!-- Critical CSS - Inline for faster initial render (above-the-fold) -->
                <style>
                        *, *::before, *::after { box-sizing: border-box; }
                        html, body { margin: 0; padding: 0; height: 100%; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background-color: #f9fafb; color: #111827; scroll-behavior: smooth; }
                        .app-container { display: flex; flex-direction: column; min-height: 100vh; }
                        .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }
                        .navbar { background: white; border-bottom: 1px solid #e5e7eb; position: sticky; top: 0; z-index: 50; }
                        .nav-wrapper { display: flex; justify-content: space-between; align-items: center; padding: 1rem 16px; }
                        .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: #111827; font-weight: 700; font-size: 1.5rem; }
                        .logo-img { height: 36px; width: auto; }
                        .logo-light { display: block; }
                        .logo-dark { display: none; }
                        .nav-links { display: flex; gap: 2rem; }
                        .nav-links a { color: #6b7280; text-decoration: none; font-weight: 500; }
                        .burger-menu { display: none; flex-direction: column; background: none; border: none; cursor: pointer; padding: 0.5rem; gap: 0.4rem; }
                        .burger-line { width: 24px; height: 3px; background-color: #111827; border-radius: 2px; transition: all 0.3s ease; }
                        .main-content { flex: 1; padding: 2rem 0; }
                        @media (max-width: 768px) {
                                .burger-menu { display: flex; }
                                .nav-links { position: absolute; top: 100%; left: 0; right: 0; background: white; flex-direction: column; padding: 1rem; gap: 0; border-bottom: 1px solid #e5e7eb; max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
                                .navbar.is-open .nav-links { max-height: 500px; }
                                .nav-links a { padding: 0.75rem 1rem; border-bottom: 1px solid #f3f4f6; }
                        }
                </style>
        </head>
        <body>
                <div class="app-container">
                        <nav class="navbar" id="navbar">
                                <div class="container nav-wrapper">
                                        <a href="/" class="logo">
                                                <img src="/logos/logo-light.svg" alt="BiFoDe Logo" class="logo-img logo-light" />
                                        </a>
                                        <div class="nav-controls">
                                                <div class="lang-switch-mobile">
                                                        <a href={langDeHref} class="lang-link" aria-current={isEn ? undefined : 'page'}>DE</a>
                                                        <span class="lang-divider">|</span>
                                                        <a href={langEnHref} class="lang-link" aria-current={isEn ? 'page' : undefined}>EN</a>
                                                </div>
                                        <button class="burger-menu" id="burgerMenu" aria-label="Navigation menu" aria-expanded="false">
                                                <span class="burger-line"></span>
                                                <span class="burger-line"></span>
                                                <span class="burger-line"></span>
                                        </button>
                                        </div>
                                        <div class="nav-links" id="navLinks">
                                                {navItems.map((item) => (
                                                        <a href={item.href} data-nav-link>{item.label}</a>
                                                ))}
                                                <div class="lang-switch" id="langSwitch">
                                                        <a href={langDeHref} id="langDe" class="lang-link">DE</a>
                                                        <span class="lang-divider">|</span>
                                                        <a href={langEnHref} id="langEn" class="lang-link">EN</a>
                                                </div>
                                        </div>
                                </div>
                        </nav>

                        <main class="main-content">
                                <slot />
                        </main>

                        <footer class="footer">
                                <div class="container footer-grid">
                                        <div class="footer-section footer-about">
                                                <div class="footer-logo">
                                                        <img src="/logos/logo-dark.svg" alt="BiFoDe Logo" />
                                                </div>
                                                <p>{isEn ? 'BiFoDe NRW. We strengthen democratic education and are clearly committed to combating antisemitism.' : 'Bildungsforum für Demokratie und Vielfalt NRW. Wir stärken demokratische Bildung und engagieren uns klar gegen Antisemitismus.'}</p>
                                        </div>

                                        <div class="footer-section footer-nav">
                                                <h4>{isEn ? 'Navigation' : 'Navigation'}</h4>
                                                <ul>
                                                        {navItems.map((item) => (
                                                                <li><a href={item.href}>{item.label}</a></li>
                                                        ))}
                                                </ul>
                                        </div>

                                        <div class="footer-section footer-contact">
                                                <h4>{isEn ? 'Contact' : 'Kontakt'}</h4>
                                                <p>E-Mail: info@bifode.org</p>
                                                <p>{isEn ? 'Location: North Rhine-Westphalia' : 'Standort: Nordrhein-Westfalen'}</p>
                                        </div>

                                        <div class="footer-section footer-legal">
                                                <h4>{isEn ? 'Legal' : 'Rechtliches'}</h4>
                                                <ul>
                                                        <li><a href={isEn ? '/en/legal-notice' : '/impressum'}>{isEn ? 'Legal Notice' : 'Impressum'}</a></li>
                                                        <li><a href={isEn ? '/en/privacy' : '/datenschutz'}>{isEn ? 'Privacy Policy' : 'Datenschutz'}</a></li>
                                                        <li><button type="button" class="footer-cookie-button" id="footer-cookie-settings">{isEn ? 'Cookie Settings' : 'Cookie-Einstellungen'}</button></li>
                                                </ul>
                                        </div>
                                </div>

                                <div class="footer-bottom">
                                        <div class="container">
                                                <p>&copy; 2026 BiFoDe e.V. {isEn ? 'All rights reserved.' : 'Alle Rechte vorbehalten.'}</p>
                                        </div>
                                </div>
                        </footer>
                </div>

                <!-- Cookie Banner -->
                <CookieBanner />

                <script>
                        document.addEventListener('DOMContentLoaded', () => {
                                const burgerMenu = document.getElementById('burgerMenu');
                                const navbar = document.getElementById('navbar');
                                const navLinks = document.getElementById('navLinks');
                                if (!burgerMenu || !navbar || !navLinks) return;

                                const navItems = navLinks.querySelectorAll('[data-nav-link]');
                                const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
                                const langDe = document.getElementById('langDe');
                                const langEn = document.getElementById('langEn');

                                navItems.forEach(item => {
                                        const linkPath = (item.getAttribute('href') || '').replace(/\/$/, '') || '/';
                                        if (linkPath === currentPath) {
                                                item.setAttribute('aria-current', 'page');
                                        }
                                });

                                if (langDe && langEn) {
                                        if (currentPath.startsWith('/en')) {
                                                langEn.setAttribute('aria-current', 'page');
                                        } else {
                                                langDe.setAttribute('aria-current', 'page');
                                        }
                                }

                                // Toggle menu on burger click
                                burgerMenu.addEventListener('click', () => {
                                        navbar.classList.toggle('is-open');
                                        burgerMenu.classList.toggle('is-open');
                                        burgerMenu.setAttribute('aria-expanded', burgerMenu.classList.contains('is-open') ? 'true' : 'false');
                                });

                                // Close menu when a link is clicked
                                navItems.forEach(item => {
                                        item.addEventListener('click', () => {
                                                navbar.classList.remove('is-open');
                                                burgerMenu.classList.remove('is-open');
                                                burgerMenu.setAttribute('aria-expanded', 'false');
                                        });
                                });

                                // Close menu when clicking outside
                                document.addEventListener('click', (event) => {
                                        const target = event.target;
                                        if (target instanceof Node && !navbar.contains(target) && navbar.classList.contains('is-open')) {
                                                navbar.classList.remove('is-open');
                                                burgerMenu.classList.remove('is-open');
                                                burgerMenu.setAttribute('aria-expanded', 'false');
                                        }
                                });

                                const footerCookieSettings = document.getElementById('footer-cookie-settings');
                                footerCookieSettings?.addEventListener('click', () => {
                                        window.dispatchEvent(new CustomEvent('open-cookie-settings'));
                                });
                        });
                </script>
        </body>
</html>

<style is:global>
        *, *::before, *::after {
                box-sizing: border-box;
        }

        :root {
                --bg: #f4f7fb;
                --surface: #ffffff;
                --surface-soft: #f8fbff;
                --text: #0f172a;
                --muted: #4b5563;
                --line: #dbe5f1;
                --primary: #163b63;
                --primary-strong: #0f2e50;
                --shadow: 0 14px 34px rgba(16, 34, 62, 0.08);
                --radius: 18px;
        }

        html, body {
                margin: 0;
                padding: 0;
                height: 100%;
                font-family: 'Inter', sans-serif;
                background-color: var(--bg);
                color: var(--text);
                scroll-behavior: smooth;
        }

        .app-container {
                display: flex;
                flex-direction: column;
                min-height: 100vh;
        }

        .container {
                max-width: 1140px;
                margin: 0 auto;
                padding: 0 1.25rem;
        }

        .navbar {
                background: rgba(255, 255, 255, 0.92);
                backdrop-filter: blur(8px);
                border-bottom: 1px solid var(--line);
                position: sticky;
                top: 0;
                z-index: 50;
        }

        .nav-wrapper {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 1rem 0;
        }

        .logo {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                text-decoration: none;
                color: var(--text);
                font-weight: 700;
                font-size: 1.5rem;
        }

        .logo:hover .logo-img {
                transform: scale(1.03);
                transition: transform 0.2s ease;
        }

        .logo-img {
                height: 36px;
                width: auto;
        }

        .logo-light {
                display: block;
        }

        .logo-dark {
                display: none;
        }

        .dark .logo-light {
                display: none;
        }

        .dark .logo-dark {
                display: block;
        }

        .nav-links {
                display: flex;
                gap: 2rem;
        }

        .nav-links a {
                color: var(--muted);
                text-decoration: none;
                font-weight: 500;
                transition: color 0.2s;
                padding-bottom: 0.3rem;
                border-bottom: 2px solid transparent;
        }

        .nav-links a:hover {
                color: var(--primary);
        }

        .nav-links a[aria-current='page'] {
                color: var(--primary);
                border-bottom-color: var(--primary);
        }

        .lang-switch {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                margin-left: 0.5rem;
                padding-left: 0.25rem;
                border-left: 1px solid var(--line);
        }

        .lang-link {
                color: var(--muted);
                text-decoration: none;
                font-weight: 700;
                font-size: 0.85rem;
                letter-spacing: 0.04em;
        }

        .lang-link[aria-current='page'] {
                color: var(--primary);
        }

        .lang-divider {
                color: #94a3b8;
                font-size: 0.8rem;
        }

        .nav-controls {
                display: inline-flex;
                align-items: center;
                gap: 0.9rem;
        }

        .lang-switch-mobile {
                display: none;
                align-items: center;
                gap: 0.35rem;
        }

        /* Burger Menu Button */
        .burger-menu {
                display: none;
                flex-direction: column;
                background: none;
                border: none;
                cursor: pointer;
                padding: 0.5rem;
                gap: 0.4rem;
        }

        .burger-line {
                width: 24px;
                height: 3px;
                background-color: var(--text);
                border-radius: 2px;
                transition: all 0.3s ease;
        }

        .burger-menu.is-open .burger-line:nth-child(1) {
                transform: rotate(45deg) translate(8px, 8px);
        }

        .burger-menu.is-open .burger-line:nth-child(2) {
                opacity: 0;
        }

        .burger-menu.is-open .burger-line:nth-child(3) {
                transform: rotate(-45deg) translate(7px, -7px);
        }

        .main-content {
                flex: 1;
                padding: 2.5rem 0 3.5rem;
        }

        .footer {
                background: linear-gradient(180deg, #0f2741 0%, #0b1e35 100%);
                color: #d4dfeb;
                padding: 3rem 0 2rem;
        }

        .footer-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 2rem;
        }

        .footer-logo {
                display: block;
                margin-bottom: 1rem;
        }

        .footer-logo img {
                height: 40px;
                width: auto;
                opacity: 0.95;
        }

        .footer-logo span {
                font-weight: 600;
                color: #ffffff;
        }

        .footer h3 {
                color: #ffffff;
                font-size: 1.25rem;
                font-weight: 600;
                margin-bottom: 0.5rem;
        }

        .footer h4 {
                color: #ffffff;
                font-size: 1rem;
                font-weight: 600;
                margin-bottom: 1rem;
        }

        .footer p {
                color: #cbd5e1;
                line-height: 1.6;
                margin-bottom: 1rem;
        }

        .footer ul {
                list-style: none;
                padding: 0;
                margin: 0;
        }

        .footer li {
                margin-bottom: 0.5rem;
        }

        .footer a {
                color: #cbd5e1;
                text-decoration: none;
                transition: color 0.2s ease;
        }

        .footer-cookie-button {
                background: transparent;
                border: none;
                padding: 0;
                color: #cbd5e1;
                font: inherit;
                cursor: pointer;
                text-align: left;
        }

        .footer a:hover {
                color: #ffffff;
        }

        .footer-cookie-button:hover {
                color: #ffffff;
        }

        .footer-bottom {
                margin-top: 2rem;
                padding-top: 1rem;
                border-top: 1px solid rgba(255,255,255,0.1);
                text-align: center;
                font-size: 0.9rem;
        }

        .footer-bottom p {
                color: #cbd5e1;
                margin: 0;
        }

        @media (max-width: 768px) {
                .nav-wrapper {
                        flex-direction: row;
                        justify-content: space-between;
                        align-items: center;
                        padding: 1rem 0;
                }

                .burger-menu {
                        display: flex;
                }

                .nav-links {
                        position: absolute;
                        top: 100%;
                        left: 0;
                        right: 0;
                        background: white;
                        flex-direction: column;
                        padding: 1rem;
                        gap: 0;
                        border-bottom: 1px solid #e5e7eb;
                        max-height: 0;
                        overflow: hidden;
                        transition: max-height 0.3s ease;
                }

                .navbar.is-open .nav-links {
                        max-height: 500px;
                }

                .nav-links a {
                        padding: 0.75rem 1rem;
                        border-bottom: 1px solid #f3f4f6;
                        transition: background-color 0.2s ease, color 0.2s ease;
                }

                .nav-links a:last-child {
                        border-bottom: none;
                }

                .lang-switch {
                        display: none;
                }

                .lang-switch-mobile {
                        display: inline-flex;
                }

                .nav-links a:hover {
                        background-color: #f9fafb;
                }

                .navbar {
                        position: relative;
                }

                .footer-grid {
                        grid-template-columns: 1fr 1fr;
                        column-gap: 1.25rem;
                        row-gap: 1.75rem;
                }

                .footer-about {
                        grid-column: 1 / -1;
                }

                .footer-nav {
                        display: none;
                }

                .footer-contact {
                        grid-column: 1;
                        grid-row: 2;
                }

                .footer-legal {
                        grid-column: 2;
                        grid-row: 2;
                        margin-top: 0;
                }
        }

        @media (max-width: 640px) {
                .logo img.logo-main {
                        display: none;
                }

                .logo img.logo-icon {
                        display: block;
                }
        }

        @media (max-width: 600px) {
                .footer {
                        padding: 2.5rem 0 1.5rem;
                }

                .footer-grid {
                        column-gap: 1rem;
                        row-gap: 1.35rem;
                }

                .card h3,
                .feature-card h3 {
                        font-size: 1.1rem;
                }
        }

        /* Global Card Styles */
        .card-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
                gap: 1.5rem;
        }

        .card,
        .feature-card {
                background: var(--surface);
                border: 1px solid var(--line);
                border-radius: var(--radius);
                padding: 1.75rem;
                box-shadow: var(--shadow);
                transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .card:hover,
        .feature-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 18px 45px rgba(15, 42, 69, 0.13);
        }

        .card-icon {
                width: 56px;
                height: 56px;
                border-radius: 16px;
                background: linear-gradient(135deg, #e8f1ff, #f1f6ff);
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--primary);
                margin-bottom: 1rem;
                border: 1px solid #d8e5f8;
        }

        .card-icon svg {
                width: 24px;
                height: 24px;
                stroke: currentColor;
                fill: none;
                stroke-width: 1.8;
                stroke-linecap: round;
                stroke-linejoin: round;
        }

        .card h3,
        .feature-card h3 {
                margin: 0 0 0.75rem;
                font-size: 1.25rem;
                color: var(--text);
                line-height: 1.3;
                overflow-wrap: anywhere;
                hyphens: auto;
        }

        .card p,
        .feature-card p {
                margin: 0;
                color: var(--muted);
                line-height: 1.65;
        }

        .card-link {
                display: inline-flex;
                margin-top: 1.25rem;
                color: #163b63;
                font-weight: 700;
                text-decoration: none;
        }

        .card-link:hover {
                text-decoration: underline;
        }

        @media (max-width: 768px) {
                html,
                body {
                        background-color: #ffffff;
                }

                .main-content {
                        padding: 1.5rem 0 2.25rem;
                }

                .card,
                .feature-card,
                .project-card,
                .contact-form-card,
                .contact-info,
                .project-logic li,
                .steps .card {
                        background: transparent !important;
                        border: none !important;
                        box-shadow: none !important;
                        border-radius: 0 !important;
                        padding: 0 !important;
                }

                .card-grid,
                .grid {
                        gap: 1rem;
                }

                .card-icon {
                        width: 36px;
                        height: 36px;
                        border-radius: 0;
                        background: transparent;
                        border: none;
                        margin-bottom: 0.65rem;
                }

                .card-icon svg {
                        width: 20px;
                        height: 20px;
                }

                .card-icon {
                        display: none;
                }
        }

        @media (max-width: 600px) {
                .card h3,
                .feature-card h3 {
                        font-size: 1.1rem;
                }
        }
</style>