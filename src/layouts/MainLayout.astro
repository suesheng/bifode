---
// src/layouts/MainLayout.astro
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import CookieBanner from '../components/CookieBanner.astro';
import FloatingCta from '../components/FloatingCta.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { buildBreadcrumbs, type BreadcrumbCrumb } from '../lib/breadcrumbs';
import { FB_PAGE_BIFODE, ULPAN_LANDING_PATH } from '../lib/communityLinks';
const {
  title = 'Startseite',
  description = 'BiFoDe e.V. entwickelt Bildungs- und Präventionsformate für Schulen und Partner in NRW',
  lang = 'de',
  titleSuffix = true,
  mainClass = '',
  breadcrumbs: breadcrumbsOverride
} = Astro.props;

const isEn = lang === 'en';
const locale = isEn ? 'en' : 'de';
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const breadcrumbItems =
  breadcrumbsOverride ?? buildBreadcrumbs(currentPath, locale, title);

type NavHref = { href: string; label: string };
type NavGroup = { kind: 'group'; label: string; items: NavHref[] };
type NavLink = { kind: 'link'; href: string; label: string; external?: boolean };
type NavEntry = NavLink | NavGroup;

const navStructure: NavEntry[] = isEn
  ? [
      { kind: 'link', href: '/en', label: 'Home' },
      {
        kind: 'group',
        label: 'Who we are',
        items: [
          { href: '/en/about', label: 'About' },
          { href: '/en/our-work', label: 'Our Work' },
          { href: '/en/cooperation', label: 'Cooperation' }
        ]
      },
      {
        kind: 'group',
        label: 'What we offer',
        items: [
          { href: '/en/schools', label: 'Schools' },
          { href: '/en/projects', label: 'Projects' }
        ]
      },
      { kind: 'link', href: '/en/contact', label: 'Contact' }
    ]
  : [
      { kind: 'link', href: '/', label: 'Startseite' },
      {
        kind: 'group',
        label: 'Wer wir sind',
        items: [
          { href: '/ueber-uns', label: 'Über uns' },
          { href: '/unsere-arbeit', label: 'Unsere Arbeit' },
          { href: '/kooperation', label: 'Kooperation' }
        ]
      },
      {
        kind: 'group',
        label: 'Was wir anbieten',
        items: [
          { href: '/fuer-schulen', label: 'Schulen' },
          { href: '/projekte', label: 'Projekte' }
        ]
      },
      { kind: 'link', href: '/kontakt', label: 'Kontakt' }
    ];

function flattenNav(entries: NavEntry[]): NavHref[] {
  const out: NavHref[] = [];
  for (const e of entries) {
    if (e.kind === 'link') out.push({ href: e.href, label: e.label });
    else for (const i of e.items) out.push(i);
  }
  return out;
}

const footerNavLinks = flattenNav(navStructure);

const pathMap: Record<string, string> = {
  '/': '/en',
  '/ueber-uns': '/en/about',
  '/unsere-arbeit': '/en/our-work',
  '/fuer-schulen': '/en/schools',
  '/schulen': '/en/schools',
  '/projekte': '/en/projects',
  '/kooperation': '/en/cooperation',
  '/kontakt': '/en/contact',
  '/spenden': '/en/donate',
  '/beitrittserklaerung': '/en/membership-declaration',
  '/impressum': '/en/legal-notice',
  '/datenschutz': '/en/privacy',
  '/cookie-richtlinien': '/en/cookie-policy',
  '/en': '/',
  '/en/about': '/ueber-uns',
  '/en/our-work': '/unsere-arbeit',
  '/en/schools': '/fuer-schulen',
  '/en/projects': '/projekte',
  '/en/cooperation': '/kooperation',
  '/en/contact': '/kontakt',
  '/en/donate': '/spenden',
  '/en/membership-declaration': '/beitrittserklaerung',
  '/en/legal-notice': '/impressum',
  '/en/privacy': '/datenschutz',
  '/en/cookie-policy': '/cookie-richtlinien'
};

const counterpartPath = pathMap[currentPath] || (isEn ? '/kontakt' : '/en/contact');
const langDeHref = isEn ? counterpartPath : currentPath;
const langEnHref = isEn ? currentPath : counterpartPath;

const siteYear = new Date().getFullYear();
const canonicalURL = new URL(Astro.url.pathname, 'https://www.bifode.org');
const orgJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'BiFoDe e.V.',
  alternateName: 'Bildungsforum für Demokratie und Vielfalt NRW e.V.',
  url: 'https://www.bifode.org/',
  logo: 'https://www.bifode.org/logos/logo-light.svg',
  email: 'info@bifode.org',
});
---

<!doctype html>
<html lang={isEn ? 'en' : 'de'}>
        <head>
                <meta charset="UTF-8" />
                <meta name="viewport" content="width=device-width" />
                <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
                <link rel="icon" href="/favicon.ico" />
                <link rel="apple-touch-icon" href="/favicon.svg" />
                <meta name="generator" content={Astro.generator} />
                <title>{titleSuffix ? `${title} | BiFoDe` : title}</title>
                <meta name="description" content={description} />
                <link rel="canonical" href={canonicalURL} />
                <script type="application/ld+json" set:html={orgJsonLd} />

                <!-- Critical CSS - Inline for faster initial render (above-the-fold) -->
                <style>
                        *, *::before, *::after { box-sizing: border-box; }
                        html, body { margin: 0; padding: 0; height: 100%; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background-color: #f9fafb; color: #111827; scroll-behavior: smooth; }
                        .app-container { display: flex; flex-direction: column; min-height: 100vh; }
                        .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }
                        .navbar { background: white; border-bottom: 1px solid #e5e7eb; position: sticky; top: 0; z-index: 50; }
                        .nav-wrapper { display: flex; justify-content: space-between; align-items: center; padding: 1rem 16px; }
                        .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: #111827; font-weight: 700; font-size: 1.5rem; }
                        .logo-img { height: 36px; width: auto; }
                        .logo-light { display: block; }
                        .logo-dark { display: none; }
                        .nav-links { display: flex; gap: 1.15rem; }
                        .nav-links a { color: #6b7280; text-decoration: none; font-weight: 500; }
                        .burger-menu { display: none; flex-direction: column; background: none; border: none; cursor: pointer; padding: 0.5rem; gap: 0.4rem; }
                        .burger-line { width: 24px; height: 3px; background-color: #111827; border-radius: 2px; transition: all 0.3s ease; }
                        .main-content { flex: 1; padding: 2rem 0; }
                        @media (max-width: 768px) {
                                .burger-menu { display: flex; }
                                .nav-links { position: absolute; top: 100%; left: 0; right: 0; background: white; flex-direction: column; padding: 1rem; gap: 0; border-bottom: 1px solid #e5e7eb; max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
                                .navbar.is-open .nav-links { max-height: 920px; }
                                .nav-links a { padding: 0.75rem 1rem; border-bottom: 1px solid #f3f4f6; }
                        }
                </style>
        </head>
        <body>
                <a href="#main-content" class="skip-link">{isEn ? 'Skip to main content' : 'Zum Inhalt springen'}</a>
                <div class="app-container">
                        <nav class="navbar" id="navbar">
                                <div class="container nav-wrapper">
                                        <a href={isEn ? '/en' : '/'} class="logo">
                                                <img src="/logos/logo-light.svg" alt="BiFoDe Logo" class="logo-img logo-light" width="1896" height="484" />
                                        </a>
                                        <div class="nav-links" id="navLinks">
                                                {navStructure.map((entry) =>
                                                  entry.kind === 'link' ? (
                                                    <a
                                                      href={entry.href}
                                                      class="nav-top-link"
                                                      data-nav-link
                                                      {...(entry.external
                                                        ? { target: '_blank', rel: 'noopener noreferrer' }
                                                        : {})}
                                                    >
                                                      {entry.label}
                                                    </a>
                                                  ) : (
                                                    <details class="nav-drop">
                                                      <summary class="nav-drop-summary">
                                                        <span>{entry.label}</span>
                                                        <span class="nav-drop-chevron" aria-hidden="true" />
                                                      </summary>
                                                      <div class="nav-drop-panel">
                                                        {entry.items.map((item) => (
                                                          <a href={item.href} data-nav-link>
                                                            {item.label}
                                                          </a>
                                                        ))}
                                                      </div>
                                                    </details>
                                                  )
                                                )}
                                                <div class="lang-switch" id="langSwitch">
                                                        <a href={langDeHref} id="langDe" class="lang-link">DE</a>
                                                        <span class="lang-divider">|</span>
                                                        <a href={langEnHref} id="langEn" class="lang-link">EN</a>
                                                </div>
                                        </div>
                                        <div class="nav-controls">
                                                <div class="lang-switch-mobile">
                                                        <a href={langDeHref} class="lang-link" aria-current={isEn ? undefined : 'page'}>DE</a>
                                                        <span class="lang-divider">|</span>
                                                        <a href={langEnHref} class="lang-link" aria-current={isEn ? 'page' : undefined}>EN</a>
                                                </div>
                                                <button class="burger-menu" id="burgerMenu" aria-label="Navigation menu" aria-expanded="false">
                                                        <span class="burger-line"></span>
                                                        <span class="burger-line"></span>
                                                        <span class="burger-line"></span>
                                                </button>
                                        </div>
                                </div>
                        </nav>

                        <main id="main-content" class:list={['main-content', mainClass]} tabindex="-1">
                                <Breadcrumbs items={breadcrumbItems} lang={locale} />
                                <slot />
                        </main>

                        <footer class="footer">
                                <div class="container footer-grid">
                                        <div class="footer-section footer-about">
                                                <div class="footer-logo">
                                                        <img src="/logos/logo-dark.svg" alt="BiFoDe Logo" width="1866" height="666" loading="lazy" />
                                                </div>
                                                <p>{isEn ? 'BiFoDe NRW. We strengthen democratic education and are clearly committed to combating antisemitism.' : 'Bildungsforum für Demokratie und Vielfalt NRW. Wir stärken demokratische Bildung und engagieren uns klar gegen Antisemitismus.'}</p>
                                        </div>

                                        <div class="footer-section footer-nav">
                                                <h4>{isEn ? 'Navigation' : 'Navigation'}</h4>
                                                <ul>
                                                        {footerNavLinks.map((item) => (
                                                                <li><a href={item.href}>{item.label}</a></li>
                                                        ))}
                                                </ul>
                                        </div>

                                        <div class="footer-section footer-contact">
                                                <h4>{isEn ? 'Contact' : 'Kontakt'}</h4>
                                                <p>E-Mail: info@bifode.org</p>
                                                <p>{isEn ? 'Location: North Rhine-Westphalia' : 'Standort: Nordrhein-Westfalen'}</p>
                                        </div>

                                        <div class="footer-section footer-community">
                                                <h4>{isEn ? 'Follow us' : 'Community'}</h4>
                                                <ul>
                                                        <li>
                                                                <a href={FB_PAGE_BIFODE} target="_blank" rel="noopener noreferrer">
                                                                        {isEn ? 'Facebook page' : 'Facebook-Seite BiFoDe'}
                                                                </a>
                                                        </li>
                                                        <li>
                                                                <a href={isEn ? '/en/ulpan' : ULPAN_LANDING_PATH}>
                                                                        Ulpan Next
                                                                </a>
                                                        </li>
                                                        {!isEn && <li><span class="footer-todo">Telegram-Kanal (Link folgt)</span></li>}
                                                </ul>
                                        </div>

                                        <div class="footer-section footer-legal">
                                                <h4>{isEn ? 'Legal' : 'Rechtliches'}</h4>
                                                <ul>
                                                        <li><a href={isEn ? '/en/legal-notice' : '/impressum'}>{isEn ? 'Legal Notice' : 'Impressum'}</a></li>
                                                        <li><a href={isEn ? '/en/privacy' : '/datenschutz'}>{isEn ? 'Privacy Policy' : 'Datenschutz'}</a></li>
                                                        <li><button type="button" class="footer-cookie-button" id="footer-cookie-settings">{isEn ? 'Cookie Settings' : 'Cookie-Einstellungen'}</button></li>
                                                </ul>
                                        </div>
                                </div>

                                {!isEn && (
                                        <div class="container footer-legal-note">
                                                <p>
                                                        <span class="footer-legal-label">Hinweis</span>
                                                        <span class="footer-legal-text">
                                                          Unsere Angebote dienen der Bildung, Orientierung und allgemeinen Information.
                                                          Sie ersetzen keine individuelle Rechts-, Steuer- oder Einwanderungsberatung. Bei Bedarf verweisen wir auf zuständige Stellen oder qualifizierte Fachpersonen.
                                                        </span>
                                                </p>
                                        </div>
                                )}

                                <div class="footer-bottom">
                                        <div class="container">
                                                <p>&copy; {siteYear} BiFoDe e.V. {isEn ? 'All rights reserved.' : 'Alle Rechte vorbehalten.'}</p>
                                        </div>
                                </div>
                        </footer>
                </div>

                <!-- Cookie Banner -->
                <CookieBanner />

                <FloatingCta lang={isEn ? 'en' : 'de'} />

                <script>
                        document.addEventListener('DOMContentLoaded', () => {
                                const burgerMenu = document.getElementById('burgerMenu');
                                const navbar = document.getElementById('navbar');
                                const navLinks = document.getElementById('navLinks');
                                if (!burgerMenu || !navbar || !navLinks) return;

                                const navItems = navLinks.querySelectorAll('[data-nav-link]');
                                const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
                                const langDe = document.getElementById('langDe');
                                const langEn = document.getElementById('langEn');

                                navItems.forEach(item => {
                                        const linkPath = (item.getAttribute('href') || '').replace(/\/$/, '') || '/';
                                        if (linkPath === currentPath) {
                                                item.setAttribute('aria-current', 'page');
                                        }
                                });

                                navLinks.querySelectorAll('details.nav-drop').forEach(details => {
                                        const sub = details.querySelectorAll('.nav-drop-panel a[data-nav-link]');
                                        let match = false;
                                        sub.forEach(a => {
                                                const p = (a.getAttribute('href') || '').replace(/\/$/, '') || '/';
                                                if (p === currentPath) match = true;
                                        });
                                        if (match) details.classList.add('nav-drop--current');
                                });

                                if (langDe && langEn) {
                                        if (currentPath.startsWith('/en')) {
                                                langEn.setAttribute('aria-current', 'page');
                                        } else {
                                                langDe.setAttribute('aria-current', 'page');
                                        }
                                }

                                // Toggle menu on burger click
                                burgerMenu.addEventListener('click', () => {
                                        navbar.classList.toggle('is-open');
                                        burgerMenu.classList.toggle('is-open');
                                        burgerMenu.setAttribute('aria-expanded', burgerMenu.classList.contains('is-open') ? 'true' : 'false');
                                });

                                // Close menu when a link is clicked; collapse dropdowns
                                const closeMobileNav = () => {
                                        navLinks.querySelectorAll('details.nav-drop').forEach(d => d.removeAttribute('open'));
                                        navbar.classList.remove('is-open');
                                        burgerMenu.classList.remove('is-open');
                                        burgerMenu.setAttribute('aria-expanded', 'false');
                                };

                                navItems.forEach(item => {
                                        item.addEventListener('click', closeMobileNav);
                                });

				const closeDropdowns = () => {
					navLinks.querySelectorAll('details.nav-drop[open]').forEach(d => d.removeAttribute('open'));
				};

				// Close menu/dropdowns when clicking outside
				document.addEventListener('click', (event) => {
					const target = event.target;
					if (!(target instanceof Node)) return;
					if (!navbar.contains(target)) {
						closeDropdowns();
						if (navbar.classList.contains('is-open')) {
							navbar.classList.remove('is-open');
							burgerMenu.classList.remove('is-open');
							burgerMenu.setAttribute('aria-expanded', 'false');
						}
					}
				});

				// Only one desktop dropdown open at a time
				navLinks.querySelectorAll('details.nav-drop').forEach(details => {
					details.addEventListener('toggle', () => {
						if (!details.open) return;
						navLinks.querySelectorAll('details.nav-drop[open]').forEach(other => {
							if (other !== details) other.removeAttribute('open');
						});
					});
				});

				// Escape closes dropdowns and mobile menu
				document.addEventListener('keydown', (event) => {
					if (event.key !== 'Escape') return;
					closeDropdowns();
					if (navbar.classList.contains('is-open')) {
						navbar.classList.remove('is-open');
						burgerMenu.classList.remove('is-open');
						burgerMenu.setAttribute('aria-expanded', 'false');
						burgerMenu.focus();
					}
				});

                                const footerCookieSettings = document.getElementById('footer-cookie-settings');
                                footerCookieSettings?.addEventListener('click', () => {
                                        window.dispatchEvent(new CustomEvent('open-cookie-settings'));
                                });
                        });
                </script>
        </body>
</html>

<style is:global>
        *, *::before, *::after {
                box-sizing: border-box;
        }

	:root {
		--bg: #f4f7fb;
		--surface: #ffffff;
		--surface-soft: #f8fbff;
		--text: #0f172a;
		--muted: #4b5563;
		--line: #dbe5f1;

		/* Brand: navy = primary, royal blue = interactive accent */
		--primary: #163b63;
		--primary-strong: #0f2e50;
		--accent: #1d4ed8;
		--accent-strong: #1e40af;
		--accent-tint: rgba(29, 78, 216, 0.12);

		/* Filled CTA */
		--cta-grad: linear-gradient(135deg, #1d4ed8 0%, #163b63 100%);
		--cta-grad-hover: linear-gradient(135deg, #1e40af 0%, #0f2e50 100%);
		--cta-shadow: 0 10px 24px rgba(29, 78, 216, 0.3);
		--cta-shadow-hover: 0 14px 30px rgba(29, 78, 216, 0.34);

		--shadow: 0 14px 34px rgba(16, 34, 62, 0.08);
		--shadow-card-hover: 0 18px 45px rgba(15, 42, 69, 0.13);

		--radius-sm: 10px;
		--radius-md: 14px;
		--radius-lg: 18px;
		--radius: 18px;
	}

        html, body {
                margin: 0;
                padding: 0;
                height: 100%;
                font-family: 'Inter', sans-serif;
                background-color: var(--bg);
                color: var(--text);
                scroll-behavior: smooth;
        }

        .skip-link {
                position: absolute;
                left: 0;
                top: 0;
                z-index: 200;
                padding: 0.65rem 1.1rem;
                background: var(--primary);
                color: #fff !important;
                font-weight: 600;
                font-size: 0.9rem;
                text-decoration: none;
                border-radius: 0 0 10px 0;
                transform: translateY(-120%);
                transition: transform 0.2s ease;
        }

        .skip-link:focus {
                outline: none;
                transform: translateY(0);
        }

        .skip-link:focus-visible {
                outline: 2px solid #fff;
                outline-offset: 2px;
        }

        .app-container {
                display: flex;
                flex-direction: column;
                min-height: 100vh;
        }

        .container {
                max-width: 1140px;
                margin: 0 auto;
                padding: 0 1.25rem;
        }

        .navbar {
                background: rgba(255, 255, 255, 0.92);
                backdrop-filter: blur(8px);
                border-bottom: 1px solid var(--line);
                position: sticky;
                top: 0;
                z-index: 50;
        }

        .nav-wrapper {
                display: flex;
                align-items: center;
                gap: 0.75rem 1rem;
                padding: 1rem 0;
        }

        .logo {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                text-decoration: none;
                color: var(--text);
                font-weight: 700;
                font-size: 1.5rem;
        }

        .logo:hover .logo-img {
                transform: scale(1.03);
                transition: transform 0.2s ease;
        }

        .logo-img {
                height: 36px;
                width: auto;
        }

        .logo-light {
                display: block;
        }

        .logo-dark {
                display: none;
        }

        .dark .logo-light {
                display: none;
        }

        .dark .logo-dark {
                display: block;
        }

        .nav-links {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                justify-content: flex-end;
                gap: 0.35rem 1.15rem;
                flex: 1;
                min-width: 0;
        }

        .nav-links .nav-top-link,
        .nav-links .nav-drop-panel a {
                color: var(--muted);
                text-decoration: none;
                font-weight: 500;
                transition: color 0.2s, border-color 0.2s, background-color 0.2s;
                padding-bottom: 0.3rem;
                border-bottom: 2px solid transparent;
                white-space: nowrap;
        }

        .nav-links .nav-top-link:hover,
        .nav-links .nav-drop-panel a:hover {
                color: var(--primary);
        }

        .nav-links .nav-top-link[aria-current='page'],
        .nav-links .nav-drop-panel a[aria-current='page'] {
                color: var(--primary);
                border-bottom-color: var(--primary);
        }

        .nav-drop {
                position: relative;
        }

        .nav-drop-summary {
                list-style: none;
                cursor: pointer;
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                color: var(--muted);
                font-weight: 500;
                font-size: inherit;
                font-family: inherit;
                padding: 0 0 0.3rem;
                margin: 0;
                border: 0;
                border-bottom: 2px solid transparent;
                background: transparent;
                user-select: none;
                white-space: nowrap;
                transition: color 0.2s, border-color 0.2s;
        }

        .nav-drop-summary::-webkit-details-marker {
                display: none;
        }

        .nav-drop-summary::marker {
                content: '';
        }

        .nav-drop-summary:hover,
        .nav-drop-summary:focus-visible {
                color: var(--primary);
                outline: none;
        }

        .nav-drop[open] > .nav-drop-summary,
        .nav-drop.nav-drop--current > .nav-drop-summary {
                color: var(--primary);
                border-bottom-color: var(--primary);
        }

        .nav-drop-chevron {
                display: inline-block;
                width: 0;
                height: 0;
                border-left: 4px solid transparent;
                border-right: 4px solid transparent;
                border-top: 5px solid currentColor;
                margin-top: 2px;
                transition: transform 0.2s ease;
        }

        .nav-drop[open] .nav-drop-chevron {
                transform: rotate(180deg);
        }

        .nav-drop-panel {
                position: absolute;
                top: calc(100% + 0.35rem);
                left: 0;
                min-width: 12.5rem;
                padding: 0.4rem 0;
                margin: 0;
                background: var(--surface);
                border: 1px solid var(--line);
                border-radius: 14px;
                box-shadow: var(--shadow);
                z-index: 80;
                display: flex;
                flex-direction: column;
                gap: 0.1rem;
        }

        .nav-drop-panel a {
                display: block;
                padding: 0.5rem 1rem;
                margin: 0 0.35rem;
                border-radius: 8px;
                border-bottom: none;
        }

        .nav-drop-panel a:hover {
                background: var(--surface-soft);
        }

        .nav-drop-summary:focus-visible,
        .nav-top-link:focus-visible,
        .nav-drop-panel a:focus-visible,
        .lang-link:focus-visible,
        .burger-menu:focus-visible {
                outline: 2px solid var(--primary);
                outline-offset: 2px;
        }

        .lang-switch {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                margin-left: 0.5rem;
                padding-left: 0.25rem;
