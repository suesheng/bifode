---
// src/components/Hero.astro
const { title, subtitle, centered = true, tertiary } = Astro.props;
const lang = Astro.props.lang === 'en' ? 'en' : 'de';
const isEn = lang === 'en';
---

<section class={`hero ${centered ? 'hero-centered' : 'hero-page'}`}>
  <div class="hero-bg"></div>

  <div class="container hero-content">
    <h1>{title}</h1>
    <p class="hero-subtitle">{subtitle}</p>

    {centered && (
      <>
        <div class="hero-actions">
          <a href={isEn ? '/en/schools' : '/schulen'} class="button">{isEn ? 'Programs for Schools' : 'Angebote für Schulen'}</a>
          <a href={isEn ? '/en/cooperation' : '/kooperation'} class="button secondary">{isEn ? 'Request Cooperation' : 'Kooperation anfragen'}</a>
        </div>

        {tertiary && (
          <p class="hero-tertiary">
            <a href={tertiary.href} class="hero-tertiary-link">{tertiary.label}</a>
          </p>
        )}

        <p class="hero-trust">
          {isEn ? 'Working with schools, partners, and civil society organizations in NRW' : 'Arbeit mit Schulen, Partnern und zivilgesellschaftlichen Organisationen in NRW'}
        </p>
      </>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(165deg, #e8f1ff 0%, #f3f8ff 42%, #ffffff 100%);
  }

  .hero-centered {
    text-align: center;
    padding: 100px 0 80px;
  }

  .hero-page {
    text-align: left;
    padding: 60px 0 40px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(circle at 15% 20%, rgba(37,99,235,0.34), transparent 44%),
      radial-gradient(circle at 85% 15%, rgba(14,116,144,0.26), transparent 42%),
      radial-gradient(circle at 60% 85%, rgba(79,70,229,0.2), transparent 48%);
    filter: blur(36px);
  }

  .hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.28) 0%, rgba(255,255,255,0.62) 100%),
      linear-gradient(rgba(22,59,99,0.06) 1px, transparent 1px);
    background-size: auto, 40px 40px;
    opacity: 0.85;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-centered .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-page .hero-content {
    max-width: 700px;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    color: #0b1e35;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 14px rgba(37, 99, 235, 0.15);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #1f3148;
    margin-bottom: 2rem;
    line-height: 1.6;
    max-width: 64ch;
    font-weight: 500;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #1d4ed8 0%, #163b63 100%);
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    border-radius: 0.7rem;
    box-shadow: 0 10px 24px rgba(29, 78, 216, 0.3);
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .button:hover {
    background: linear-gradient(135deg, #1e40af 0%, #0f2e50 100%);
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(29, 78, 216, 0.34);
  }

  .button.secondary {
    background: rgba(255, 255, 255, 0.82);
    color: #12365e;
    border: 1px solid #89a6cc;
    box-shadow: 0 8px 20px rgba(15, 46, 80, 0.1);
  }

  .button.secondary:hover {
    background: #163b63;
    color: #ffffff;
    box-shadow: 0 14px 30px rgba(15, 46, 80, 0.25);
  }

  .hero-tertiary {
    margin: 0 0 1rem;
    font-size: 0.95rem;
  }

  .hero-tertiary-link {
    color: #163b63;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(22, 59, 99, 0.35);
  }

  .hero-tertiary-link:hover {
    color: #0f2e50;
    border-bottom-color: #0f2e50;
  }

  .hero-trust {
    font-size: 0.9rem;
    color: #334155;
    margin: 0;
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .hero-centered {
      padding: 60px 0 50px;
    }

    .hero-page {
      padding: 40px 0 30px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .button {
      width: 100%;
      max-width: 300px;
    }
  }
</style>