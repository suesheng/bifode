---
// src/components/Hero.astro
const { title, subtitle, centered = true } = Astro.props;
---

<section class={`hero ${centered ? 'hero-centered' : 'hero-page'}`}>
  <div class="hero-bg"></div>

  <div class="container hero-content">
    <h1>{title}</h1>
    <p class="hero-subtitle">{subtitle}</p>

    {centered && (
      <>
        <div class="hero-actions">
          <a href="/schulen" class="button">Angebote für Schulen</a>
          <a href="/kooperation" class="button secondary">Kooperation anfragen</a>
        </div>

        <p class="hero-trust">
          Arbeit mit Schulen, Partnern und zivilgesellschaftlichen Organisationen in NRW
        </p>
      </>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(to bottom, #f8fafc, #ffffff);
  }

  .hero-centered {
    text-align: center;
    padding: 100px 0 80px;
  }

  .hero-page {
    text-align: left;
    padding: 60px 0 40px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(circle at 20% 20%, rgba(59,130,246,0.18), transparent 40%),
      radial-gradient(circle at 80% 30%, rgba(22,59,99,0.12), transparent 45%),
      radial-gradient(circle at 50% 80%, rgba(99,102,241,0.10), transparent 50%);
    filter: blur(40px);
  }

  .hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(0,0,0,0.02) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.4;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-centered .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-page .hero-content {
    max-width: 700px;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #475569;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: #3b82f6;
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    border-radius: 0.375rem;
    transition: background-color 0.2s ease;
  }

  .button:hover {
    background: #2563eb;
  }

  .button.secondary {
    background: transparent;
    color: #3b82f6;
    border: 1px solid #3b82f6;
  }

  .button.secondary:hover {
    background: #3b82f6;
    color: #ffffff;
  }

  .hero-trust {
    font-size: 0.9rem;
    color: #9ca3af;
    margin: 0;
  }

  @media (max-width: 600px) {
    .hero-centered {
      padding: 60px 0 50px;
    }

    .hero-page {
      padding: 40px 0 30px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .button {
      width: 100%;
      max-width: 300px;
    }
  }
</style>