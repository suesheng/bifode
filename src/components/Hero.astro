---
// src/components/Hero.astro
import { getImage } from 'astro:assets';
import heroBgSource from '../assets/hero-bg.webp';

type TertiaryLink = { href: string; label: string; external?: boolean };

const { title, subtitle, centered = true, tertiary, tertiaryLinks } = Astro.props;
const lang = Astro.props.lang === 'en' ? 'en' : 'de';
const isEn = lang === 'en';

const resolvedTertiaryLinks: TertiaryLink[] =
  tertiaryLinks ?? (tertiary ? [tertiary] : []);

const heroBg = await getImage({
  src: heroBgSource,
  width: 1536,
  format: 'webp',
  quality: 80,
});
---

<section class={`hero ${centered ? 'hero-centered' : 'hero-page'}`}>
  <div
    class="hero-bg"
    aria-hidden="true"
    style={`background-image: url(${heroBg.src})`}
  ></div>

  <div class="container hero-content">
    <h1>{title}</h1>
    <p class="hero-subtitle">{subtitle}</p>

    {centered && (
      <>
        <div class="hero-actions">
          <a href={isEn ? '/en/schools' : '/fuer-schulen'} class="button">{isEn ? 'Programmes for Schools' : 'Angebote für Schulen'}</a>
          <a href={isEn ? '/en/cooperation' : '/kooperation'} class="button secondary">{isEn ? 'Request a partnership' : 'Kooperation anfragen'}</a>
        </div>

        {resolvedTertiaryLinks.length > 0 && (
          <p class="hero-tertiary">
            {resolvedTertiaryLinks.map((link, index) => (
              <>
                {index > 0 && <span class="hero-tertiary-sep" aria-hidden="true"> · </span>}
                <a
                  href={link.href}
                  class="hero-tertiary-link"
                  {...(link.external
                    ? { target: '_blank', rel: 'noopener noreferrer' }
                    : {})}
                >
                  {link.label}
                </a>
              </>
            ))}
          </p>
        )}

        <p class="hero-trust">
          {isEn ? 'Working with schools, partners, and civil society organisations in NRW' : 'Arbeit mit Schulen, Partnern und zivilgesellschaftlichen Organisationen in NRW'}
        </p>
      </>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: #f3f8ff;
  }

  .hero-centered {
    text-align: center;
    padding: 100px 0 80px;
  }

  .hero-page {
    text-align: left;
    padding: 60px 0 40px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-centered .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-page .hero-content {
    max-width: 700px;
  }

  .hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #0b1e35;
    margin-bottom: 1.5rem;
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #1f3148;
    margin-bottom: 2rem;
    line-height: 1.6;
    max-width: 64ch;
    font-weight: 500;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--cta-grad);
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    border-radius: var(--radius-sm);
    box-shadow: var(--cta-shadow);
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .button:hover {
    background: var(--cta-grad-hover);
    transform: translateY(-2px);
    box-shadow: var(--cta-shadow-hover);
  }

  .button.secondary {
    background: rgba(255, 255, 255, 0.82);
    color: #12365e;
    border: 1px solid #89a6cc;
    box-shadow: 0 8px 20px rgba(15, 46, 80, 0.1);
  }

  .button.secondary:hover {
    background: var(--primary);
    color: #ffffff;
    box-shadow: 0 14px 30px rgba(15, 46, 80, 0.25);
  }

  .hero-tertiary {
    margin: 0 0 1rem;
    font-size: 0.95rem;
  }

  .hero-tertiary-link {
    color: #163b63;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(22, 59, 99, 0.35);
  }

  .hero-tertiary-link:hover {
    color: #0f2e50;
    border-bottom-color: #0f2e50;
  }

  .hero-tertiary-sep {
    color: #64748b;
    font-weight: 400;
  }

  .hero-trust {
    font-size: 0.9rem;
    color: #334155;
    margin: 0;
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .hero-centered {
      padding: 60px 0 50px;
    }

    .hero-page {
      padding: 40px 0 30px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .button {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
