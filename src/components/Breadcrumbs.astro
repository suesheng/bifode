---
import type { BreadcrumbCrumb } from '../lib/breadcrumbs';

const { items, lang = 'de' } = Astro.props as {
  items: BreadcrumbCrumb[];
  lang?: 'de' | 'en';
};

const siteOrigin = 'https://www.bifode.org';
const show = items.length > 0;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((crumb, index) => {
    const item: Record<string, unknown> = {
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.label,
    };
    if (crumb.href) {
      item.item = new URL(crumb.href, siteOrigin).href;
    }
    return item;
  }),
};
---

{show && (
  <>
    <nav class="breadcrumbs" aria-label={lang === 'en' ? 'Breadcrumb' : 'Brotkrumen'}>
      <div class="container breadcrumbs-inner">
        <ol class="breadcrumbs-list">
          {items.map((crumb, index) => {
            const isLast = index === items.length - 1;
            return (
              <li class="breadcrumbs-item">
                {crumb.href && !isLast ? (
                  <a href={crumb.href}>{crumb.label}</a>
                ) : (
                  <span aria-current={isLast ? 'page' : undefined}>{crumb.label}</span>
                )}
              </li>
            );
          })}
        </ol>
      </div>
    </nav>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </>
)}

<style>
  .breadcrumbs {
    background: #f8fafc;
    border-bottom: 1px solid #e5e7eb;
    padding: 0.55rem 0;
  }

  .breadcrumbs-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .breadcrumbs-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0;
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 0.875rem;
    line-height: 1.4;
    color: #64748b;
  }

  .breadcrumbs-item {
    display: inline-flex;
    align-items: center;
    max-width: 100%;
  }

  .breadcrumbs-item:not(:last-child)::after {
    content: '›';
    margin: 0 0.4rem;
    color: #94a3b8;
    font-weight: 600;
  }

  .breadcrumbs-item a {
    color: #1e3a8a;
    text-decoration: none;
    font-weight: 500;
  }

  .breadcrumbs-item a:hover {
    text-decoration: underline;
  }

  .breadcrumbs-item span {
    color: #334155;
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  @media (max-width: 768px) {
    .breadcrumbs {
      padding: 0.5rem 0;
    }

    .breadcrumbs-list {
      font-size: 0.8rem;
    }
  }
</style>
