---
const { lang = 'de' } = Astro.props;
const isEn = lang === 'en';

const spenden = isEn
  ? { href: '/en/donate', label: 'Donate' }
  : { href: '/spenden', label: 'Spenden' };

const mitglied = isEn
  ? { href: '/mitglied-werden', label: 'Become a member' }
  : { href: '/mitglied-werden', label: 'Mitglied werden' };
---

<aside
  class="float-cta no-print"
  data-float-cta
  aria-label={isEn ? 'Support the association' : 'Verein unterstützen'}
>
  <a href={mitglied.href} class="float-cta-btn float-cta-btn-primary">
    {mitglied.label}
  </a>
  <a href={spenden.href} class="float-cta-btn float-cta-btn-secondary">
    {spenden.label}
  </a>
</aside>

<script>
  function initFloatingCta() {
    const el = document.querySelector('[data-float-cta]');
    if (!(el instanceof HTMLElement)) return;

    const reveal = () => {
      if (window.scrollY > 320) el.classList.add('is-visible');
      else el.classList.remove('is-visible');
    };

    reveal();
    window.addEventListener('scroll', reveal, { passive: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFloatingCta, { once: true });
  } else {
    initFloatingCta();
  }
</script>

<style>
  .float-cta {
    position: fixed;
    right: 1rem;
    bottom: 1.25rem;
    z-index: 45;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.55rem;
    max-width: 12rem;
    pointer-events: none;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .float-cta.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .float-cta-btn {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0.7rem 1.1rem;
    font-weight: 600;
    font-size: 0.88rem;
    line-height: 1.25;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, color 0.2s ease,
      border-color 0.2s ease;
  }

  .float-cta-btn-primary {
    background: var(--cta-grad);
    color: #ffffff;
    border: 1px solid transparent;
    box-shadow: var(--cta-shadow);
  }

  .float-cta-btn-primary:hover {
    background: var(--cta-grad-hover);
    transform: translateY(-2px);
    box-shadow: var(--cta-shadow-hover);
  }

  .float-cta-btn-secondary {
    background: rgba(255, 255, 255, 0.92);
    color: #12365e;
    border: 1px solid #89a6cc;
    box-shadow: 0 8px 20px rgba(15, 46, 80, 0.12);
    backdrop-filter: blur(6px);
  }

  .float-cta-btn-secondary:hover {
    background: var(--primary);
    color: #ffffff;
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(15, 46, 80, 0.25);
  }

  .float-cta-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .float-cta {
      right: 0.75rem;
      bottom: 0.85rem;
      max-width: 10.5rem;
      gap: 0.45rem;
    }

    .float-cta-btn {
      padding: 0.6rem 0.85rem;
      font-size: 0.82rem;
    }
  }

  @media (max-width: 480px) {
    .float-cta {
      right: 0.5rem;
      bottom: 0.65rem;
      max-width: 9.25rem;
    }

    .float-cta-btn {
      padding: 0.55rem 0.7rem;
      font-size: 0.78rem;
    }
  }

  @media print {
    .float-cta {
      display: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .float-cta,
    .float-cta-btn {
      transition: none;
    }

    .float-cta-btn:hover {
      transform: none;
    }
  }
</style>
