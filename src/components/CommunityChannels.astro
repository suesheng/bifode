---
import {
  FB_PAGE_BIFODE,
  MOODLE_INFO_PATH,
  telegramIsraelHubUrl,
} from '../lib/communityLinks';

interface Props {
  lang?: 'de' | 'en';
}

const { lang = 'de' } = Astro.props;
const isEn = lang === 'en';
const telegramUrl = telegramIsraelHubUrl();

const copy = isEn
  ? {
      title: 'News & dates',
      lead: 'News and event dates are published on our Facebook page. Ulpan Next, Moodle, and other programmes are available after membership.',
      fbPage: 'BiFoDe on Facebook',
      fbPageHint: 'News, dates, and updates from BiFoDe e.V.',
      ulpan: 'Ulpan Next',
      ulpanHint: 'Hebrew education project — see Projects',
      moodle: 'Moodle',
      moodleHint: 'Learning platform for members — membership required',
      tg: 'Telegram',
      membership: 'Membership',
      membershipHint: 'Apply for admission to BiFoDe e.V.',
    }
  : {
      title: 'Aktuelles & Termine',
      lead: 'Neuigkeiten und Termine veröffentlichen wir auf unserer Facebook-Seite. Ulpan Next, Moodle und weitere Angebote sind nach Aufnahme als Mitglied verfügbar.',
      fbPage: 'BiFoDe auf Facebook',
      fbPageHint: 'Aktuelles, Termine und Beiträge von BiFoDe e.V.',
      ulpan: 'Ulpan Next',
      ulpanHint: 'Bildungsprojekt Hebräisch — unter Projekte',
      moodle: 'Moodle',
      moodleHint: 'Lernplattform für Mitglieder — Aufnahme im Verein erforderlich',
      tg: 'Telegram',
      membership: 'Mitgliedschaft',
      membershipHint: 'Aufnahme bei BiFoDe e.V. beantragen',
    };
---

<section class="container community-channels">
  <div class="section-header">
    <h2>{copy.title}</h2>
  </div>
  <p class="community-channels-lead">{copy.lead}</p>
  <div class="community-channels-grid">
    <a
      class="card community-channel-card"
      href={FB_PAGE_BIFODE}
      target="_blank"
      rel="noopener noreferrer"
    >
      <h3>{copy.fbPage}</h3>
      <p>{copy.fbPageHint}</p>
      <span class="community-channel-cta">{isEn ? 'Open page →' : 'Seite öffnen →'}</span>
    </a>
    <a class="card community-channel-card" href={isEn ? '/en/projects' : '/projekte'}>
      <h3>{copy.ulpan}</h3>
      <p>{copy.ulpanHint}</p>
      <span class="community-channel-cta">{isEn ? 'View projects →' : 'Zu den Projekten →'}</span>
    </a>
    <a class="card community-channel-card" href={isEn ? '/en/moodle' : MOODLE_INFO_PATH}>
      <h3>{copy.moodle}</h3>
      <p>{copy.moodleHint}</p>
      <span class="community-channel-cta">{isEn ? 'About Moodle →' : 'Zur Moodle-Seite →'}</span>
    </a>
    {
      telegramUrl ? (
        <a
          class="card community-channel-card"
          href={telegramUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <h3>{copy.tg}</h3>
          <p>{isEn ? 'Channel updates' : 'Kanal-Updates'}</p>
          <span class="community-channel-cta">{isEn ? 'Open Telegram →' : 'Telegram öffnen →'}</span>
        </a>
      ) : null
    }
    <a class="card community-channel-card" href="/mitglied-werden">
      <h3>{copy.membership}</h3>
      <p>{copy.membershipHint}</p>
      <span class="community-channel-cta">{isEn ? 'Apply for membership →' : 'Mitglied werden →'}</span>
    </a>
  </div>
</section>

<style>
  .community-channels {
    margin-block: 2.5rem 3rem;
  }

  .community-channels-lead {
    max-width: 720px;
    color: #475569;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .community-channels-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .community-channel-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .community-channel-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 14px var(--accent-tint);
  }

  .community-channel-card h3 {
    font-size: 1.1rem;
    margin: 0;
    color: #111827;
  }

  .community-channel-card p {
    margin: 0;
    flex: 1;
    font-size: 0.95rem;
    color: #64748b;
    line-height: 1.5;
  }

  .community-channel-cta {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--primary);
  }

  .community-channel-card--muted {
    pointer-events: auto;
  }

  .community-channel-card--muted a {
    color: var(--primary);
    font-weight: 600;
  }
</style>
