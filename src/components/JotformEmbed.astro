---
/**
 * Jotform iframe with official embed handler (auto height, scrolling="no").
 * Pass full publish URL, e.g. https://form.jotform.com/261212926350046
 *
 * Embed handler script loads only when the block is near the viewport and the user
 * has scrolled, typed, tapped, or used the wheel; if the block stays in view without
 * interaction, it loads after 5s so passive readers still get the form.
 */
interface Props {
  formUrl: string;
  title: string;
  /** e.g. "de" when the form UI is German on an English page */
  iframeLang?: string;
  /** Match a white page section — sets Jotform background to #fff */
  flush?: boolean;
}

const { formUrl, title, iframeLang, flush = false } = Astro.props;

let formId = '';
let embedSrc = formUrl;
let originBase = 'https://form.jotform.com/';

try {
  const u = new URL(formUrl);
  originBase = `${u.origin}/`;
  const m = u.pathname.match(/\/(\d+)\/?$/);
  formId = m?.[1] ?? '';
  u.searchParams.set('isIframeEmbed', '1');
  if (flush) {
    u.searchParams.set('background', 'ffffff');
    u.searchParams.set('bgcolor', 'ffffff');
    u.searchParams.set('fontcolor', '0c1e34');
    u.searchParams.set('headercolor', 'ffffff');
  }
  embedSrc = u.href;
} catch {
  /* keep raw formUrl */
}

const frameId = formId ? `JotFormIFrame-${formId}` : 'JotFormIFrame-embed';
---

<div class:list={['jotform-embed-root', flush && 'jotform-embed-root--flush']}>
  <iframe
    id={frameId}
    title={title}
    lang={iframeLang}
    src={embedSrc}
    allow="geolocation; microphone; camera; fullscreen; payment"
    allowtransparency="true"
    loading="lazy"
    scrolling="no"
    class="jotform-iframe"
  />
</div>

<script is:inline define:vars={{ frameId, originBase }}>
  (function () {
    var iframe = document.getElementById(frameId);
    var root = iframe && iframe.closest ? iframe.closest('.jotform-embed-root') : null;
    var target = root || iframe;
    if (!iframe || !target) return;

    function run() {
      if (typeof window.jotformEmbedHandler === 'function') {
        window.jotformEmbedHandler("iframe[id='" + frameId + "']", originBase);
      }
    }

    function injectScript() {
      var existing = document.querySelector('script[data-jotform-embed-handler]');
      if (existing) {
        run();
        return;
      }
      var s = document.createElement('script');
      s.src = 'https://cdn.jotfor.ms/s/umd/latest/for-form-embed-handler.js';
      s.async = true;
      s.setAttribute('data-jotform-embed-handler', '1');
      s.onload = run;
      document.head.appendChild(s);
      if (typeof window.jotformEmbedHandler === 'function') run();
    }

    /** Load only when embed is near viewport AND user has scrolled/typed/tapped (reduces main-thread work). Fallback: load after 5s in view for passive readers. */
    var inView = false;
    var engaged = false;
    var done = false;
    var fallbackTimer;
    var io;

    function clearFallback() {
      if (fallbackTimer) {
        clearTimeout(fallbackTimer);
        fallbackTimer = null;
      }
    }

    function detachEngagement() {
      window.removeEventListener('pointerdown', onEngage, true);
      window.removeEventListener('keydown', onEngage, true);
      window.removeEventListener('scroll', onEngage, true);
      window.removeEventListener('touchstart', onEngage, true);
      window.removeEventListener('wheel', onEngage, true);
    }

    function onEngage() {
      if (engaged) return;
      engaged = true;
      detachEngagement();
      tryInject();
    }

    function tryInject() {
      if (done) return;
      if (!inView || !engaged) return;
      done = true;
      clearFallback();
      detachEngagement();
      if (io) {
        io.disconnect();
        io = null;
      }
      injectScript();
    }

    function onEnterViewport() {
      inView = true;
      tryInject();
      if (done) return;
      clearFallback();
      fallbackTimer = setTimeout(function () {
        engaged = true;
        tryInject();
      }, 5000);
    }

    function attachEngagement() {
      window.addEventListener('pointerdown', onEngage, { capture: true, passive: true });
      window.addEventListener('keydown', onEngage, { capture: true, passive: true });
      window.addEventListener('scroll', onEngage, { capture: true, passive: true });
      window.addEventListener('touchstart', onEngage, { capture: true, passive: true });
      window.addEventListener('wheel', onEngage, { capture: true, passive: true });
    }

    if (!('IntersectionObserver' in window)) {
      inView = true;
      engaged = true;
      tryInject();
      return;
    }

    io = new IntersectionObserver(
      function (entries) {
        for (var i = 0; i < entries.length; i++) {
          if (entries[i].isIntersecting) {
            io.disconnect();
            io = null;
            onEnterViewport();
            return;
          }
        }
      },
      { rootMargin: '160px', threshold: 0.01 }
    );
    io.observe(target);
    attachEngagement();
  })();
</script>

<style>
  .jotform-embed-root {
    width: 100%;
    line-height: 0;
  }

  .jotform-iframe {
    display: block;
    width: 1px;
    min-width: 100%;
    max-width: 100%;
    height: 720px;
    margin: 0;
    padding: 0;
    border: 0;
  }
  .jotform-embed-root--flush {
    background: #fff;
  }

  .jotform-embed-root--flush .jotform-iframe {
    background: transparent;
  }
</style>
