---
/**
 * Jotform iframe with official embed handler (auto height, scrolling="no").
 * Pass full publish URL, e.g. https://form.jotform.com/261212926350046
 */
interface Props {
  formUrl: string;
  title: string;
  /** e.g. "de" when the form UI is German on an English page */
  iframeLang?: string;
}

const { formUrl, title, iframeLang } = Astro.props;

let formId = '';
let embedSrc = formUrl;
let originBase = 'https://form.jotform.com/';

try {
  const u = new URL(formUrl);
  originBase = `${u.origin}/`;
  const m = u.pathname.match(/\/(\d+)\/?$/);
  formId = m?.[1] ?? '';
  u.searchParams.set('isIframeEmbed', '1');
  embedSrc = u.href;
} catch {
  /* keep raw formUrl */
}

const frameId = formId ? `JotFormIFrame-${formId}` : 'JotFormIFrame-embed';
---

<div class="jotform-embed-root">
  <iframe
    id={frameId}
    title={title}
    lang={iframeLang}
    src={embedSrc}
    allow="geolocation; microphone; camera; fullscreen; payment"
    loading="lazy"
    scrolling="no"
    class="jotform-iframe"
  />
</div>

<script is:inline define:vars={{ frameId, originBase }}>
  (function () {
    function run() {
      if (typeof window.jotformEmbedHandler === 'function') {
        window.jotformEmbedHandler("iframe[id='" + frameId + "']", originBase);
      }
    }
    var existing = document.querySelector('script[data-jotform-embed-handler]');
    if (existing) {
      run();
      return;
    }
    var s = document.createElement('script');
    s.src = 'https://cdn.jotfor.ms/s/umd/latest/for-form-embed-handler.js';
    s.async = true;
    s.setAttribute('data-jotform-embed-handler', '1');
    s.onload = run;
    document.head.appendChild(s);
    if (typeof window.jotformEmbedHandler === 'function') run();
  })();
</script>

<style>
  .jotform-embed-root {
    width: 100%;
    line-height: 0;
  }

  .jotform-iframe {
    display: block;
    width: 1px;
    min-width: 100%;
    max-width: 100%;
    height: 720px;
    margin: 0;
    padding: 0;
    border: 0;
  }
</style>
