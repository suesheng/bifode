---
const {
  label,
  partnerTitle,
  cooperationHref,
  cooperationLabel,
  mobileHidden = true,
} = Astro.props as {
  label: string;
  partnerTitle?: string;
  cooperationHref?: string;
  cooperationLabel?: string;
  mobileHidden?: boolean;
};
---

<section class={`trust-section ${mobileHidden ? 'mobile-hidden' : ''}`}>
  <div class="container trust-content">
    {partnerTitle && <h2 class="trust-partner-title">{partnerTitle}</h2>}
    <p class="trust-label">{label}</p>
    <div class="trust-logos">
      <img src="/logos/logo1.png" alt="Partner logo" />
      <img src="/logos/logo2.svg" alt="Partner logo" />
      <img src="/logos/logo3.svg" alt="Partner logo" />
      <img src="/logos/logo4.svg" alt="Partner logo" />
      <img src="/logos/logo5.svg" alt="Partner logo" />
    </div>
    {cooperationHref && cooperationLabel && (
      <p class="trust-cooperation">
        <a href={cooperationHref}>{cooperationLabel}</a>
      </p>
    )}
  </div>
</section>

<style>
  .trust-section {
    padding: 2.5rem 0 3rem;
  }

  .trust-content {
    text-align: center;
  }

  .trust-partner-title {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.02em;
  }

  .trust-label {
    font-size: 0.9rem;
    color: #9ca3af;
    margin-bottom: 1.5rem;
  }

  .trust-logos {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .trust-logos img {
    height: 80px;
    opacity: 0.6;
    filter: grayscale(100%);
    transition: all 0.2s ease;
  }

  .trust-logos img:hover {
    opacity: 1;
    filter: grayscale(0%);
  }

  .trust-cooperation {
    margin: 1.25rem 0 0;
    font-size: 0.9rem;
  }

  .trust-cooperation a {
    color: #163b63;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(22, 59, 99, 0.35);
  }

  .trust-cooperation a:hover {
    color: #0f2e50;
    border-bottom-color: #0f2e50;
  }

  @media (max-width: 768px) {
    .trust-section.mobile-hidden {
      display: none;
    }

    .trust-logos img {
      height: 64px;
    }
  }
</style>
