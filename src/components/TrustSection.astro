---
import PartnerGrid from './PartnerGrid.astro';

const {
  label,
  partnerTitle,
  cooperationHref,
  cooperationLabel,
  mobileHidden = false,
} = Astro.props as {
  label: string;
  partnerTitle?: string;
  cooperationHref?: string;
  cooperationLabel?: string;
  mobileHidden?: boolean;
};
---

<section class={`trust-section ${mobileHidden ? 'mobile-hidden' : ''}`}>
  <div class="container trust-content">
    {partnerTitle && <h2 class="trust-partner-title">{partnerTitle}</h2>}
    <p class="trust-label">{label}</p>
    <PartnerGrid />
    {cooperationHref && cooperationLabel && (
      <p class="trust-cooperation">
        <a href={cooperationHref}>{cooperationLabel}</a>
      </p>
    )}
  </div>
</section>

<style>
  .trust-section {
    padding: 2.5rem 0 3rem;
  }

  .trust-content {
    text-align: center;
  }

  .trust-partner-title {
    margin: 0 0 0.35rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.02em;
  }

  .trust-label {
    font-size: 0.95rem;
    color: #64748b;
    margin-bottom: 0.5rem;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .trust-cooperation {
    margin: 1.5rem 0 0;
    font-size: 0.9rem;
  }

  .trust-cooperation a {
    color: #163b63;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(22, 59, 99, 0.35);
  }

  .trust-cooperation a:hover {
    color: #0f2e50;
    border-bottom-color: #0f2e50;
  }

  @media (max-width: 768px) {
    .trust-section.mobile-hidden {
      display: none;
    }
  }
</style>
