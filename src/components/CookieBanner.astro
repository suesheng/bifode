---
// src/components/CookieBanner.astro
---

<div id="cookie-banner" class="cookie-banner" role="dialog" aria-live="polite" aria-label="Cookie-Einstellungen">
  <div class="cookie-banner-content">
    <div class="cookie-banner-text">
      <h3>Cookies & Datenschutz</h3>
      <p>
        Wir nutzen notwendige Cookies für den Betrieb der Website. Optionale Cookies helfen uns bei Analyse
        und Weiterentwicklung unserer Inhalte. Sie können Ihre Einwilligung jederzeit anpassen.
      </p>
    </div>

    <div class="cookie-banner-actions">
      <button id="cookie-settings" class="btn btn-secondary" type="button">Einstellungen</button>
      <button id="cookie-essential" class="btn btn-outline" type="button">Nur notwendige</button>
      <button id="cookie-accept-all" class="btn btn-primary" type="button">Alle akzeptieren</button>
    </div>

    <div id="cookie-details" class="cookie-details" hidden>
      <div class="cookie-intro">
        <p>Wählen Sie aus, welche optionalen Kategorien Sie zulassen möchten.</p>
      </div>

      <div class="cookie-category">
        <div class="cookie-category-header">
          <h4>Notwendige Cookies</h4>
          <input type="checkbox" checked disabled />
          <span class="cookie-status required">Immer aktiv</span>
        </div>
        <p>Diese Cookies sind technisch erforderlich und können nicht deaktiviert werden.</p>
      </div>

      <div class="cookie-category">
        <div class="cookie-category-header">
          <h4>Funktionale Cookies</h4>
          <input type="checkbox" id="functional-cookies" />
          <span class="cookie-status optional">Optional</span>
        </div>
        <p>Speichern Komforteinstellungen wie z. B. Sprache und Darstellung.</p>
      </div>

      <div class="cookie-category">
        <div class="cookie-category-header">
          <h4>Analyse-Cookies</h4>
          <input type="checkbox" id="analytics-cookies" />
          <span class="cookie-status optional">Optional</span>
        </div>
        <p>Helfen uns zu verstehen, welche Inhalte genutzt werden, damit wir das Angebot verbessern können.</p>
      </div>

      <div class="cookie-category">
        <div class="cookie-category-header">
          <h4>Marketing-Cookies</h4>
          <input type="checkbox" id="marketing-cookies" />
          <span class="cookie-status optional">Optional</span>
        </div>
        <p>Ermöglichen Reichweitenmessung und ggf. personalisierte Ausspielung auf Drittplattformen.</p>
      </div>

      <div class="cookie-details-actions">
        <button id="cookie-save-settings" class="btn btn-primary" type="button">Auswahl speichern</button>
        <button id="cookie-accept-all-detailed" class="btn btn-secondary" type="button">Alle akzeptieren</button>
        <button id="cookie-reject-all" class="btn btn-outline" type="button">Alle ablehnen</button>
      </div>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: white;
    border-top: 1px solid #e5e7eb;
    box-shadow: 0 -4px 6px -1px rgba(0, 0, 0, 0.1);
    z-index: 1000;
    transform: translateY(100%);
    transition: transform 0.3s ease-in-out;
  }

  .cookie-banner.show {
    transform: translateY(0);
  }

  .cookie-banner-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem;
  }

  .cookie-banner-text h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: #111827;
  }

  .cookie-banner-text p {
    margin: 0 0 1rem 0;
    color: #6b7280;
    line-height: 1.5;
  }

  .cookie-banner-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .btn-primary {
    background-color: #163b63;
    color: white;
  }

  .btn-primary:hover {
    background-color: #0f2e50;
  }

  .btn-secondary {
    background-color: #334155;
    color: white;
  }

  .btn-secondary:hover {
    background-color: #4b5563;
  }

  .btn-outline {
    background-color: transparent;
    color: #163b63;
    border: 1px solid #163b63;
  }

  .btn-outline:hover {
    background-color: #163b63;
    color: white;
  }

  .cookie-details {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e7eb;
  }

  .cookie-intro {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .cookie-intro p {
    margin: 0;
    color: #6b7280;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .cookie-category {
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: #f9fafb;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }

  .cookie-category:last-child {
    margin-bottom: 0;
  }

  .cookie-category-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .cookie-category-header h4 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: #111827;
  }

  .cookie-status {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }

  .cookie-status.required {
    color: #065f46;
    background: #ecfdf5;
  }

  .cookie-status.optional {
    color: #334155;
    background: #e2e8f0;
  }

  .cookie-category p {
    margin: 0 0 0.75rem 0;
    color: #6b7280;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .cookie-examples {
    font-size: 0.8125rem;
    color: #4b5563;
    line-height: 1.4;
  }

  .cookie-details-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e7eb;
  }

  @media (max-width: 640px) {
    .cookie-banner-actions {
      flex-direction: column;
    }

    .cookie-banner-actions .btn {
      width: 100%;
    }

    .cookie-details-actions {
      flex-direction: column;
    }

    .cookie-details-actions .btn {
      width: 100%;
    }
  }
</style>

<script>
  const COOKIE_STORAGE_KEY = 'cookie-consent-v1';
  type Consent = {
    essential: boolean;
    functional: boolean;
    analytics: boolean;
    marketing: boolean;
    updatedAt: number;
  };

  const defaultConsent: Consent = {
    essential: true,
    functional: false,
    analytics: false,
    marketing: false,
    updatedAt: 0
  };

  function readConsent(): Consent | null {
    const saved = localStorage.getItem(COOKIE_STORAGE_KEY);
    if (!saved) return null;
    try {
      const parsed = JSON.parse(saved);
      return { ...defaultConsent, ...parsed, essential: true };
    } catch {
      return null;
    }
  }

  function persistConsent(consent: Partial<Consent>): Consent {
    const payload = { ...defaultConsent, ...consent, essential: true, updatedAt: Date.now() };
    localStorage.setItem(COOKIE_STORAGE_KEY, JSON.stringify(payload));
    window.dispatchEvent(new CustomEvent('cookie-consent-changed', { detail: payload }));
    return payload;
  }

  function initCookieBanner() {
    const banner = document.getElementById('cookie-banner');
    const details = document.getElementById('cookie-details');
    const settingsBtn = document.getElementById('cookie-settings');
    const essentialBtn = document.getElementById('cookie-essential');
    const acceptAllBtn = document.getElementById('cookie-accept-all');
    const saveSettingsBtn = document.getElementById('cookie-save-settings');
    const acceptAllDetailedBtn = document.getElementById('cookie-accept-all-detailed');
    const rejectAllBtn = document.getElementById('cookie-reject-all');
    const functionalCheckbox = document.getElementById('functional-cookies');
    const analyticsCheckbox = document.getElementById('analytics-cookies');
    const marketingCheckbox = document.getElementById('marketing-cookies');

    if (
      !banner ||
      !details ||
      !settingsBtn ||
      !essentialBtn ||
      !acceptAllBtn ||
      !saveSettingsBtn ||
      !acceptAllDetailedBtn ||
      !rejectAllBtn ||
      !(functionalCheckbox instanceof HTMLInputElement) ||
      !(analyticsCheckbox instanceof HTMLInputElement) ||
      !(marketingCheckbox instanceof HTMLInputElement)
    ) {
      return;
    }

    const bannerEl = banner as HTMLElement;
    const detailsEl = details as HTMLElement;
    const settingsBtnEl = settingsBtn as HTMLElement;
    const essentialBtnEl = essentialBtn as HTMLElement;
    const acceptAllBtnEl = acceptAllBtn as HTMLElement;
    const saveSettingsBtnEl = saveSettingsBtn as HTMLElement;
    const acceptAllDetailedBtnEl = acceptAllDetailedBtn as HTMLElement;
    const rejectAllBtnEl = rejectAllBtn as HTMLElement;
    const functionalInput = functionalCheckbox as HTMLInputElement;
    const analyticsInput = analyticsCheckbox as HTMLInputElement;
    const marketingInput = marketingCheckbox as HTMLInputElement;

    function syncCheckboxes(consent: Consent) {
      functionalInput.checked = Boolean(consent.functional);
      analyticsInput.checked = Boolean(consent.analytics);
      marketingInput.checked = Boolean(consent.marketing);
    }

    function openBanner(withDetails = false) {
      bannerEl.style.display = '';
      bannerEl.classList.add('show');
      detailsEl.hidden = !withDetails;
    }

    function closeBanner() {
      bannerEl.classList.remove('show');
      setTimeout(() => {
        bannerEl.style.display = 'none';
      }, 300);
    }

    function saveCurrentSelection() {
      const consent = persistConsent({
        functional: functionalInput.checked,
        analytics: analyticsInput.checked,
        marketing: marketingInput.checked
      });
      syncCheckboxes(consent);
      closeBanner();
    }

    const existingConsent = readConsent();
    if (existingConsent) {
      syncCheckboxes(existingConsent);
      bannerEl.style.display = 'none';
    } else {
      setTimeout(() => openBanner(false), 500);
    }

    settingsBtnEl.addEventListener('click', () => {
      detailsEl.hidden = !detailsEl.hidden;
    });

    essentialBtnEl.addEventListener('click', () => {
      const consent = persistConsent({ functional: false, analytics: false, marketing: false });
      syncCheckboxes(consent);
      closeBanner();
    });

    acceptAllBtnEl.addEventListener('click', () => {
      const consent = persistConsent({ functional: true, analytics: true, marketing: true });
      syncCheckboxes(consent);
      closeBanner();
    });

    saveSettingsBtnEl.addEventListener('click', saveCurrentSelection);

    acceptAllDetailedBtnEl.addEventListener('click', () => {
      const consent = persistConsent({ functional: true, analytics: true, marketing: true });
      syncCheckboxes(consent);
      closeBanner();
    });

    rejectAllBtnEl.addEventListener('click', () => {
      const consent = persistConsent({ functional: false, analytics: false, marketing: false });
      syncCheckboxes(consent);
      closeBanner();
    });

    window.addEventListener('open-cookie-settings', () => {
      const consent = readConsent() || defaultConsent;
      syncCheckboxes(consent);
      openBanner(true);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCookieBanner, { once: true });
  } else {
    initCookieBanner();
  }
</script>